          </div>`;
      }).join('');
    }

    /* ── Correct answer footer ───────────────────────────── */
    const footerEl = document.getElementById('qd-correct-footer');
    if (footerEl) {
      footerEl.innerHTML = `<strong style="color:var(--text-main)">Correct answer:</strong> ${question.answer}`;
    }

  })();
  </script>

</body>
</html>