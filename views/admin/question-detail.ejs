        <p style="color:var(--text-subdued)">Loading question…</p>
      </div>

    </main>
  </div>

  <script src="/js/admin-shell.js"></script>
  <script>
  (async () => {

    /* ── Get question ID from URL ────────────────────────── */
    const qid = parseInt(window.location.pathname.split('/').pop(), 10);
    const emptyEl = document.getElementById('qd-empty');

    if (!qid) {
      if (emptyEl) emptyEl.querySelector('p').textContent = 'Invalid question ID.';
      return;
    }

    /* ── Fetch all questions and find the one we need ────── */
    let question;
    try {
      const r = await fetch('/admin/api/questions');
      if (!r.ok) throw new Error('fetch failed');
      const data = await r.json();
      question = (data.questions || []).find(q => q.id === qid);
    } catch (_) {
      if (emptyEl) emptyEl.querySelector('p').textContent = 'Failed to load question.';
      return;
    }

    if (!question) {
      if (emptyEl) {
        emptyEl.querySelector('div').textContent = '🔍';
        emptyEl.querySelector('p').textContent   = 'Question #' + qid + ' not found.';
      }
      return;
    }

    /* ── Hide loading, show card ─────────────────────────── */
    if (emptyEl) emptyEl.style.display = 'none';
    const card = document.getElementById('qd-card');
    if (card) card.style.display = '';

    /* ── Domain class helper ─────────────────────────────── */
    function domainClass(d) {
      if (d === 'Verbal Ability')    return 'verbal';
      if (d === 'Numerical Ability') return 'numerical';
      if (d === 'Clerical Ability')  return 'clerical';
      return 'general';
    }

    /* ── Meta chips ──────────────────────────────────────── */
    const metaEl = document.getElementById('qd-meta');
    if (metaEl) {
      const diffStyle = question.difficulty === 'Hard' ? ' hard' : '';
      metaEl.innerHTML =
        `<span class="qb-num">#${question.id}</span>` +
        `<span class="q-domain-badge ${domainClass(question.domain)}">${question.domain.replace(' Ability', '')}</span>` +
        `<span class="q-difficulty${diffStyle}">${question.difficulty}</span>`;
      document.title = 'Question #' + question.id + ' | Hauers Admin';
    }

    /* ── Question text ───────────────────────────────────── */
    const qTextEl = document.getElementById('qd-question');
    if (qTextEl) qTextEl.textContent = question.question;

    /* ── Choices ─────────────────────────────────────────── */
    const choicesEl = document.getElementById('qd-choices');
    if (choicesEl) {
      const letters = ['A', 'B', 'C', 'D'];
      choicesEl.innerHTML = question.choices.map((choice, i) => {
