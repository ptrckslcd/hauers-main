<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Question Detail | Hauers Admin</title>
  <link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <script src="/js/theme-toggle.js"></script>
</head>
<body data-role="admin">

  <div id="navbar-placeholder"><%- include('../partials/navbar') %></div>

  <div class="app-shell sidebar-collapsed">
    <div class="sidebar-overlay" id="sidebar-overlay"></div>
    <div id="sidebar-placeholder"><%- include('../partials/admin-sidebar') %></div>

    <main class="page-content">

      <a href="/admin/question-bank" class="qd-back-link">
        <span class="material-symbols-outlined" style="font-size:1.1rem;vertical-align:-3px">arrow_back</span>
        Question Bank
      </a>

      <!-- Loading skeleton -->
      <div id="qd-loading" class="dash-card qd-loading-card">
        <span class="material-symbols-outlined" style="font-size:2rem;opacity:.3;margin-bottom:.5rem">hourglass_empty</span>
        <p style="font-size:.88rem;color:var(--text-subdued)">Loading question…</p>
      </div>

      <!-- Main content (shown after load) -->
      <div id="qd-content" hidden>

        <!-- Page header -->
        <header class="page-header qd-detail-header">
          <div>
            <div class="qd-breadcrumb" id="qd-breadcrumb"></div>
            <h1 class="page-title" id="qd-heading">Question</h1>
          </div>
          <div class="qd-header-actions">
            <button type="button" class="bat-btn-secondary" id="qd-edit-btn">
              <span class="material-symbols-outlined">edit</span>
              Edit
            </button>
            <button type="button" id="qd-arch-btn" class="bat-btn-ghost qd-arch-ghost">
              <span class="material-symbols-outlined">archive</span>
              Archive
            </button>
          </div>
        </header>

        <!-- 2-col layout -->
        <div class="pgx-grid-2 qd-grid">

          <!-- Left: question body -->
          <div style="display:flex;flex-direction:column;gap:1.25rem">

            <!-- Question text + choices -->
            <div class="dash-card qd-question-card">
              <p class="pgx-section-label">Question</p>
              <p class="qd-question-text" id="qd-qtext">—</p>

              <div class="qd-choices" id="qd-choices"></div>

              <div class="qd-expl-section" id="qd-expl-section" hidden>
                <p class="pgx-section-label" style="margin-top:1.25rem">Explanation</p>
                <p class="qd-expl-text" id="qd-expl">—</p>
              </div>
            </div>

          </div>

          <!-- Right: metadata + usage -->
          <div style="display:flex;flex-direction:column;gap:1.25rem">

            <!-- Metadata card -->
            <div class="dash-card">
              <p class="pgx-section-label">Metadata</p>
              <div class="qd-meta-grid">
                <div class="qd-meta-item">
                  <span class="qd-meta-lbl">Status</span>
                  <span id="qd-status">—</span>
                </div>
                <div class="qd-meta-item">
                  <span class="qd-meta-lbl">Difficulty</span>
                  <span id="qd-difficulty">—</span>
                </div>
                <div class="qd-meta-item">
                  <span class="qd-meta-lbl">Exam level</span>
                  <span class="qd-meta-val" id="qd-level">—</span>
                </div>
                <div class="qd-meta-item">
                  <span class="qd-meta-lbl">M-Elo rating</span>
                  <span class="qd-meta-val qd-melo" id="qd-melo">—</span>
                </div>
                <div class="qd-meta-item qd-meta-full">
                  <span class="qd-meta-lbl">Domain tags</span>
                  <div id="qd-domains" style="display:flex;flex-wrap:wrap;gap:.35rem;margin-top:.35rem"></div>
                </div>
                <div class="qd-meta-item">
                  <span class="qd-meta-lbl">Created</span>
                  <span class="qd-meta-val" id="qd-created">—</span>
                </div>
                <div class="qd-meta-item">
                  <span class="qd-meta-lbl">Last updated</span>
                  <span class="qd-meta-val" id="qd-updated">—</span>
                </div>
              </div>
            </div>

            <!-- Usage stats card -->
            <div class="dash-card">
              <p class="pgx-section-label">Usage statistics</p>
              <div class="qd-usage-row">
                <div class="qd-usage-cell">
                  <span class="qd-usage-n" id="qd-seen">—</span>
                  <span class="qd-usage-lbl">Times seen</span>
                </div>
                <div class="qd-usage-div"></div>
                <div class="qd-usage-cell">
                  <span class="qd-usage-n" id="qd-correct">—</span>
                  <span class="qd-usage-lbl">Times correct</span>
                </div>
                <div class="qd-usage-div"></div>
                <div class="qd-usage-cell">
                  <span class="qd-usage-n" id="qd-acc">—</span>
                  <span class="qd-usage-lbl">Accuracy</span>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>

    </main>
  </div>

  <!-- Edit modal (reuses question-bank form pattern) -->
  <div class="bat-modal-overlay" id="qd-edit-modal" hidden>
    <div class="bat-modal qk-modal-wide" role="dialog" aria-modal="true" aria-labelledby="qd-edit-title">
      <div class="bat-modal-head">
        <h2 class="bat-modal-title" id="qd-edit-title">Edit question</h2>
        <button type="button" class="bat-modal-x" id="qd-em-close" aria-label="Close"><span class="material-symbols-outlined">close</span></button>
      </div>
      <form id="qd-edit-form" class="bat-modal-form" autocomplete="off" novalidate>

        <div class="bat-field bat-field--full" style="margin-bottom:.9rem">
          <label class="bat-field-lbl" for="qde-text">Question text <span class="qk-req">*</span></label>
          <textarea class="bat-input qk-textarea" id="qde-text" rows="3" required></textarea>
        </div>

        <div class="bat-field bat-field--full" style="margin-bottom:.9rem">
          <label class="bat-field-lbl">Choices <span class="qk-req">*</span></label>
          <div class="qk-choices-grid">
            <div class="qk-choice-row"><span class="qk-choice-lbl">A</span><input class="bat-input qk-choice-input" id="qde-ca" type="text" required data-letter="a"></div>
            <div class="qk-choice-row"><span class="qk-choice-lbl">B</span><input class="bat-input qk-choice-input" id="qde-cb" type="text" required data-letter="b"></div>
            <div class="qk-choice-row"><span class="qk-choice-lbl">C</span><input class="bat-input qk-choice-input" id="qde-cc" type="text" required data-letter="c"></div>
            <div class="qk-choice-row"><span class="qk-choice-lbl">D</span><input class="bat-input qk-choice-input" id="qde-cd" type="text" required data-letter="d"></div>
          </div>
        </div>

        <div class="bat-field bat-field--full" style="margin-bottom:.9rem">
          <label class="bat-field-lbl">Correct answer <span class="qk-req">*</span></label>
          <div class="qk-correct-row">
            <label class="qk-correct-opt" data-letter="a"><input type="radio" name="qde-correct" value="a" class="qk-radio"><span class="qk-correct-badge">A</span><span class="qk-correct-text" id="qde-ct-a">Choice A</span></label>
            <label class="qk-correct-opt" data-letter="b"><input type="radio" name="qde-correct" value="b" class="qk-radio"><span class="qk-correct-badge">B</span><span class="qk-correct-text" id="qde-ct-b">Choice B</span></label>
            <label class="qk-correct-opt" data-letter="c"><input type="radio" name="qde-correct" value="c" class="qk-radio"><span class="qk-correct-badge">C</span><span class="qk-correct-text" id="qde-ct-c">Choice C</span></label>
            <label class="qk-correct-opt" data-letter="d"><input type="radio" name="qde-correct" value="d" class="qk-radio"><span class="qk-correct-badge">D</span><span class="qk-correct-text" id="qde-ct-d">Choice D</span></label>
          </div>
        </div>

        <div class="bat-field bat-field--full" style="margin-bottom:.9rem">
          <label class="bat-field-lbl" for="qde-expl">Explanation <span class="bat-optional">(optional)</span></label>
          <textarea class="bat-input qk-textarea" id="qde-expl" rows="2"></textarea>
        </div>

        <div class="bat-form-grid qk-meta-grid">
          <div class="bat-field bat-field--full">
            <label class="bat-field-lbl">Domain tags <span class="qk-req">*</span></label>
            <div class="qk-domain-checks" id="qde-domains"></div>
          </div>
          <div class="bat-field">
            <label class="bat-field-lbl" for="qde-level">Exam level <span class="qk-req">*</span></label>
            <select class="bat-input bat-select" id="qde-level">
              <option value="both">Both</option>
              <option value="professional">Professional</option>
              <option value="subprofessional">Sub-professional</option>
            </select>
          </div>
          <div class="bat-field">
            <label class="bat-field-lbl" for="qde-diff">Difficulty <span class="qk-req">*</span></label>
            <select class="bat-input bat-select" id="qde-diff">
              <option value="medium">Medium</option>
              <option value="easy">Easy</option>
              <option value="hard">Hard</option>
            </select>
          </div>
          <div class="bat-field">
            <label class="bat-field-lbl" for="qde-status">Status <span class="qk-req">*</span></label>
            <select class="bat-input bat-select" id="qde-status">
              <option value="active">Active</option>
              <option value="draft">Draft</option>
              <option value="archived">Archived</option>
            </select>
          </div>
          <div class="bat-field">
            <label class="bat-field-lbl" for="qde-melo">M-Elo rating</label>
            <input class="bat-input" type="number" id="qde-melo" min="400" max="3000" step="1">
          </div>
        </div>

        <div id="qde-err" class="qk-form-err" hidden></div>

        <div class="bat-modal-actions">
          <button type="button" class="bat-btn-ghost" id="qd-em-cancel">Cancel</button>
          <button type="submit" class="bat-btn-save" id="qd-em-submit">Save changes</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Archive confirm -->
  <div class="bat-modal-overlay" id="qd-arch-modal" hidden>
    <div class="bat-modal bat-modal--sm" role="dialog" aria-modal="true">
      <div class="bat-modal-head">
        <h2 class="bat-modal-title">Archive question?</h2>
        <button type="button" class="bat-modal-x" id="qd-am-close" aria-label="Close"><span class="material-symbols-outlined">close</span></button>
      </div>
      <div style="padding:1.25rem">
        <p style="font-size:.88rem;color:var(--text-subdued);margin:0 0 1.25rem;line-height:1.55">
          This question will be excluded from all future sessions. You can restore it by editing the status.
        </p>
        <div class="bat-modal-actions" style="border-top:none;padding-top:0;margin-top:0">
          <button type="button" class="bat-btn-ghost" id="qd-am-cancel">Cancel</button>
          <button type="button" class="bat-btn-save" id="qd-am-confirm" style="background:#dc2626">Archive</button>
        </div>
      </div>
    </div>
  </div>

  <div class="rxv-toast" id="qd-toast" hidden>
    <span class="material-symbols-outlined" id="qd-toast-ic">check_circle</span>
    <span id="qd-toast-msg"></span>
  </div>

  <script src="/js/admin-shell.js"></script>
  <script>
  (async () => {
    const $ = id => document.getElementById(id);

    function toast(msg, err) {
      const t = $('qd-toast'), ic = $('qd-toast-ic'), m = $('qd-toast-msg');
      if (ic) { ic.textContent = err ? 'error' : 'check_circle'; ic.style.color = err ? '#f87171' : '#4ade80'; }
      if (m) m.textContent = msg;
      t.removeAttribute('hidden');
      t.classList.add('rxv-toast--show');
      setTimeout(() => { t.classList.remove('rxv-toast--show'); setTimeout(() => t.setAttribute('hidden',''), 280); }, 3200);
    }

    function escHtml(s) { const d = document.createElement('div'); d.textContent = String(s||''); return d.innerHTML; }
    function fmtDate(d) { if (!d) return '—'; return new Date(d).toLocaleDateString('en-PH',{year:'numeric',month:'short',day:'numeric'}); }

    /* ─── Load question ──────────────────────────────────────── */
    const qid = parseInt(window.location.pathname.split('/').pop(), 10);
    if (!qid) { $('qd-loading').querySelector('p').textContent = 'Invalid question ID.'; return; }

    let question, allDomains = [], usage = {};

    try {
      const [qRes, listRes] = await Promise.all([
        fetch('/admin/api/questions/' + qid),
        fetch('/admin/api/questions?status='),
      ]);
      if (!qRes.ok) throw new Error();
      const qData    = await qRes.json();
      const listData = listRes.ok ? await listRes.json() : {};
      question   = qData.question;
      usage      = qData.usage || {};
      allDomains = listData.domains || [];
    } catch {
      $('qd-loading').querySelector('p').textContent = 'Failed to load question.';
      return;
    }

    document.title = 'Question #' + question.id + ' | Hauers Admin';

    /* ─── Render page ────────────────────────────────────────── */
    function diffBadge(d) {
      const cls = d==='hard'?'qk-diff--hard':d==='easy'?'qk-diff--easy':'qk-diff--med';
      return `<span class="qk-diff-badge ${cls}">${d}</span>`;
    }
    function statusPill(s) {
      const cls = s==='active'?'bat-st--active':s==='archived'?'bat-st--closed':'bat-st--draft';
      return `<span class="bat-status-pill ${cls}">${s}</span>`;
    }
    function levelLabel(l) {
      return l==='professional'?'Professional':l==='subprofessional'?'Sub-professional':'Both';
    }

    function renderPage(q) {
      $('qd-heading').textContent = 'Question #' + q.id;
      $('qd-breadcrumb').innerHTML =
        `<span style="font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--text-subdued)">Question Bank / #${q.id}</span>`;

      $('qd-qtext').textContent = q.question_text;

      const letters = ['A','B','C','D'];
      const choices = [q.choice_a, q.choice_b, q.choice_c, q.choice_d];
      $('qd-choices').innerHTML = choices.map((c, i) => {
        const l = letters[i].toLowerCase();
        const correct = l === q.correct_choice;
        return `<div class="qd-choice${correct?' qd-choice--correct':''}">
          <span class="qd-choice-letter${correct?' qd-choice-letter--correct':''}">${letters[i]}</span>
          <span class="qd-choice-txt">${escHtml(c)}</span>
          ${correct ? '<span class="qd-correct-tick"><span class="material-symbols-outlined">check_circle</span>Correct</span>' : ''}
        </div>`;
      }).join('');

      if (q.explanation) {
        $('qd-expl').textContent = q.explanation;
        $('qd-expl-section').removeAttribute('hidden');
      } else {
        $('qd-expl-section').setAttribute('hidden','');
      }

      $('qd-status').innerHTML     = statusPill(q.status);
      $('qd-difficulty').innerHTML = diffBadge(q.difficulty);
      $('qd-level').textContent    = levelLabel(q.exam_level);
      $('qd-melo').textContent     = (q.melo_difficulty ?? 1200).toFixed(1);
      $('qd-created').textContent  = fmtDate(q.created_at);
      $('qd-updated').textContent  = fmtDate(q.updated_at);

      const domEl = $('qd-domains');
      domEl.innerHTML = (q.domains||[]).length
        ? q.domains.map(d=>`<span class="qk-domain-chip">${escHtml(d.name)}</span>`).join('')
        : '<span style="font-size:.8rem;color:var(--text-subdued)">None assigned</span>';

      const seen    = Number(usage.times_seen)    || 0;
      const correct = Number(usage.times_correct) || 0;
      $('qd-seen').textContent    = seen;
      $('qd-correct').textContent = correct;
      $('qd-acc').textContent     = seen ? Math.round(correct / seen * 100) + '%' : '—';

      // Arch button visibility
      if (q.status === 'archived') $('qd-arch-btn').setAttribute('hidden','');
    }

    $('qd-loading').setAttribute('hidden','');
    $('qd-content').removeAttribute('hidden');
    renderPage(question);

    /* ─── Edit modal ─────────────────────────────────────────── */
    function renderDomainChecks(containerId, selectedIds) {
      const container = $(containerId);
      if (!allDomains.length) { container.innerHTML = '<span style="font-size:.8rem;color:var(--text-subdued)">No domains available.</span>'; return; }
      container.innerHTML = allDomains.map(d =>
        `<label class="qk-dom-check-lbl">
          <input type="checkbox" class="qk-dom-check" value="${d.id}" ${(selectedIds||[]).includes(d.id)?'checked':''}>
          <span>${escHtml(d.name)}</span>
        </label>`
      ).join('');
    }

    const choiceMap = { a:'qde-ca', b:'qde-cb', c:'qde-cc', d:'qde-cd' };
    ['a','b','c','d'].forEach(l => {
      $(choiceMap[l]).addEventListener('input', () => {
        const txt = $(choiceMap[l]).value.trim();
        $('qde-ct-' + l).textContent = txt || 'Choice ' + l.toUpperCase();
      });
    });

    function openEditModal() {
      const q = question;
      $('qde-text').value   = q.question_text;
      $('qde-ca').value     = q.choice_a;
      $('qde-cb').value     = q.choice_b;
      $('qde-cc').value     = q.choice_c;
      $('qde-cd').value     = q.choice_d;
      $('qde-expl').value   = q.explanation || '';
      $('qde-level').value  = q.exam_level;
      $('qde-diff').value   = q.difficulty;
      $('qde-status').value = q.status;
      $('qde-melo').value   = q.melo_difficulty ?? 1200;
      ['a','b','c','d'].forEach(l => { $('qde-ct-'+l).textContent = $(choiceMap[l]).value.trim() || 'Choice '+l.toUpperCase(); });
      const radio = document.querySelector(`input[name="qde-correct"][value="${q.correct_choice}"]`);
      if (radio) radio.checked = true;
      renderDomainChecks('qde-domains', (q.domains||[]).map(d=>d.id));
      hideEditErr();
      $('qd-edit-modal').removeAttribute('hidden');
      $('qde-text').focus();
    }
    function closeEditModal() { $('qd-edit-modal').setAttribute('hidden',''); }

    $('qd-edit-btn').addEventListener('click', openEditModal);
    $('qd-em-close').addEventListener('click', closeEditModal);
    $('qd-em-cancel').addEventListener('click', closeEditModal);
    $('qd-edit-modal').addEventListener('click', e => { if (e.target.id==='qd-edit-modal') closeEditModal(); });

    function hideEditErr() { $('qde-err').setAttribute('hidden',''); $('qde-err').textContent=''; }
    function showEditErr(msg) { $('qde-err').textContent=msg; $('qde-err').removeAttribute('hidden'); }

    $('qd-edit-form').addEventListener('submit', async e => {
      e.preventDefault();
      hideEditErr();
      const correctRadio = document.querySelector('input[name="qde-correct"]:checked');
      if (!correctRadio) return showEditErr('Select the correct answer.');
      const domChecked = Array.from(document.querySelectorAll('#qde-domains .qk-dom-check:checked')).map(c=>Number(c.value));
      if (!domChecked.length) return showEditErr('Select at least one domain tag.');
      const btn = $('qd-em-submit'); btn.disabled = true;
      try {
        const r = await fetch('/admin/api/questions/'+question.id, {
          method:'PUT', headers:{'Content-Type':'application/json'},
          body: JSON.stringify({
            question_text: $('qde-text').value.trim(),
            choice_a: $('qde-ca').value.trim(), choice_b: $('qde-cb').value.trim(),
            choice_c: $('qde-cc').value.trim(), choice_d: $('qde-cd').value.trim(),
            correct_choice: correctRadio.value,
            explanation: $('qde-expl').value.trim() || null,
            exam_level: $('qde-level').value, difficulty: $('qde-diff').value,
            status: $('qde-status').value,
            melo_difficulty: Number($('qde-melo').value)||1200,
            domain_ids: domChecked,
          }),
        });
        const d = await r.json();
        if (!r.ok) { showEditErr(d.error||'Save failed.'); return; }
        question = d.question;
        usage = usage; // preserve
        renderPage(question);
        closeEditModal();
        toast('Question updated.');
      } catch { showEditErr('Network error.'); }
      finally  { btn.disabled = false; }
    });

    /* ─── Archive ────────────────────────────────────────────── */
    function openArchModal()  { $('qd-arch-modal').removeAttribute('hidden'); }
    function closeArchModal() { $('qd-arch-modal').setAttribute('hidden',''); }
    $('qd-arch-btn').addEventListener('click', openArchModal);
    $('qd-am-close').addEventListener('click', closeArchModal);
    $('qd-am-cancel').addEventListener('click', closeArchModal);
    $('qd-arch-modal').addEventListener('click', e => { if (e.target.id==='qd-arch-modal') closeArchModal(); });
    $('qd-am-confirm').addEventListener('click', async () => {
      const btn = $('qd-am-confirm'); btn.disabled = true;
      try {
        const r = await fetch('/admin/api/questions/'+question.id+'/archive', { method:'POST' });
        if (!r.ok) throw new Error();
        question.status = 'archived';
        renderPage(question);
        closeArchModal();
        toast('Question archived.');
      } catch { toast('Could not archive.', true); }
      finally  { btn.disabled = false; }
    });

    document.addEventListener('keydown', e => {
      if (e.key==='Escape') { closeEditModal(); closeArchModal(); }
    });
  })();
  </script>

</body>
</html>
