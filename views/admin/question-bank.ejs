<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Question Bank | Hauers Admin</title>
  <link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <script src="/js/theme-toggle.js"></script>
</head>
<body data-role="admin">

  <div id="navbar-placeholder"><%- include('../partials/navbar') %></div>

  <div class="app-shell sidebar-collapsed">
    <div class="sidebar-overlay" id="sidebar-overlay"></div>
    <div id="sidebar-placeholder"><%- include('../partials/admin-sidebar') %></div>

    <main class="page-content">

      <header class="page-header qk-page-header">
        <h1 class="page-title">Question Bank</h1>
        <button type="button" class="bat-btn-create" id="qk-add-btn">
          <span class="material-symbols-outlined">add</span>
          Add question
        </button>
      </header>

      <!-- KPI row -->
      <div class="home-stats-row bat-kpi">
        <div class="dash-card home-stat-card">
          <div class="home-stat-ico-wrap home-stat-ico-wrap--blue"><span class="material-symbols-outlined">library_books</span></div>
          <div class="home-stat-copy">
            <span class="home-stat-value" id="qk-kpi-total">—</span>
            <span class="home-stat-label">Total questions</span>
          </div>
        </div>
        <div class="dash-card home-stat-card">
          <div class="home-stat-ico-wrap home-stat-ico-wrap--green"><span class="material-symbols-outlined">check_circle</span></div>
          <div class="home-stat-copy">
            <span class="home-stat-value" id="qk-kpi-active">—</span>
            <span class="home-stat-label">Active</span>
          </div>
        </div>
        <div class="dash-card home-stat-card">
          <div class="home-stat-ico-wrap home-stat-ico-wrap--amber"><span class="material-symbols-outlined">edit_note</span></div>
          <div class="home-stat-copy">
            <span class="home-stat-value" id="qk-kpi-draft">—</span>
            <span class="home-stat-label">Draft</span>
          </div>
        </div>
        <div class="dash-card home-stat-card">
          <div class="home-stat-ico-wrap qk-kpi-ico--archived"><span class="material-symbols-outlined">archive</span></div>
          <div class="home-stat-copy">
            <span class="home-stat-value" id="qk-kpi-archived">—</span>
            <span class="home-stat-label">Archived</span>
          </div>
        </div>
      </div>

      <!-- Toolbar (inner row avoids dash-card column flex breaking layout) -->
      <div class="dash-card qk-toolbar">
        <p class="qk-toolbar-label">Search and filters</p>
        <div class="qk-toolbar-inner">
          <div class="qk-search-wrap">
            <label class="qk-sr-only" for="qk-search">Search question text</label>
            <span class="material-symbols-outlined qk-search-ic" aria-hidden="true">search</span>
            <input type="search" class="qk-search-input" id="qk-search" placeholder="Search by question or choice text…" autocomplete="off">
          </div>
          <div class="qk-filters" role="group" aria-label="Filter questions">
            <div class="qk-filter-group">
              <label class="qk-filter-lbl" for="qk-f-domain">Domain</label>
              <select class="qk-filter-select" id="qk-f-domain">
                <option value="">All domains</option>
              </select>
            </div>
            <div class="qk-filter-group">
              <label class="qk-filter-lbl" for="qk-f-level">Exam level</label>
              <select class="qk-filter-select" id="qk-f-level">
                <option value="">All levels</option>
                <option value="professional">Professional</option>
                <option value="subprofessional">Sub-professional</option>
                <option value="both">Both</option>
              </select>
            </div>
            <div class="qk-filter-group">
              <label class="qk-filter-lbl" for="qk-f-diff">Difficulty</label>
              <select class="qk-filter-select" id="qk-f-diff">
                <option value="">All</option>
                <option value="easy">Easy</option>
                <option value="medium">Medium</option>
                <option value="hard">Hard</option>
              </select>
            </div>
            <div class="qk-filter-group">
              <label class="qk-filter-lbl" for="qk-f-status">Status</label>
              <select class="qk-filter-select" id="qk-f-status">
                <option value="">All statuses</option>
                <option value="active">Active</option>
                <option value="draft">Draft</option>
                <option value="archived">Archived</option>
              </select>
            </div>
          </div>
        </div>
      </div>

      <!-- Table -->
      <div class="dash-card qk-table-card">
          <p class="pgx-section-label pgx-section-label--flush qk-result-msg" id="qk-result-msg">Loading…</p>
        <div class="qk-table-scroll">
          <table class="admin-table qk-table">
            <thead>
              <tr>
                <th class="qk-col-id">#</th>
                <th>Question</th>
                <th class="qk-col-difficulty">Difficulty</th>
                <th class="qk-col-level">Exam level</th>
                <th class="qk-col-status">Status</th>
                <th class="qk-col-actions" aria-label="Actions"></th>
              </tr>
            </thead>
            <tbody id="qk-tbody">
              <tr><td colspan="6" class="bat-empty-cell">Loading...</td></tr>
            </tbody>
          </table>
        </div>
      </div>

    </main>
  </div>

  <!-- Add / Edit modal -->
  <div class="bat-modal-overlay" id="qk-modal" hidden>
    <div class="bat-modal qk-modal-wide" role="dialog" aria-modal="true" aria-labelledby="qk-modal-title">
      <div class="bat-modal-head">
        <h2 class="bat-modal-title" id="qk-modal-title">Add question</h2>
        <button type="button" class="bat-modal-x" id="qk-modal-close" aria-label="Close"><span class="material-symbols-outlined">close</span></button>
      </div>
      <form id="qk-form" class="bat-modal-form" autocomplete="off" novalidate>
        <input type="hidden" id="qf-id">

        <!-- Question text -->
        <div class="bat-field bat-field--full qk-field-spaced">
          <label class="bat-field-lbl" for="qf-text">Question text <span class="qk-req">*</span></label>
          <textarea class="bat-input qk-textarea" id="qf-text" rows="3" placeholder="Type the full question here…" required></textarea>
        </div>

        <!-- Choices A–D -->
        <div class="bat-field bat-field--full qk-field-spaced">
          <label class="bat-field-lbl">Choices <span class="qk-req">*</span></label>
          <div class="qk-choices-grid">
            <div class="qk-choice-row">
              <span class="qk-choice-lbl">A</span>
              <input class="bat-input qk-choice-input" id="qf-ca" type="text" placeholder="Choice A" required data-letter="a">
            </div>
            <div class="qk-choice-row">
              <span class="qk-choice-lbl">B</span>
              <input class="bat-input qk-choice-input" id="qf-cb" type="text" placeholder="Choice B" required data-letter="b">
            </div>
            <div class="qk-choice-row">
              <span class="qk-choice-lbl">C</span>
              <input class="bat-input qk-choice-input" id="qf-cc" type="text" placeholder="Choice C" required data-letter="c">
            </div>
            <div class="qk-choice-row">
              <span class="qk-choice-lbl">D</span>
              <input class="bat-input qk-choice-input" id="qf-cd" type="text" placeholder="Choice D" required data-letter="d">
            </div>
          </div>
        </div>

        <!-- Correct answer radios (updated live as choices fill in) -->
        <div class="bat-field bat-field--full qk-field-spaced">
          <label class="bat-field-lbl">Correct answer <span class="qk-req">*</span></label>
          <div class="qk-correct-row" id="qf-correct-row">
            <label class="qk-correct-opt" data-letter="a">
              <input type="radio" name="qf-correct" value="a" class="qk-radio">
              <span class="qk-correct-badge">A</span>
              <span class="qk-correct-text" id="qf-ct-a">Choice A</span>
            </label>
            <label class="qk-correct-opt" data-letter="b">
              <input type="radio" name="qf-correct" value="b" class="qk-radio">
              <span class="qk-correct-badge">B</span>
              <span class="qk-correct-text" id="qf-ct-b">Choice B</span>
            </label>
            <label class="qk-correct-opt" data-letter="c">
              <input type="radio" name="qf-correct" value="c" class="qk-radio">
              <span class="qk-correct-badge">C</span>
              <span class="qk-correct-text" id="qf-ct-c">Choice C</span>
            </label>
            <label class="qk-correct-opt" data-letter="d">
              <input type="radio" name="qf-correct" value="d" class="qk-radio">
              <span class="qk-correct-badge">D</span>
              <span class="qk-correct-text" id="qf-ct-d">Choice D</span>
            </label>
          </div>
        </div>

        <!-- Explanation -->
        <div class="bat-field bat-field--full qk-field-spaced">
          <label class="bat-field-lbl" for="qf-expl">Explanation <span class="bat-optional">(optional, shown after answering)</span></label>
          <textarea class="bat-input qk-textarea" id="qf-expl" rows="2" placeholder="Explain why the correct answer is right…"></textarea>
        </div>

        <!-- Domain, Exam level, Difficulty, Status, M-Elo -->
        <div class="bat-form-grid qk-meta-grid">
          <div class="bat-field bat-field--full">
            <label class="bat-field-lbl">Domain tags <span class="qk-req">*</span></label>
            <div class="qk-domain-checks" id="qf-domains">
              <span class="qk-muted-inline">Loading domains…</span>
            </div>
          </div>
          <div class="bat-field">
            <label class="bat-field-lbl" for="qf-level">Exam level <span class="qk-req">*</span></label>
            <select class="bat-input bat-select" id="qf-level" required>
              <option value="both">Both</option>
              <option value="professional">Professional</option>
              <option value="subprofessional">Sub-professional</option>
            </select>
          </div>
          <div class="bat-field">
            <label class="bat-field-lbl" for="qf-diff">Difficulty <span class="qk-req">*</span></label>
            <select class="bat-input bat-select" id="qf-diff" required>
              <option value="medium">Medium</option>
              <option value="easy">Easy</option>
              <option value="hard">Hard</option>
            </select>
          </div>
          <div class="bat-field">
            <label class="bat-field-lbl" for="qf-status">Status <span class="qk-req">*</span></label>
            <select class="bat-input bat-select" id="qf-status" required>
              <option value="active">Active</option>
              <option value="draft">Draft</option>
            </select>
          </div>
          <div class="bat-field">
            <label class="bat-field-lbl" for="qf-melo">Initial M-Elo rating</label>
            <input class="bat-input" type="number" id="qf-melo" value="1200" min="400" max="3000" step="1">
            <p class="bat-field-hint">Default 1200. Adjust for known difficulty calibration.</p>
          </div>
        </div>

        <div id="qf-err" class="qk-form-err" hidden></div>

        <div class="bat-modal-actions">
          <button type="button" class="bat-btn-ghost" id="qk-modal-cancel">Cancel</button>
          <button type="submit" class="bat-btn-save" id="qk-modal-submit">Add question</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Archive confirm -->
  <div class="bat-modal-overlay" id="qk-arch-modal" hidden>
    <div class="bat-modal bat-modal--sm" role="dialog" aria-modal="true">
      <div class="bat-modal-head">
        <h2 class="bat-modal-title">Archive question?</h2>
        <button type="button" class="bat-modal-x" id="qk-arch-close" aria-label="Close"><span class="material-symbols-outlined">close</span></button>
      </div>
      <div class="qk-confirm-body">
        <p class="qk-confirm-text">
          Question <strong id="qk-arch-label" class="qk-confirm-id"></strong> will be hidden from reviewees and excluded from new sessions. You can restore it by editing status back to Active.
        </p>
        <div class="bat-modal-actions qk-confirm-actions">
          <button type="button" class="bat-btn-ghost" id="qk-arch-cancel">Cancel</button>
          <button type="button" class="bat-btn-save qk-confirm-archive-btn" id="qk-arch-confirm">Archive</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Delete confirm -->
  <div class="bat-modal-overlay" id="qk-del-modal" hidden>
    <div class="bat-modal bat-modal--sm" role="dialog" aria-modal="true">
      <div class="bat-modal-head">
        <h2 class="bat-modal-title">Delete question?</h2>
        <button type="button" class="bat-modal-x" id="qk-del-close" aria-label="Close"><span class="material-symbols-outlined">close</span></button>
      </div>
      <div class="qk-confirm-body">
        <p class="qk-confirm-text">
          Question <strong id="qk-del-label" class="qk-confirm-id"></strong> will be permanently removed from the question bank. This action cannot be undone.
        </p>
        <div class="bat-modal-actions qk-confirm-actions">
          <button type="button" class="bat-btn-ghost" id="qk-del-cancel">Cancel</button>
          <button type="button" class="bat-btn-save qk-btn-danger" id="qk-del-confirm">Delete permanently</button>
        </div>
      </div>
    </div>
  </div>

  <div class="rxv-toast" id="qk-toast" hidden>
    <span class="material-symbols-outlined" id="qk-toast-ic">check_circle</span>
    <span id="qk-toast-msg"></span>
  </div>

  <script src="/js/admin-shell.js"></script>
  <script>
  (function () {
    const $ = id => document.getElementById(id);

    /* ─── Toast ─────────────────────────────────────────────── */
    function toast(msg, err) {
      const t = $('qk-toast'), ic = $('qk-toast-ic'), m = $('qk-toast-msg');
      if (ic) { ic.textContent = err ? 'error' : 'check_circle'; ic.style.color = err ? '#f87171' : '#4ade80'; }
      if (m) m.textContent = msg;
      t.removeAttribute('hidden');
      t.classList.add('rxv-toast--show');
      setTimeout(() => { t.classList.remove('rxv-toast--show'); setTimeout(() => t.setAttribute('hidden',''), 280); }, 3200);
    }

    /* ─── Helpers ────────────────────────────────────────────── */
    function escHtml(s) { const d = document.createElement('div'); d.textContent = String(s||''); return d.innerHTML; }

    function diffBadge(d) {
      const cls = d === 'hard' ? 'qk-diff--hard' : d === 'easy' ? 'qk-diff--easy' : 'qk-diff--med';
      return `<span class="qk-diff-badge ${cls}">${d}</span>`;
    }
    function statusPill(s) {
      const cls = s === 'active' ? 'bat-st--active' : s === 'archived' ? 'bat-st--closed' : 'bat-st--draft';
      return `<span class="bat-status-pill ${cls}">${s}</span>`;
    }
    function levelLabel(l) {
      return l === 'professional' ? 'Prof.' : l === 'subprofessional' ? 'Sub-prof.' : 'Both';
    }
    function domainChips(names) {
      if (!names || !names.length) return '<span class="qk-muted-inline">None</span>';
      return names.map(n => `<span class="qk-domain-chip">${escHtml(n.replace(' Ability',''))}</span>`).join('');
    }

    /* ─── State ──────────────────────────────────────────────── */
    let allQuestions = [], allDomains = [];
    let searchTimer = null;

    /* ─── Fetch & render ─────────────────────────────────────── */
    async function fetchQuestions() {
      const params = new URLSearchParams();
      const q = $('qk-search').value.trim();
      const domain = $('qk-f-domain').value;
      const level  = $('qk-f-level').value;
      const diff   = $('qk-f-diff').value;
      const status = $('qk-f-status').value;
      if (q)      params.set('q', q);
      if (domain) params.set('domain_id', domain);
      if (level)  params.set('exam_level', level);
      if (diff)   params.set('difficulty', diff);
      if (status) params.set('status', status);

      const isFiltered = q || domain || level || diff || status;

      $('qk-tbody').innerHTML = '<tr><td colspan="6" class="bat-empty-cell">Loading...</td></tr>';

      try {
        const r = await fetch('/admin/api/questions?' + params.toString());
        if (!r.ok) throw new Error();
        const data = await r.json();

        allQuestions = data.questions || [];
        allDomains   = data.domains   || [];

        // KPIs always reflect total set
        $('qk-kpi-total').textContent    = data.total    ?? '—';
        $('qk-kpi-active').textContent   = data.active   ?? '—';
        $('qk-kpi-draft').textContent    = data.draft    ?? '—';
        $('qk-kpi-archived').textContent = data.archived ?? '—';

        // Populate domain filter (idempotent — only on first load)
        const domSel = $('qk-f-domain');
        if (domSel.options.length <= 1 && allDomains.length) {
          allDomains.forEach(d => {
            const o = document.createElement('option');
            o.value = d.id; o.textContent = d.name;
            domSel.appendChild(o);
          });
        }

        renderTable(allQuestions, isFiltered);
      } catch {
        $('qk-tbody').innerHTML = '<tr><td colspan="6" class="bat-empty-cell">Could not load questions.</td></tr>';
      }
    }

    function renderTable(qs, isFiltered) {
      const msg = $('qk-result-msg');
      if (!qs.length) {
        $('qk-tbody').innerHTML = '<tr><td colspan="6" class="bat-empty-cell">' +
          (isFiltered ? 'No questions match the current filters.' : 'No questions yet. Add one to get started.') +
          '</td></tr>';
        if (msg) msg.textContent = '0 questions';
        return;
      }
      if (msg) msg.textContent = qs.length + ' question' + (qs.length !== 1 ? 's' : '');

      $('qk-tbody').innerHTML = qs.map((q, idx) => {
        const preview = q.question_text.length > 90 ? q.question_text.slice(0, 90) + '…' : q.question_text;
        const href = `/admin/question-bank/${q.id}`;
        return `<tr class="qk-row" data-href="${href}">
          <td class="qk-id-cell">${idx + 1}</td>
          <td class="qk-preview-cell">
            <a class="qk-question-link" href="${href}"><span class="qk-question-preview">${escHtml(preview)}</span></a>
          </td>
          <td>${diffBadge(q.difficulty)}</td>
          <td class="qk-level-cell">${levelLabel(q.exam_level)}</td>
          <td>${statusPill(q.status)}</td>
          <td class="qk-actions-cell">
            <a class="qk-btn-view" href="/admin/question-bank/${q.id}" title="View / details">
              <span class="material-symbols-outlined">open_in_new</span>
            </a>
            <button type="button" class="qk-btn-edit" title="Edit" data-id="${q.id}">
              <span class="material-symbols-outlined">edit</span>
            </button>
            ${q.status !== 'archived' ? `<button type="button" class="qk-btn-arch" title="Archive" data-id="${q.id}" data-num="#${q.id}">
              <span class="material-symbols-outlined">archive</span>
            </button>` : ''}
            <button type="button" class="qk-btn-delete" title="Delete permanently" data-id="${q.id}" data-num="#${q.id}">
              <span class="material-symbols-outlined">delete</span>
            </button>
          </td>
        </tr>
        <tr class="qk-domain-row" data-href="${href}">
          <td></td>
          <td colspan="5" class="qk-domain-band"><span class="qk-domain-band-label">Domains</span>${domainChips(q.domain_names)}</td>
        </tr>`;
      }).join('');

      $('qk-tbody').querySelectorAll('.qk-row, .qk-domain-row').forEach(row => {
        row.addEventListener('click', e => {
          if (e.target.closest('a, button, input, select, textarea')) return;
          const href = row.dataset.href;
          if (href) window.location.href = href;
        });
      });
      $('qk-tbody').querySelectorAll('.qk-btn-edit').forEach(btn => {
        btn.addEventListener('click', () => openEdit(Number(btn.dataset.id)));
      });
      $('qk-tbody').querySelectorAll('.qk-btn-arch').forEach(btn => {
        btn.addEventListener('click', () => openArchive(Number(btn.dataset.id), btn.dataset.num));
      });
      $('qk-tbody').querySelectorAll('.qk-btn-delete').forEach(btn => {
        btn.addEventListener('click', () => openDelete(Number(btn.dataset.id), btn.dataset.num));
      });
    }

    /* ─── Filter / search events ─────────────────────────────── */
    $('qk-search').addEventListener('input', () => {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(fetchQuestions, 320);
    });
    ['qk-f-domain','qk-f-level','qk-f-diff','qk-f-status'].forEach(id => {
      $(id).addEventListener('change', fetchQuestions);
    });
    /* ─── Modal helpers ──────────────────────────────────────── */
    function openModal() { $('qk-modal').removeAttribute('hidden'); }
    function closeModal() { $('qk-modal').setAttribute('hidden',''); }

    $('qk-modal-close').addEventListener('click', closeModal);
    $('qk-modal-cancel').addEventListener('click', closeModal);
    $('qk-modal').addEventListener('click', e => { if (e.target.id === 'qk-modal') closeModal(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeModal(); closeArchModal(); closeDelModal(); } });

    /* ─── Choice inputs → live-update correct-answer labels ─── */
    const choiceMap = { a: 'qf-ca', b: 'qf-cb', c: 'qf-cc', d: 'qf-cd' };
    ['a','b','c','d'].forEach(l => {
      $(choiceMap[l]).addEventListener('input', () => {
        const txt = $(choiceMap[l]).value.trim();
        $('qf-ct-' + l).textContent = txt || 'Choice ' + l.toUpperCase();
      });
    });

    /* ─── Populate domain checkboxes in modal ─────────────────── */
    function renderDomainChecks(selectedIds) {
      const container = $('qf-domains');
      if (!allDomains.length) { container.innerHTML = '<span class="qk-muted-inline">No domains available.</span>'; return; }
      container.innerHTML = allDomains.map(d =>
        `<label class="qk-dom-check-lbl">
          <input type="checkbox" class="qk-dom-check" value="${d.id}"
            ${(selectedIds||[]).includes(d.id) ? 'checked' : ''}>
          <span>${escHtml(d.name)}</span>
        </label>`
      ).join('');
    }

    /* ─── Open Add modal ─────────────────────────────────────── */
    function openAdd() {
      $('qk-modal-title').textContent  = 'Add question';
      $('qk-modal-submit').textContent = 'Add question';
      $('qf-id').value = '';
      $('qk-form').reset();
      ['a','b','c','d'].forEach(l => { $('qf-ct-' + l).textContent = 'Choice ' + l.toUpperCase(); });
      $('qf-melo').value = '1200';
      $('qf-diff').value = 'medium';
      $('qf-status').value = 'active';
      $('qf-level').value = 'both';
      renderDomainChecks([]);
      hideFormErr();
      openModal();
      $('qf-text').focus();
    }

    /* ─── Open Edit modal ────────────────────────────────────── */
    async function openEdit(id) {
      $('qk-modal-title').textContent  = 'Edit question';
      $('qk-modal-submit').textContent = 'Save changes';
      hideFormErr();
      renderDomainChecks([]);
      openModal();

      try {
        const r = await fetch('/admin/api/questions/' + id);
        if (!r.ok) throw new Error();
        const { question: q } = await r.json();

        $('qf-id').value          = q.id;
        $('qf-text').value        = q.question_text;
        $('qf-ca').value          = q.choice_a;
        $('qf-cb').value          = q.choice_b;
        $('qf-cc').value          = q.choice_c;
        $('qf-cd').value          = q.choice_d;
        $('qf-expl').value        = q.explanation || '';
        $('qf-level').value       = q.exam_level;
        $('qf-diff').value        = q.difficulty;
        $('qf-status').value      = q.status;
        $('qf-melo').value        = q.melo_difficulty ?? 1200;

        ['a','b','c','d'].forEach(l => {
          $('qf-ct-' + l).textContent = $(choiceMap[l]).value.trim() || 'Choice ' + l.toUpperCase();
        });

        const radio = document.querySelector(`input[name="qf-correct"][value="${q.correct_choice}"]`);
        if (radio) radio.checked = true;

        renderDomainChecks((q.domains || []).map(d => d.id));
      } catch {
        toast('Could not load question.', true);
        closeModal();
      }
    }

    $('qk-add-btn').addEventListener('click', openAdd);

    function hideFormErr() { $('qf-err').setAttribute('hidden',''); $('qf-err').textContent = ''; }
    function showFormErr(msg) { $('qf-err').textContent = msg; $('qf-err').removeAttribute('hidden'); }

    /* ─── Form submit ────────────────────────────────────────── */
    $('qk-form').addEventListener('submit', async e => {
      e.preventDefault();
      hideFormErr();

      const correctRadio = document.querySelector('input[name="qf-correct"]:checked');
      if (!correctRadio) return showFormErr('Select the correct answer.');

      const domChecked = Array.from(document.querySelectorAll('.qk-dom-check:checked')).map(c => Number(c.value));
      if (!domChecked.length) return showFormErr('Select at least one domain tag.');

      const btn = $('qk-modal-submit');
      btn.disabled = true;
      const editId = $('qf-id').value;

      const payload = {
        question_text: $('qf-text').value.trim(),
        choice_a: $('qf-ca').value.trim(),
        choice_b: $('qf-cb').value.trim(),
        choice_c: $('qf-cc').value.trim(),
        choice_d: $('qf-cd').value.trim(),
        correct_choice: correctRadio.value,
        explanation: $('qf-expl').value.trim() || null,
        exam_level: $('qf-level').value,
        difficulty: $('qf-diff').value,
        status: $('qf-status').value,
        melo_difficulty: Number($('qf-melo').value) || 1200,
        domain_ids: domChecked,
      };

      try {
        const url    = editId ? '/admin/api/questions/' + editId : '/admin/api/questions';
        const method = editId ? 'PUT' : 'POST';
        const r = await fetch(url, { method, headers: { 'Content-Type':'application/json' }, body: JSON.stringify(payload) });
        const d = await r.json();
        if (!r.ok) { showFormErr(d.error || 'Save failed.'); return; }
        closeModal();
        toast(editId ? 'Question updated.' : 'Question #' + d.question.id + ' added.');
        fetchQuestions();
      } catch { showFormErr('Network error. Please try again.'); }
      finally  { btn.disabled = false; }
    });

    /* ─── Archive ────────────────────────────────────────────── */
    let archiveTarget = null;
    function openArchive(id, label) {
      archiveTarget = id;
      $('qk-arch-label').textContent = label;
      $('qk-arch-modal').removeAttribute('hidden');
    }
    function closeArchModal() { $('qk-arch-modal').setAttribute('hidden',''); archiveTarget = null; }
    $('qk-arch-close').addEventListener('click',  closeArchModal);
    $('qk-arch-cancel').addEventListener('click', closeArchModal);
    $('qk-arch-modal').addEventListener('click', e => { if (e.target.id === 'qk-arch-modal') closeArchModal(); });
    $('qk-arch-confirm').addEventListener('click', async () => {
      if (!archiveTarget) return;
      const btn = $('qk-arch-confirm');
      btn.disabled = true;
      try {
        const r = await fetch('/admin/api/questions/' + archiveTarget + '/archive', { method: 'POST' });
        if (!r.ok) throw new Error();
        closeArchModal();
        toast('Question archived.');
        fetchQuestions();
      } catch { toast('Could not archive.', true); }
      finally  { btn.disabled = false; }
    });

    let deleteTarget = null;
    function openDelete(id, label) {
      deleteTarget = id;
      $('qk-del-label').textContent = label;
      $('qk-del-modal').removeAttribute('hidden');
    }
    function closeDelModal() { $('qk-del-modal').setAttribute('hidden',''); deleteTarget = null; }
    $('qk-del-close').addEventListener('click',  closeDelModal);
    $('qk-del-cancel').addEventListener('click', closeDelModal);
    $('qk-del-modal').addEventListener('click', e => { if (e.target.id === 'qk-del-modal') closeDelModal(); });
    $('qk-del-confirm').addEventListener('click', async () => {
      if (!deleteTarget) return;
      const btn = $('qk-del-confirm');
      btn.disabled = true;
      try {
        const r = await fetch('/admin/api/questions/' + deleteTarget, { method: 'DELETE' });
        if (!r.ok) throw new Error();
        closeDelModal();
        toast('Question deleted.');
        fetchQuestions();
      } catch { toast('Could not delete question.', true); }
      finally  { btn.disabled = false; }
    });

    /* ─── Initial load ───────────────────────────────────────── */
    fetchQuestions();
  })();
  </script>

</body>
</html>
