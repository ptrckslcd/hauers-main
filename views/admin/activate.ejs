<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Activate Admin Account | Hauers</title>
  <link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/auth.css">
  <script src="/js/theme-toggle.js"></script>
</head>
<body>
  <main class="auth-main">
    <div class="auth-column">
      <div class="greeting-area">
        <div class="greeting">Activate your admin account</div>
        <div class="greeting-sub">Invitation for <strong><%= invite.email %></strong></div>
      </div>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="auth-error-banner" style="margin-bottom:1rem;">
          <span class="auth-error-text"><%= error %></span>
        </div>
      <% } %>

      <form method="POST" action="/admin/activate" class="auth-form">
        <input type="hidden" name="token" value="<%= token %>">
        <div class="input-field"><div class="input-inner"><div class="input-stack"><input type="text" name="firstName" placeholder="First name" required></div></div></div>
        <div class="input-field"><div class="input-inner"><div class="input-stack"><input type="text" name="lastName" placeholder="Last name" required></div></div></div>
        <p style="font-size: 0.8rem; color: var(--text-muted); margin: -0.25rem 0 0.5rem 0.25rem;">(Note: Only @my.cspc.edu.ph emails are permitted)</p>
        <div class="input-field"><div class="input-inner"><div class="input-stack">
          <input type="password" id="activate-password" name="password" placeholder="Create password" required>
          <button type="button" id="toggle-activate-password" class="eye-toggle" tabindex="-1" aria-label="Toggle password visibility">
            <svg viewBox="0 0 24 24"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg>
          </button>
        </div></div></div>
        <div class="input-field"><div class="input-inner"><div class="input-stack">
          <input type="password" id="activate-confirm-password" name="confirmPassword" placeholder="Confirm password" required>
          <button type="button" id="toggle-activate-confirm-password" class="eye-toggle" tabindex="-1" aria-label="Toggle confirm password visibility">
            <svg viewBox="0 0 24 24"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg>
          </button>
        </div></div></div>
        <button type="submit" class="submit-btn" style="display: flex; align-items: center; justify-content: center; gap: 8px;">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" width="18px" height="18px">
            <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
            <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
            <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
            <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
          </svg>
          Bind & Activate with Google Account
        </button>
      </form>
    </div>
  </main>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      var eyeOpen = '<svg viewBox="0 0 24 24"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg>';
      var eyeClosed = '<svg viewBox="0 0 24 24"><path d="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z"/></svg>';
      
      function setupEyeToggle(btnId, inputId) {
        var btn = document.getElementById(btnId);
        var input = document.getElementById(inputId);
        if (btn && input) {
          btn.addEventListener('click', function() {
            var show = input.getAttribute('type') === 'password';
            input.setAttribute('type', show ? 'text' : 'password');
            btn.innerHTML = show ? eyeClosed : eyeOpen;
          });
        }
      }
      
      setupEyeToggle('toggle-activate-password', 'activate-password');
      setupEyeToggle('toggle-activate-confirm-password', 'activate-confirm-password');
    });
  </script>
</body>
</html>