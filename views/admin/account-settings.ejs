<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Settings | Hauers</title>
  <link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <script src="/js/theme-toggle.js"></script>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=block">
</head>
<body data-role="admin">

  <div id="navbar-placeholder"><%- include('../partials/navbar') %></div>

  <div class="app-shell sidebar-collapsed">
    <div class="sidebar-overlay" id="sidebar-overlay"></div>
    <div id="sidebar-placeholder"><%- include('../partials/admin-sidebar') %></div>

    <main class="page-content">

      <header class="page-header">
        <h1 class="page-title">Settings</h1>
      </header>

      <!-- Profile -->
      <div class="dash-card st-card">
        <p class="pgx-section-label">Profile</p>
        <div class="st-alert" id="st-profile-alert"></div>
        <form id="st-profile-form" class="st-form" novalidate>
          <div class="st-form-row">
            <div class="st-form-group">
              <label for="st-first-name">First Name</label>
              <input type="text" id="st-first-name" name="firstName" placeholder="First name" autocomplete="given-name">
            </div>
            <div class="st-form-group">
              <label for="st-last-name">Last Name</label>
              <input type="text" id="st-last-name" name="lastName" placeholder="Last name" autocomplete="family-name">
            </div>
          </div>
          <div class="st-form-group">
            <label for="st-email-input">Email Address</label>
            <input type="email" id="st-email-input" name="email" placeholder="admin@example.com" autocomplete="email">
          </div>
          <div class="st-form-actions">
            <button type="submit" class="cta-pill" id="st-profile-btn">Save Changes</button>
          </div>
        </form>
      </div>

      <!-- Preferences -->
      <div class="dash-card st-card">
        <p class="pgx-section-label">Preferences</p>
        <div class="st-pref-list">
          <div class="st-pref-row st-pref-row--last">
            <div class="st-pref-info">
              <strong>Dark Mode</strong>
              <span>Switch between light and dark theme</span>
            </div>
            <label class="st-toggle" aria-label="Toggle dark mode">
              <input type="checkbox" id="st-dark-toggle">
              <span class="st-toggle-track"></span>
            </label>
          </div>
        </div>
      </div>

      <!-- Google Authentication -->
      <div class="dash-card st-card">
        <p class="pgx-section-label">Google Authentication</p>
        <div class="st-pref-list">
          <div class="st-pref-row st-pref-row--last">
            <div class="st-pref-info">
              <strong>Google Account</strong>
              <% if (locals.user && (user.authProvider === 'google' || user.authProvider === 'both')) { %>
                <span style="color:var(--text-success)">Bound to Google OAuth</span>
              <% } else { %>
                <span>Connect your @my.cspc.edu.ph account to enable omni-channel login</span>
              <% } %>
            </div>
            <div class="st-action">
              <% if (locals.user && user.authProvider !== 'google' && user.authProvider !== 'both') { %>
                <a href="/admin/settings/bind-google" class="cta-pill" style="text-decoration:none;">Bind Google Account</a>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <div class="pgx-grid-2" style="align-items:stretch">
        <!-- Change Password -->
        <div class="dash-card st-card">
          <p class="pgx-section-label">Change Password</p>
          <div class="st-alert" id="st-pw-alert"></div>
          <form id="st-pw-form" class="st-form" novalidate>
            <div class="st-form-group">
              <label for="st-current-pw">Current Password</label>
              <div class="st-pw-wrap">
                <input type="password" id="st-current-pw" name="currentPassword" placeholder="Current password" autocomplete="current-password">
                <button type="button" class="st-pw-eye" data-target="st-current-pw" aria-label="Show/hide">
                  <span class="material-symbols-outlined eye-off">visibility_off</span>
                  <span class="material-symbols-outlined eye-on" style="display:none">visibility</span>
                </button>
              </div>
            </div>
            <div class="st-form-group">
              <label for="st-new-pw">New Password</label>
              <div class="st-pw-wrap">
                <input type="password" id="st-new-pw" name="newPassword" placeholder="New password" autocomplete="new-password">
                <button type="button" class="st-pw-eye" data-target="st-new-pw" aria-label="Show/hide">
                  <span class="material-symbols-outlined eye-off">visibility_off</span>
                  <span class="material-symbols-outlined eye-on" style="display:none">visibility</span>
                </button>
              </div>
              <div class="st-pw-strength" id="st-pw-strength"></div>
            </div>
            <div class="st-form-group">
              <label for="st-confirm-pw">Confirm New Password</label>
              <div class="st-pw-wrap">
                <input type="password" id="st-confirm-pw" name="confirmPassword" placeholder="Confirm password" autocomplete="new-password">
                <button type="button" class="st-pw-eye" data-target="st-confirm-pw" aria-label="Show/hide">
                  <span class="material-symbols-outlined eye-off">visibility_off</span>
                  <span class="material-symbols-outlined eye-on" style="display:none">visibility</span>
                </button>
              </div>
            </div>
            <div class="st-form-actions">
              <button type="submit" class="cta-pill" id="st-pw-btn">Update Password</button>
            </div>
          </form>
        </div>

        <!-- Platform Configuration -->
        <div class="dash-card st-card">
          <p class="pgx-section-label">Platform Configuration</p>
          <div class="st-alert" id="pl-alert"></div>
          <form id="pl-form" class="st-form" novalidate>
            <div class="st-form-group">
              <label for="pl-name">Platform name display</label>
              <input type="text" id="pl-name" placeholder="Hauers">
            </div>
            <div class="st-form-row">
              <div class="st-form-group">
                <label for="pl-qcount">Session question count default</label>
                <input type="number" id="pl-qcount" min="1" max="200" step="1">
              </div>
              <div class="st-form-group">
                <label for="pl-k-diag">K-factor (diagnostic)</label>
                <input type="number" id="pl-k-diag" min="1" max="200" step="1">
              </div>
            </div>
            <div class="st-form-group">
              <label for="pl-k-std">K-factor (standard)</label>
              <input type="number" id="pl-k-std" min="1" max="200" step="1">
            </div>

            <div class="st-form-group" style="margin-top:0.75rem">
              <label>Study plan phase definitions</label>
              <div id="pl-phases"></div>
              <button type="button" class="home-btn home-btn--ghost" id="pl-add-phase" style="margin-top:0.6rem">Add phase</button>
            </div>

            <div class="st-form-actions">
              <button type="submit" class="cta-pill" id="pl-save-btn">Save Configuration</button>
            </div>
          </form>
        </div>
      </div>

      <!-- Maintenance -->
      <div class="dash-card st-card">
        <p class="pgx-section-label">Maintenance</p>
        <div class="pgx-grid-2" style="align-items:start">
          <div class="st-notice" style="margin:0">
            <span class="material-symbols-outlined st-notice-ic">info</span>
            <p>Maintenance actions are for cleanup and diagnostics. This page stays aggregate and privacy-safe.</p>
          </div>
          <div>
            <div class="st-form-group">
              <label for="mt-days">Clear stale sessions older than (days)</label>
              <input type="number" id="mt-days" min="1" max="3650" step="1" value="30">
            </div>
            <div style="display:flex;gap:0.6rem;flex-wrap:wrap;margin-top:0.65rem">
              <button type="button" class="home-btn home-btn--ghost" id="mt-clear">Clear stale sessions</button>
              <button type="button" class="home-btn home-btn--ghost" id="mt-archive">Archive inactive users</button>
              <button type="button" class="home-btn home-btn--primary" id="mt-load-logs">View system logs</button>
            </div>
            <div class="st-alert" id="mt-alert" style="margin-top:0.75rem"></div>
          </div>
        </div>
        <div id="mt-logs" style="margin-top:1rem;display:none"></div>
      </div>

    </main>
  </div>

  <script src="/js/admin-shell.js"></script>
  <script>
  (function () {
    function showAlert(id, type, msg) {
      const el = document.getElementById(id);
      if (!el) return;
      el.className = 'st-alert st-alert--' + type;
      el.textContent = msg;
      el.style.display = 'flex';
      clearTimeout(el._t);
      el._t = setTimeout(() => { el.style.display = 'none'; }, 5000);
    }

    /* ── Password eye toggle ── */
    document.querySelectorAll('.st-pw-eye').forEach(btn => {
      btn.addEventListener('click', () => {
        const inp     = document.getElementById(btn.dataset.target);
        const visible = inp.type === 'text';
        inp.type = visible ? 'password' : 'text';
        btn.querySelector('.eye-off').style.display = visible ? ''     : 'none';
        btn.querySelector('.eye-on').style.display  = visible ? 'none' : '';
      });
    });

    /* ── Password strength ── */
    const pwInp = document.getElementById('st-new-pw');
    if (pwInp) {
      pwInp.addEventListener('input', function () {
        const v  = this.value;
        const el = document.getElementById('st-pw-strength');
        if (!v) { el.innerHTML = ''; return; }
        let s = 0;
        if (v.length >= 6)          s++;
        if (/[A-Z]/.test(v))        s++;
        if (/[0-9]/.test(v))        s++;
        if (/[^A-Za-z0-9]/.test(v)) s++;
        const cls   = ['', 'st-str-weak', 'st-str-fair', 'st-str-good', 'st-str-strong'][s];
        const label = ['', 'Weak',        'Fair',         'Good',        'Strong'       ][s];
        el.innerHTML =
          `<div class="st-str-bar ${cls}"><span></span><span></span><span></span><span></span></div>` +
          `<span class="st-str-label ${cls}">${label}</span>`;
      });
    }

    /* ── Theme toggle ── */
    const darkToggle = document.getElementById('st-dark-toggle');
    if (darkToggle) {
      darkToggle.checked = (localStorage.getItem('theme') || 'light') === 'dark';
      darkToggle.addEventListener('change', function () {
        const theme = this.checked ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', theme);
        localStorage.setItem('theme', theme);
      });
    }

    /* ── Load admin user ── */
    (async () => {
      try {
        const r = await fetch('/admin/api/user');
        if (!r.ok) return;
        const d = await r.json();
        document.getElementById('st-first-name').value = d.firstName || '';
        document.getElementById('st-last-name').value = d.lastName || '';
        document.getElementById('st-email-input').value = d.email || '';
      } catch (_) {}
    })();

    /* ── Update profile ── */
    document.getElementById('st-profile-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('st-profile-btn');
      btn.disabled = true; btn.textContent = 'Saving…';
      try {
        const r = await fetch('/admin/api/profile/update', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            firstName: document.getElementById('st-first-name').value,
            lastName: document.getElementById('st-last-name').value,
            email: document.getElementById('st-email-input').value,
          }),
        });
        const d = await r.json();
        if (!r.ok) showAlert('st-profile-alert', 'error', d.error || 'Update failed.');
        else showAlert('st-profile-alert', 'success', 'Profile updated.');
      } catch (_) {
        showAlert('st-profile-alert', 'error', 'Something went wrong.');
      } finally {
        btn.disabled = false; btn.textContent = 'Save Changes';
      }
    });

    /* ── Change password ── */
    document.getElementById('st-pw-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('st-pw-btn');
      btn.disabled = true; btn.textContent = 'Updating…';
      try {
        const r = await fetch('/admin/api/settings/password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            currentPassword: document.getElementById('st-current-pw').value,
            newPassword: document.getElementById('st-new-pw').value,
            confirmPassword: document.getElementById('st-confirm-pw').value,
          }),
        });
        const d = await r.json();
        if (!r.ok) showAlert('st-pw-alert', 'error', d.error || 'Update failed.');
        else { document.getElementById('st-pw-form').reset(); document.getElementById('st-pw-strength').innerHTML = ''; showAlert('st-pw-alert', 'success', 'Password updated.'); }
      } catch (_) {
        showAlert('st-pw-alert', 'error', 'Something went wrong.');
      } finally {
        btn.disabled = false; btn.textContent = 'Update Password';
      }
    });

    /* ── Platform config ── */
    const phasesHost = document.getElementById('pl-phases');
    function phaseRow(p) {
      const div = document.createElement('div');
      div.className = 'st-form-row';
      div.style.marginBottom = '0.6rem';
      div.innerHTML = `
        <div class="st-form-group">
          <label>Label</label>
          <input type="text" class="pl-phase-label" placeholder="Phase label" value="${String(p.label || '').replace(/\"/g,'&quot;')}">
        </div>
        <div class="st-form-group">
          <label>Start week</label>
          <input type="number" class="pl-phase-start" min="1" max="520" step="1" value="${Number(p.startWeek || 1)}">
        </div>
        <div class="st-form-group">
          <label>End week</label>
          <input type="number" class="pl-phase-end" min="1" max="520" step="1" value="${Number(p.endWeek || 1)}">
        </div>
        <div class="st-form-group" style="display:flex;align-items:end">
          <button type="button" class="home-btn home-btn--ghost pl-phase-del" style="width:100%">Remove</button>
        </div>
      `;
      div.querySelector('.pl-phase-del').addEventListener('click', () => div.remove());
      return div;
    }

    async function loadPlatformSettings() {
      try {
        const r = await fetch('/admin/api/settings/platform');
        if (!r.ok) return;
        const d = await r.json();
        const s = d.settings || {};
        document.getElementById('pl-name').value = s.platformNameDisplay || 'Hauers';
        document.getElementById('pl-qcount').value = s.sessionQuestionCountDefault || 15;
        document.getElementById('pl-k-diag').value = s.kFactors?.diagnostic || 48;
        document.getElementById('pl-k-std').value = s.kFactors?.standard || 24;
        phasesHost.innerHTML = '';
        (s.studyPlanPhases || []).forEach(p => phasesHost.appendChild(phaseRow(p)));
      } catch (_) {}
    }
    loadPlatformSettings();

    document.getElementById('pl-add-phase').addEventListener('click', () => {
      phasesHost.appendChild(phaseRow({ label: '', startWeek: 1, endWeek: 1 }));
    });

    document.getElementById('pl-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('pl-save-btn');
      btn.disabled = true; btn.textContent = 'Saving…';
      try {
        const phases = Array.from(phasesHost.querySelectorAll('.st-form-row')).map(row => ({
          label: row.querySelector('.pl-phase-label')?.value || '',
          startWeek: Number(row.querySelector('.pl-phase-start')?.value || 1),
          endWeek: Number(row.querySelector('.pl-phase-end')?.value || 1),
        }));
        const payload = {
          platformNameDisplay: document.getElementById('pl-name').value,
          sessionQuestionCountDefault: Number(document.getElementById('pl-qcount').value || 15),
          kFactors: {
            diagnostic: Number(document.getElementById('pl-k-diag').value || 48),
            standard: Number(document.getElementById('pl-k-std').value || 24),
          },
          studyPlanPhases: phases,
        };
        const r = await fetch('/admin/api/settings/platform', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ settings: payload }),
        });
        const d = await r.json();
        if (!r.ok) showAlert('pl-alert', 'error', d.error || 'Save failed.');
        else { showAlert('pl-alert', 'success', 'Configuration saved.'); await loadPlatformSettings(); }
      } catch (_) {
        showAlert('pl-alert', 'error', 'Something went wrong.');
      } finally {
        btn.disabled = false; btn.textContent = 'Save Configuration';
      }
    });

    /* ── Maintenance actions ── */
    async function postJson(url, body) {
      const r = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body || {}) });
      const d = await r.json().catch(() => ({}));
      if (!r.ok) throw new Error(d.error || 'Request failed');
      return d;
    }

    document.getElementById('mt-clear').addEventListener('click', async () => {
      const days = Number(document.getElementById('mt-days').value || 30);
      try {
        const d = await postJson('/admin/api/settings/maintenance/clear-stale-sessions', { days });
        showAlert('mt-alert', 'success', `Cleared stale sessions > ${d.days}d (practice: ${d.deleted.practice}, diagnostic: ${d.deleted.diagnostic}).`);
      } catch (e) {
        showAlert('mt-alert', 'error', e.message || 'Failed.');
      }
    });

    document.getElementById('mt-archive').addEventListener('click', async () => {
      try {
        const d = await postJson('/admin/api/settings/maintenance/archive-inactive-users');
        showAlert('mt-alert', 'success', `Archived ${d.affected} inactive users (batches ended >2y).`);
      } catch (e) {
        showAlert('mt-alert', 'error', e.message || 'Failed.');
      }
    });

    document.getElementById('mt-load-logs').addEventListener('click', async () => {
      const host = document.getElementById('mt-logs');
      host.style.display = '';
      host.innerHTML = '<p class="pf-muted">Loading…</p>';
      try {
        const r = await fetch('/admin/api/settings/logs?limit=100');
        const d = await r.json();
        if (!r.ok) throw new Error(d.error || 'Failed to load logs');
        const logs = d.logs || [];
        host.innerHTML = logs.length ? `
          <div class="ra-table-wrap">
            <table class="admin-table ra-table">
              <thead><tr><th>ID</th><th>Route</th><th>Message</th><th>Time</th></tr></thead>
              <tbody>
                ${logs.map(l => `<tr><td>${l.id}</td><td style="max-width:240px;word-break:break-word">${(l.route||'—')}</td><td style="max-width:520px">${String(l.message||'').replace(/</g,'&lt;')}</td><td>${l.created_at}</td></tr>`).join('')}
              </tbody>
            </table>
          </div>
        ` : '<p class="pf-muted">No logs yet.</p>';
      } catch (e) {
        host.innerHTML = '<p class="pf-muted">Failed to load logs.</p>';
      }
    });
  })();
  </script>

</body>
</html>
