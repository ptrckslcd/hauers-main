<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Settings | Hauers</title>
  <link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <script src="/js/theme-toggle.js"></script>
</head>
<body data-role="admin">

  <div id="navbar-placeholder"><%- include('../partials/navbar') %></div>

  <div class="app-shell sidebar-collapsed">
    <div class="sidebar-overlay" id="sidebar-overlay"></div>
    <div id="sidebar-placeholder"><%- include('../partials/admin-sidebar') %></div>

    <main class="page-content">

      <!-- ── Page header ── -->
      <header class="page-header">
        <div>
          <h1 class="page-title">Settings</h1>

        </div>
      </header>

      <!-- ── Settings layout ── -->
      <div class="st-layout">

        <!-- Left: user card + nav -->
        <aside class="st-aside">
          <div class="dash-card st-user-card">
            <div class="st-avatar" id="st-avatar">A</div>
            <strong class="st-name" id="st-name">Loading…</strong>
            <span class="st-email" id="st-card-email">—</span>
            <span class="badge" style="background:rgba(255,153,51,0.12);color:var(--fs-orange);border:1px solid rgba(255,153,51,0.25);font-size:0.7rem;padding:0.2rem 0.6rem;border-radius:6px;font-weight:700">
              Admin
            </span>

            <nav class="st-nav">
              <button class="st-nav-btn active" data-tab="profile">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="8" r="4"/>
                  <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
                </svg>
                Profile
              </button>
              <button class="st-nav-btn" data-tab="security">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="11" width="18" height="11" rx="2"/>
                  <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
                Security
              </button>
              <button class="st-nav-btn" data-tab="preferences">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="4"  y1="6"  x2="20" y2="6"/>
                  <line x1="4"  y1="12" x2="20" y2="12"/>
                  <line x1="4"  y1="18" x2="20" y2="18"/>
                  <circle cx="9"  cy="6"  r="2" fill="currentColor" stroke="none"/>
                  <circle cx="15" cy="12" r="2" fill="currentColor" stroke="none"/>
                  <circle cx="9"  cy="18" r="2" fill="currentColor" stroke="none"/>
                </svg>
                Preferences
              </button>
              <button class="st-nav-btn" data-tab="platform">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>
                </svg>
                Platform
              </button>
            </nav>
          </div>
        </aside>

        <!-- Right: panels -->
        <div class="st-panels">

          <!-- ── Panel: Profile ── -->
          <section class="st-panel active" id="tab-profile">
            <div class="dash-card">
              <h2 class="st-panel-title">Profile Information</h2>
              <p class="st-panel-sub">Update your display name and admin email address.</p>

              <div class="st-alert" id="st-profile-alert"></div>
              <form id="st-profile-form" class="st-form" novalidate>
                <div class="st-form-row">
                  <div class="st-form-group">
                    <label for="st-first-name">First Name</label>
                    <input type="text" id="st-first-name" name="firstName" placeholder="First name" autocomplete="given-name">
                  </div>
                  <div class="st-form-group">
                    <label for="st-last-name">Last Name</label>
                    <input type="text" id="st-last-name" name="lastName" placeholder="Last name" autocomplete="family-name">
                  </div>
                </div>
                <div class="st-form-group">
                  <label for="st-email-input">Email Address</label>
                  <input type="email" id="st-email-input" name="email" placeholder="admin@example.com" autocomplete="email">
                </div>
                <div class="st-form-group">
                  <label>Role</label>
                  <input type="text" value="Administrator" disabled
                    style="opacity:0.55;cursor:not-allowed;background:var(--bg-base)">
                </div>
                <div class="st-form-actions">
                  <button type="submit" class="cta-pill" id="st-profile-btn">Save Changes</button>
                </div>
              </form>
            </div>
          </section>

          <!-- ── Panel: Security ── -->
          <section class="st-panel" id="tab-security">
            <div class="dash-card">
              <h2 class="st-panel-title">Change Password</h2>
              <p class="st-panel-sub">Use a strong password to keep your admin account secure.</p>
              <div class="st-alert" id="st-pw-alert"></div>
              <form id="st-pw-form" class="st-form" novalidate>
                <div class="st-form-group">
                  <label for="st-current-pw">Current Password</label>
                  <div class="st-pw-wrap">
                    <input type="password" id="st-current-pw" name="currentPassword" placeholder="Enter current password" autocomplete="current-password">
                    <button type="button" class="st-pw-eye" data-target="st-current-pw" aria-label="Show/hide password">
                      <svg class="eye-off" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                      <svg class="eye-on"  width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    </button>
                  </div>
                </div>
                <div class="st-form-group">
                  <label for="st-new-pw">New Password</label>
                  <div class="st-pw-wrap">
                    <input type="password" id="st-new-pw" name="newPassword" placeholder="Enter new password" autocomplete="new-password">
                    <button type="button" class="st-pw-eye" data-target="st-new-pw" aria-label="Show/hide password">
                      <svg class="eye-off" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                      <svg class="eye-on"  width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    </button>
                  </div>
                  <div class="st-pw-strength" id="st-pw-strength"></div>
                </div>
                <div class="st-form-group">
                  <label for="st-confirm-pw">Confirm New Password</label>
                  <div class="st-pw-wrap">
                    <input type="password" id="st-confirm-pw" name="confirmPassword" placeholder="Confirm new password" autocomplete="new-password">
                    <button type="button" class="st-pw-eye" data-target="st-confirm-pw" aria-label="Show/hide password">
                      <svg class="eye-off" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                      <svg class="eye-on"  width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    </button>
                  </div>
                </div>
                <div class="st-form-actions">
                  <button type="submit" class="cta-pill" id="st-pw-btn">Update Password</button>
                </div>
              </form>
            </div>
          </section>

          <!-- ── Panel: Preferences ── -->
          <section class="st-panel" id="tab-preferences">
            <div class="dash-card">
              <h2 class="st-panel-title">Preferences</h2>
              <p class="st-panel-sub">Customize your admin interface and notification settings.</p>
              <div class="st-pref-list">

                <div class="st-pref-row">
                  <div class="st-pref-info">
                    <strong>Dark Mode</strong>
                    <span>Switch between light and dark theme</span>
                  </div>
                  <label class="st-toggle" aria-label="Toggle dark mode">
                    <input type="checkbox" id="st-dark-toggle">
                    <span class="st-toggle-track"></span>
                  </label>
                </div>

                <div class="st-pref-row">
                  <div class="st-pref-info">
                    <strong>Weekly Digest Email</strong>
                    <span>Receive a weekly platform performance summary</span>
                  </div>
                  <label class="st-toggle" aria-label="Toggle weekly digest">
                    <input type="checkbox" id="st-digest-toggle" checked>
                    <span class="st-toggle-track"></span>
                  </label>
                </div>

                <div class="st-pref-row">
                  <div class="st-pref-info">
                    <strong>New User Alerts</strong>
                    <span>Get notified when a new user registers</span>
                  </div>
                  <label class="st-toggle" aria-label="Toggle new user alerts">
                    <input type="checkbox" id="st-new-user-toggle" checked>
                    <span class="st-toggle-track"></span>
                  </label>
                </div>

                <div class="st-pref-row">
                  <div class="st-pref-info">
                    <strong>Compact Sidebar</strong>
                    <span>Start with the sidebar collapsed by default</span>
                  </div>
                  <label class="st-toggle" aria-label="Toggle compact sidebar">
                    <input type="checkbox" id="st-compact-sidebar-toggle">
                    <span class="st-toggle-track"></span>
                  </label>
                </div>

              </div>
            </div>
          </section>

          <!-- ── Panel: Platform ── -->
          <section class="st-panel" id="tab-platform">
            <div class="dash-card">
              <h2 class="st-panel-title">Platform Overview</h2>
              <p class="st-panel-sub">Read-only snapshot of key platform metrics and current configuration.</p>

              <div class="ud-field-grid" style="margin-top:1.25rem;gap:1rem 2rem">
                <div class="ud-field">
                  <span class="ud-field-label">Total Users</span>
                  <span class="ud-field-value" id="pl-total-users">—</span>
                </div>
                <div class="ud-field">
                  <span class="ud-field-label">Active Reviewees</span>
                  <span class="ud-field-value" id="pl-active">—</span>
                </div>
                <div class="ud-field">
                  <span class="ud-field-label">Avg Readiness Score</span>
                  <span class="ud-field-value" id="pl-readiness">—</span>
                </div>
                <div class="ud-field">
                  <span class="ud-field-label">Questions in Bank</span>
                  <span class="ud-field-value" id="pl-questions">—</span>
                </div>
                <div class="ud-field">
                  <span class="ud-field-label">Mock Exam Pass Rate</span>
                  <span class="ud-field-value" id="pl-pass-rate">—</span>
                </div>
                <div class="ud-field">
                  <span class="ud-field-label">Recent Signups (30d)</span>
                  <span class="ud-field-value" id="pl-signups">—</span>
                </div>
              </div>

              <div style="margin-top:1.75rem;border-top:1px solid var(--border-subdued);padding-top:1.25rem">
                <h3 style="font-size:0.85rem;font-weight:700;color:var(--text-main);margin-bottom:0.75rem">Weakest Domains Platform-wide</h3>
                <div id="pl-weak-domains" style="display:flex;flex-wrap:wrap;gap:0.5rem"></div>
              </div>

              <div style="margin-top:1.75rem;border-top:1px solid var(--border-subdued);padding-top:1.25rem">
                <h3 style="font-size:0.85rem;font-weight:700;color:var(--text-main);margin-bottom:0.75rem">Configuration</h3>
                <div class="ud-field-grid" style="gap:0.6rem 2rem">
                  <div class="ud-field">
                    <span class="ud-field-label">Platform Version</span>
                    <span class="ud-field-value">1.0.0</span>
                  </div>
                  <div class="ud-field">
                    <span class="ud-field-label">Auth Mode</span>
                    <span class="ud-field-value">Session (in-memory)</span>
                  </div>
                  <div class="ud-field">
                    <span class="ud-field-label">Data Storage</span>
                    <span class="ud-field-value">Mock (JSON)</span>
                  </div>
                  <div class="ud-field">
                    <span class="ud-field-label">Environment</span>
                    <span class="ud-field-value" id="pl-env">—</span>
                  </div>
                </div>
              </div>

            </div>
          </section>

        </div><!-- /st-panels -->
      </div><!-- /st-layout -->

    </main>
  </div>

  <script src="/js/admin-shell.js"></script>
  <script>
  /* ══════════════════════════════════════════════════════
     ADMIN ACCOUNT SETTINGS
     ══════════════════════════════════════════════════════ */

  /* ── Load profile data ─────────────────────────────── */
  (async () => {
    try {
      const res = await fetch('/admin/api/user');
      if (!res.ok) return;
      const u = await res.json();

      const initials = (u.firstName[0] + (u.lastName?.[0] || '')).toUpperCase();
      document.getElementById('st-avatar').textContent     = initials;
      document.getElementById('st-name').textContent       = u.firstName + ' ' + u.lastName;
      document.getElementById('st-card-email').textContent = u.email;

      document.getElementById('st-first-name').value  = u.firstName;
      document.getElementById('st-last-name').value   = u.lastName;
      document.getElementById('st-email-input').value = u.email;
    } catch (_) {}
  })();

  /* ── Load platform data (Platform tab) ─────────────── */
  (async () => {
    try {
      const [dashRes, qRes] = await Promise.all([
        fetch('/admin/api/dashboard'),
        fetch('/admin/api/questions'),
      ]);
      const dash = dashRes.ok ? await dashRes.json() : null;
      const qData = qRes.ok ? await qRes.json() : null;

      if (dash) {
        const setV = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = v; };
        setV('pl-total-users', dash.totalUsers);
        setV('pl-active',      dash.activeReviewees);
        setV('pl-readiness',   dash.avgReadiness + '%');
        setV('pl-pass-rate',   dash.passRate + '%');
        setV('pl-signups',     '+' + dash.recentSignups);

        const weakEl = document.getElementById('pl-weak-domains');
        if (weakEl && dash.weakestCommonDomains) {
          weakEl.innerHTML = dash.weakestCommonDomains.map(d =>
            `<span style="display:inline-flex;align-items:center;padding:0.25rem 0.65rem;
              background:rgba(255,51,102,0.08);border:1px solid rgba(255,51,102,0.2);
              border-radius:99px;font-size:0.78rem;font-weight:600;color:var(--fs-pink)">${d}</span>`
          ).join('');
        }
      }

      if (qData) {
        const el = document.getElementById('pl-questions');
        if (el) el.textContent = qData.total;
      }

      const envEl = document.getElementById('pl-env');
      if (envEl) envEl.textContent = window.location.hostname === 'localhost' ? 'Development' : 'Production';
    } catch (_) {}
  })();

  /* ── Tab switching ─────────────────────────────────── */
  document.querySelectorAll('.st-nav-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.st-nav-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.st-panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
    });
  });

  /* ── Password eye toggle ───────────────────────────── */
  document.querySelectorAll('.st-pw-eye').forEach(btn => {
    btn.addEventListener('click', () => {
      const inp     = document.getElementById(btn.dataset.target);
      const visible = inp.type === 'text';
      inp.type = visible ? 'password' : 'text';
      btn.querySelector('.eye-off').style.display = visible ? ''     : 'none';
      btn.querySelector('.eye-on').style.display  = visible ? 'none' : '';
    });
  });

  /* ── Password strength ─────────────────────────────── */
  document.getElementById('st-new-pw').addEventListener('input', function () {
    const v  = this.value;
    const el = document.getElementById('st-pw-strength');
    if (!v) { el.innerHTML = ''; return; }
    let s = 0;
    if (v.length >= 6)          s++;
    if (/[A-Z]/.test(v))        s++;
    if (/[0-9]/.test(v))        s++;
    if (/[^A-Za-z0-9]/.test(v)) s++;
    const cls   = ['', 'st-str-weak', 'st-str-fair', 'st-str-good', 'st-str-strong'][s];
    const label = ['', 'Weak',        'Fair',         'Good',        'Strong'       ][s];
    el.innerHTML =
      `<div class="st-str-bar ${cls}"><span></span><span></span><span></span><span></span></div>` +
      `<span class="st-str-label ${cls}">${label}</span>`;
  });

  /* ── Alert helper ──────────────────────────────────── */
  function showAlert(id, type, msg) {
    const el = document.getElementById(id);
    el.className = 'st-alert st-alert--' + type;
    el.textContent = msg;
    el.style.display = 'flex';
    clearTimeout(el._t);
    el._t = setTimeout(() => { el.style.display = 'none'; }, 5000);
  }

  /* ── Profile form ──────────────────────────────────── */
  document.getElementById('st-profile-form').addEventListener('submit', async e => {
    e.preventDefault();
    const btn = document.getElementById('st-profile-btn');
    btn.disabled = true; btn.textContent = 'Saving…';
    try {
      const r = await fetch('/admin/api/profile/update', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          firstName: document.getElementById('st-first-name').value.trim(),
          lastName:  document.getElementById('st-last-name').value.trim(),
          email:     document.getElementById('st-email-input').value.trim(),
        }),
      });
      const data = await r.json();
      if (!r.ok) {
        showAlert('st-profile-alert', 'error', data.error);
      } else {
        const u = data.user;
        const initials = (u.firstName[0] + (u.lastName?.[0] || '')).toUpperCase();
        document.getElementById('st-avatar').textContent     = initials;
        document.getElementById('st-name').textContent       = u.firstName + ' ' + u.lastName;
        document.getElementById('st-card-email').textContent = u.email;
        showAlert('st-profile-alert', 'success', 'Profile updated successfully!');
      }
    } catch (_) {
      showAlert('st-profile-alert', 'error', 'Something went wrong. Please try again.');
    } finally {
      btn.disabled = false; btn.textContent = 'Save Changes';
    }
  });

  /* ── Password form ─────────────────────────────────── */
  document.getElementById('st-pw-form').addEventListener('submit', async e => {
    e.preventDefault();
    const btn = document.getElementById('st-pw-btn');
    btn.disabled = true; btn.textContent = 'Updating…';
    try {
      const r = await fetch('/admin/api/settings/password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          currentPassword: document.getElementById('st-current-pw').value,
          newPassword:     document.getElementById('st-new-pw').value,
          confirmPassword: document.getElementById('st-confirm-pw').value,
        }),
      });
      const data = await r.json();
      if (!r.ok) {
        showAlert('st-pw-alert', 'error', data.error);
      } else {
        document.getElementById('st-pw-form').reset();
        document.getElementById('st-pw-strength').innerHTML = '';
        showAlert('st-pw-alert', 'success', 'Password updated successfully!');
      }
    } catch (_) {
      showAlert('st-pw-alert', 'error', 'Something went wrong. Please try again.');
    } finally {
      btn.disabled = false; btn.textContent = 'Update Password';
    }
  });

  /* ── Dark mode toggle ──────────────────────────────── */
  const darkToggle = document.getElementById('st-dark-toggle');
  darkToggle.checked = (localStorage.getItem('theme') || 'light') === 'dark';
  darkToggle.addEventListener('change', function () {
    const theme = this.checked ? 'dark' : 'light';
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('theme', theme);
  });

  /* ── Compact sidebar toggle ────────────────────────── */
  const compactToggle = document.getElementById('st-compact-sidebar-toggle');
  compactToggle.checked = localStorage.getItem('hauers_admin_sidebar_collapsed') === '1';
  compactToggle.addEventListener('change', function () {
    localStorage.setItem('hauers_admin_sidebar_collapsed', this.checked ? '1' : '0');
  });

  /* ── Other preference toggles (localStorage) ──────── */
  ['st-digest-toggle', 'st-new-user-toggle'].forEach(id => {
    const el = document.getElementById(id);
    const stored = localStorage.getItem(id);
    if (stored !== null) el.checked = stored === 'true';
    el.addEventListener('change', function () {
      localStorage.setItem(id, this.checked);
    });
  });
  </script>

</body>
</html>
