<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Hauers | Verify your email</title>
  <link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/auth.css">
  <script src="/js/theme-toggle.js"></script>
  <script src="/js/auth.js" defer></script>
</head>
<body>

  <svg width="0" height="0" style="position: absolute;">
    <defs>
      <linearGradient id="fs-gradient" x1="100%" y1="100%" x2="0%" y2="0%">
        <stop offset="0%"   stop-color="#FF3366" />
        <stop offset="50%"  stop-color="#FF9933" />
        <stop offset="100%" stop-color="#FFD633" />
      </linearGradient>
    </defs>
  </svg>

  <div class="ambient-glow"></div>

  <button id="theme-toggle-btn" class="auth-theme-toggle" aria-label="Toggle Theme">
    <svg class="sun-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
    <svg class="moon-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
  </button>

  <main class="auth-main">
    <div class="auth-column" style="align-items: center;">

      <div class="auth-icon-ring">
        <svg viewBox="0 0 24 24">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2zm0 2v.511l8 5.333 8-5.333V6H4zm0 3.618V18h16v-8.382l-8 5.333-8-5.333z"/>
        </svg>
      </div>

      <div class="greeting-area" style="text-align: center; width: 100%;">
        <div class="greeting" style="justify-content: center;">
          <span class="gradient-text">Check your inbox</span>
        </div>
        <div class="greeting-sub">We sent a 6-digit code to your email.</div>
      </div>

      <p class="auth-hint" style="text-align: center; margin-bottom: 0;">
        Enter the code below to verify your account.
        The code expires in <strong>10 minutes</strong>.
      </p>

      <form action="/verify-email" method="POST" id="otp-form" class="auth-form" style="width: 100%;">
        <input type="hidden" name="otp" id="otp-value">

        <div class="otp-group" role="group" aria-label="One-time password">
          <input class="otp-box" type="text" inputmode="numeric" maxlength="1" autocomplete="one-time-code" aria-label="Digit 1">
          <input class="otp-box" type="text" inputmode="numeric" maxlength="1" aria-label="Digit 2">
          <input class="otp-box" type="text" inputmode="numeric" maxlength="1" aria-label="Digit 3">
          <input class="otp-box" type="text" inputmode="numeric" maxlength="1" aria-label="Digit 4">
          <input class="otp-box" type="text" inputmode="numeric" maxlength="1" aria-label="Digit 5">
          <input class="otp-box" type="text" inputmode="numeric" maxlength="1" aria-label="Digit 6">
        </div>

        <button type="submit" class="submit-btn">Verify email</button>
      </form>

      <div class="resend-row">
        <span class="resend-label">Didn't receive the code?</span>
        <div class="resend-action">
          <button class="resend-btn" id="otp-resend-btn" disabled type="button">Resend</button>
          <span class="countdown" id="otp-countdown"></span>
        </div>
      </div>

      <a href="/login" class="back-link">
        <svg viewBox="0 0 24 24"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
        Back to log in
      </a>

    </div>
  </main>

</body>
</html>