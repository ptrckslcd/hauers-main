<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign Up | Hauers</title>

  <link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/auth.css">

  <script src="/js/theme-toggle.js"></script>
  <script src="/js/auth.js" defer></script>
</head>

<body>

  <!-- Global SVG gradient definition Ã¢â‚¬â€ used by input icons on focus -->
  <svg width="0" height="0" style="position: absolute;">
    <defs>
      <linearGradient id="fs-gradient" x1="100%" y1="100%" x2="0%" y2="0%">
        <stop offset="0%" stop-color="#F5A623" />
        <stop offset="100%" stop-color="#D48C1A" />
      </linearGradient>
    </defs>
  </svg>



  <!-- Theme Toggle -->
  <button id="theme-toggle-btn" class="auth-theme-toggle" aria-label="Toggle Theme">
    <svg class="sun-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
      stroke-linejoin="round">
      <circle cx="12" cy="12" r="5" />
      <line x1="12" y1="1" x2="12" y2="3" />
      <line x1="12" y1="21" x2="12" y2="23" />
      <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
      <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
      <line x1="1" y1="12" x2="3" y2="12" />
      <line x1="21" y1="12" x2="23" y2="12" />
      <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
      <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
    </svg>
    <svg class="moon-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
      stroke-linejoin="round">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
    </svg>
  </button>

  <main class="auth-main">
    <div class="auth-column">

      <div class="greeting-area">
        <div class="greeting">
          Join <a href="/" class="auth-logo-link"><img src="/assets/hauers-logo.svg" alt="" draggable="false"
              style="height: 1.1em; vertical-align: middle; margin-left: 0.5rem; margin-bottom: 4px;"></a>
        </div>
        <div class="greeting-sub">
          Reviewees sign up with their CSPC email through Google OAuth.
        </div>
      </div>

      <div class="auth-note" style="margin-bottom: 1rem; color: var(--text-subdued); line-height: 1.6; text-align: center; max-width: 34rem;">
        Local password creation is disabled for reviewees. If your email is approved, continue with Google OAuth.
      </div>

      <div class="divider">or</div>

      <a href="/auth/google?source=signup" class="google-btn" style="display:flex;align-items:center;justify-content:center;text-decoration:none;">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48">
          <path fill="#EA4335"
            d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z" />
          <path fill="#4285F4"
            d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z" />
          <path fill="#FBBC05"
            d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z" />
          <path fill="#34A853"
            d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z" />
          <path fill="none" d="M0 0h48v48H0z" />
        </svg>
        Sign up with CSPC Email
      </a>

      <p class="auth-footer-text">
        Already have an account? <a href="/login">Log in</a>
      </p>

    </div>
  </main>

</body>

</html>