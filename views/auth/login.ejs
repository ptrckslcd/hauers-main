<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login | Hauers</title>
  
  <link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/auth.css">
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=block" rel="stylesheet">
  <script src="/js/theme-toggle.js"></script>
  <!-- Removed main.js so header/footer partials do not load here -->
  <script src="/js/auth.js" defer></script>
</head>
<body>

  <!-- Global SVG definitions for the gradient used in borders & icons -->
  <svg width="0" height="0" style="position: absolute;">
    <defs>
      <linearGradient id="fs-gradient" x1="100%" y1="100%" x2="0%" y2="0%">
        <stop offset="0%" stop-color="#F5A623" />
        <stop offset="100%" stop-color="#D48C1A" />
      </linearGradient>
    </defs>
  </svg>



  <!-- Theme Toggle Button -->
  <button id="theme-toggle-btn" class="auth-theme-toggle" aria-label="Toggle Theme">
    <svg class="sun-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
    <svg class="moon-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
  </button>

  <main class="auth-main">
    <div class="auth-column">
      
      <div class="greeting-area">
        <div class="greeting">
          Log in to <a href="/" class="auth-logo-link"><img src="/assets/hauers-logo.svg" alt="" draggable="false" style="height: 1.1em; vertical-align: middle; margin-left: 0.5rem; margin-bottom: 4px;"></a>
        </div>
        <div class="greeting-sub">
          Welcome back. Please enter your details.
        </div>
      </div>

      <!-- Error banner — shown when ?error=1 -->
      <div class="auth-error-banner" id="auth-error-banner" hidden>
        <span class="material-symbols-outlined auth-error-icon">error</span>
        <span class="auth-error-text">Invalid email or password. Please try again.</span>
        <button type="button" class="auth-error-close" id="auth-error-close" aria-label="Dismiss error">
          <span class="material-symbols-outlined" style="font-size:16px">close</span>
        </button>
      </div>

      <form action="/login" method="POST" class="auth-form">
        
        <!-- Email Input -->
        <div class="input-field">
          <div class="input-inner">
            <div class="input-stack">
              <svg class="input-icon" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2zm0 2v.511l8 5.333 8-5.333V6H4zm0 3.618V18h16v-8.382l-8 5.333-8-5.333z"/></svg>
              <input type="email" name="email" id="email" placeholder="Email address" required autocomplete="email">
            </div>
          </div>
        </div>

        <!-- Password Input -->
        <div class="input-field">
          <div class="input-inner">
            <div class="input-stack">
              <svg class="input-icon" viewBox="0 0 24 24"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM9 6c0-1.66 1.34-3 3-3s3 1.34 3 3v2H9V6zm9 14H6V10h12v10zm-6-3c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2z"/></svg>
              <input type="password" name="password" id="password" placeholder="Password" required autocomplete="current-password">
              
              <button type="button" id="toggle-password" class="eye-toggle" tabindex="-1" aria-label="Toggle password visibility">
                <!-- Eye open icon -->
                <svg id="eye-icon" viewBox="0 0 24 24"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg>
              </button>

            </div>
          </div>
        </div>

        <div class="auth-actions">
          <a href="/forgot-password" class="forgot-link">Forgot password?</a>
        </div>

        <button type="submit" class="submit-btn">Log in</button>
      </form>

      <div class="divider">or</div>

      <button type="button" class="google-btn">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48">
          <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
          <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
          <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
          <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
          <path fill="none" d="M0 0h48v48H0z"/>
        </svg>
        Log in with CSPC Email
      </button>

      <p class="auth-footer-text">
        Don't have an account? <a href="/signup">Sign up</a>
      </p>

    </div>
  </main>

  <script>
    (function () {
      var params = new URLSearchParams(window.location.search);
      if (params.get('error') === '1') {
        var banner = document.getElementById('auth-error-banner');
        if (banner) banner.hidden = false;
      }
      var closeBtn = document.getElementById('auth-error-close');
      if (closeBtn) {
        closeBtn.addEventListener('click', function () {
          var banner = document.getElementById('auth-error-banner');
          if (banner) banner.hidden = true;
        });
      }
    })();
  </script>
</body>
</html>
