  position: fixed;
  inset: 0;
  z-index: 1100;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.25s ease-out;
  backdrop-filter: blur(2px);
}

.enrollment-modal-wrapper.blocking {
  pointer-events: auto;
}

.enrollment-modal-wrapper.blocking .enrollment-modal-overlay {
  pointer-events: auto;
}

.enrollment-modal-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.6);
  pointer-events: auto;
}

.enrollment-modal-content {
  position: relative;
  background: linear-gradient(180deg, var(--bg-primary, #ffffff) 0%, var(--bg-secondary, #f9fafb) 100%);
  border-radius: 18px;
  box-shadow: 0 28px 70px rgba(15, 23, 42, 0.28);
  max-width: 460px;
  width: 90%;
  max-height: 90vh;
  animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  border: 1px solid var(--border-subtle, rgba(0, 0, 0, 0.06));
  overflow-y: auto;
}

.enrollment-modal-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1rem;
  padding: 1.5rem 1.5rem 1.25rem;
  border-bottom: 1px solid var(--border-default, #e5e7eb);
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.10) 0%, rgba(37, 99, 235, 0.06) 100%);
}

.enrollment-modal-heading {
  display: flex;
  align-items: flex-start;
  gap: 0.95rem;
  min-width: 0;
}

.enrollment-modal-icon {
  width: 42px;
  height: 42px;
  border-radius: 12px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  background: rgba(245, 158, 11, 0.16);
  color: var(--fs-gold-dark, #b45309);
  border: 1px solid rgba(245, 158, 11, 0.22);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.35);
}

.enrollment-modal-icon .material-symbols-outlined {
  font-size: 22px;
}

.enrollment-modal-title {
  font-size: 1.35rem;
  font-weight: 700;
  color: var(--text-primary, #000000);
  margin: 0 0 0.25rem 0;
  letter-spacing: -0.02em;
}

.enrollment-modal-subtitle {
  font-size: 0.92rem;
  color: var(--text-secondary, #6b7280);
  margin: 0;
  font-weight: 400;
}

.enrollment-modal-close {
  width: 40px;
  height: 40px;
  background: rgba(148, 163, 184, 0.08);
