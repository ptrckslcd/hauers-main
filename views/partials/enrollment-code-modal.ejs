.enrollment-modal-close:focus-visible {
  outline: none;
  box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.18);
}

.enrollment-modal-close .material-symbols-outlined {
  font-size: 20px;
}

.enrollment-modal-body {
  padding: 1.5rem;
}

.enrollment-modal-actions {
  display: flex;
  gap: 1rem;
  margin-top: 1.5rem;
  align-items: center;
}

.enrollment-modal-secondary,
.enrollment-modal-primary {
  min-height: 44px;
}

.enrollment-modal-secondary {
  flex: 0 0 auto;
  padding-inline: 1rem;
  white-space: nowrap;
}

.enrollment-modal-primary {
  flex: 1;
}

.enrollment-modal-primary .btn-spinner {
  display: inline-flex;
  align-items: center;
