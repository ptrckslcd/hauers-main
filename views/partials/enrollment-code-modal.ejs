}

[data-theme="dark"] .enrollment-modal-close:hover {
  background: var(--bg-tertiary, #374151);
}
</style>

<script>
let enrollmentModalIsBlocking = false;

function closeEnrollmentModal() {
  // Only allow closing if not in blocking mode
  if (!enrollmentModalIsBlocking) {
    const modal = document.getElementById('enrollment-code-modal');
    if (modal) {
      modal.style.display = 'none';
      document.body.style.overflow = 'auto';
    }
  }
}

function goToDashboard() {
  window.location.href = '/reviewee/dashboard';
}

function showEnrollmentModal(blocking = false) {
  const modal = document.getElementById('enrollment-code-modal');
  if (modal) {
    enrollmentModalIsBlocking = blocking;
    modal.style.display = 'flex';
    modal.classList.toggle('blocking', blocking);
    document.body.style.overflow = 'hidden';
    
    // Hide close button if blocking
    const closeBtn = document.getElementById('enrollment-modal-close-btn');
    if (closeBtn) {
      closeBtn.style.display = 'flex';
    }
    
    // Focus input
    const input = document.getElementById('modal-enrollment-code');
    if (input) {
      setTimeout(() => input.focus(), 100);
    }
  }
}

async function handleEnrollmentCodeSubmit(event) {
  event.preventDefault();
  
  const code = document.getElementById('modal-enrollment-code').value.trim();
  const submitBtn = document.getElementById('enrollment-submit-btn');
  const errorMsg = document.getElementById('enrollment-error-msg');
  const spinner = submitBtn.querySelector('.btn-spinner');
  const text = submitBtn.querySelector('.btn-text');
  
  if (!code) {
    errorMsg.textContent = 'Please enter an enrollment code.';
    errorMsg.style.display = 'block';
    return;
  }
  
  // Show loading state
  submitBtn.disabled = true;
  spinner.style.display = 'inline-flex';
  text.style.display = 'none';
  errorMsg.style.display = 'none';
  
  try {
    const response = await fetch('/reviewee/api/enroll', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ enrollment_code: code })
    });
    
    if (!response.ok) {
      const data = await response.json();
      throw new Error(data.error || 'Failed to submit enrollment code');
    }
    
    // Success - show toast and reload
    if (typeof showToast === 'function') {
      showToast('Enrollment successful!', 'success');
    }
    
    // Close modal and reload page to clear the gate parameter
    setTimeout(() => {
      const modal = document.getElementById('enrollment-code-modal');
      if (modal) modal.style.display = 'none';
      document.body.style.overflow = 'auto';
      
      // Remove the gate parameter from URL and reload
      const cleanUrl = window.location.pathname;
      window.history.replaceState({}, document.title, cleanUrl);
      window.location.reload();
    }, 500);
    
  } catch (error) {
    errorMsg.textContent = error.message || 'Invalid or expired enrollment code.';
    errorMsg.style.display = 'block';
    submitBtn.disabled = false;
    spinner.style.display = 'none';
    text.style.display = 'inline';
  }
}

// Initialize on page load
document.addEventListener('DOMContentLoaded', function() {
  const urlParams = new URLSearchParams(window.location.search);
  const gateParam = urlParams.get('gate');
  
  if (gateParam === 'requireEnrolled') {
    // Show blocking modal
    showEnrollmentModal(true);
  }
});
</script>
