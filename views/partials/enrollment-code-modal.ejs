<!-- Enrollment Code Modal -->
<div id="enrollment-code-modal" class="enrollment-modal-wrapper" style="display: none;">
  <div class="enrollment-modal-overlay"></div>
  <div class="enrollment-modal-content">
    <div class="enrollment-modal-header">
      <div class="enrollment-modal-heading">
        <div class="enrollment-modal-icon">
          <span class="material-symbols-outlined">passkey</span>
        </div>
        <div>
        <h2 class="enrollment-modal-title">Enrollment Code Required</h2>
        <p class="enrollment-modal-subtitle">Enter your access code to continue</p>
        </div>
      </div>
      <button class="enrollment-modal-close" id="enrollment-modal-close-btn" aria-label="Leave this page" onclick="goToDashboard()">
        <span class="material-symbols-outlined">close</span>
      </button>
    </div>
    
    <div class="enrollment-modal-body">
      <form id="enrollment-code-form" onsubmit="handleEnrollmentCodeSubmit(event)">
        <div class="form-group">
          <label class="input-label" for="modal-enrollment-code">Enrollment Code</label>
          <div class="input-field">
            <div class="input-inner">
              <div class="input-stack">
                <input 
                  type="text" 
                  id="modal-enrollment-code" 
                  name="enrollmentCode" 
                  placeholder="e.g. ACCESS-2026" 
                  autocomplete="off" 
                  spellcheck="false" 
                  style="text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600;"
                  required
                >
              </div>
            </div>
          </div>
          <p style="font-size: 0.85rem; color: var(--text-subdued); margin-top: 0.5rem; line-height: 1.4;">
            This code ties your account to a specific exam batch. Check your enrollment email or contact your administrator if you don't have one.
          </p>
        </div>

        <div id="enrollment-error-msg" style="display: none; margin-top: 1rem; padding: 0.75rem; background: rgba(239, 68, 68, 0.1); border: 1px solid #ef4444; border-radius: 6px; color: #dc2626; font-size: 0.9rem;"></div>

        <div class="enrollment-modal-actions">
          <button type="button" class="home-btn home-btn--ghost enrollment-modal-secondary" onclick="goToDashboard()">
            <span class="material-symbols-outlined">space_dashboard</span>
            Go to Dashboard
          </button>
          <button type="submit" class="home-btn home-btn--primary enrollment-modal-primary" id="enrollment-submit-btn">
            <span class="btn-text">Submit Code</span>
            <span class="btn-spinner" style="display: none;">
              <span class="material-symbols-outlined enrollment-spin">progress_activity</span>
            </span>
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<style>
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

