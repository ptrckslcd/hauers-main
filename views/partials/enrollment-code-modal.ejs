.enrollment-modal-body .input-label {
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  margin-bottom: 0.55rem;
  color: var(--text-primary, #111827);
  font-weight: 650;
}

.enrollment-modal-body .input-field {
  padding: 0;
  border: none;
  background: transparent;
}

.enrollment-modal-body .input-inner {
  background: transparent;
  padding: 0;
}

.enrollment-modal-body .input-stack {
  position: relative;
}

.enrollment-spin {
  font-size: 18px;
  animation: spin 1s linear infinite;
}

[data-theme="dark"] .enrollment-modal-content {
  background: linear-gradient(180deg, var(--bg-primary, #111827) 0%, var(--bg-secondary, #0f172a) 100%);
}

[data-theme="dark"] .enrollment-modal-header {
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.08) 0%, rgba(37, 99, 235, 0.08) 100%);
}

[data-theme="dark"] .enrollment-modal-icon {
  background: rgba(245, 158, 11, 0.12);
  color: #f59e0b;
  border-color: rgba(245, 158, 11, 0.18);
