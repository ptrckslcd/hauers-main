<nav class="top-navbar">

  <!-- Left: logos -->
  <div class="nav-left">
    <a href="/reviewee/dashboard" class="nav-logo-link" tabindex="-1" aria-hidden="true">
      <!-- CSPC seal — swaps with theme -->
      <img src="/assets/cspc-og-logo.png"    alt="CSPC logo" class="nav-cspc-logo nav-cspc-logo--light" height="30">
      <img src="/assets/cspc-white-logo.png" alt="CSPC logo" class="nav-cspc-logo nav-cspc-logo--dark"  height="30">
      <span class="nav-logo-sep" aria-hidden="true"></span>
      <img src="/assets/access-logo.svg" alt="ACCESS logo" class="nav-access-logo" height="20">
      <span class="nav-x" aria-hidden="true">&times;</span>
      <img src="/assets/hauers-logo.svg" alt="Hauers logo" height="20">
    </a>
  </div>

  <!-- Center: search bar -->
  <div class="nav-center">
    <div class="nav-search-wrap">
      <span class="material-symbols-outlined search-icon">search</span>
      <input type="text" class="nav-search-input" placeholder="Search Hauers..." aria-label="Search">
    </div>
  </div>

  <!-- Right: notification bell + theme toggle + divider + user info -->
  <div class="nav-right">

    <!-- Notification bell -->
    <div class="nav-notif-wrap" id="nav-notif-wrap">
      <button class="nav-icon-btn nav-notif-btn" id="nav-notif-btn" type="button" aria-label="Notifications">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
          <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
        </svg>
        <span class="nav-notif-badge" id="nav-notif-badge" hidden></span>
      </button>
      <div class="nav-notif-panel" id="nav-notif-panel" hidden>
        <div class="nav-notif-header">
          <span class="nav-notif-title">Notifications</span>
          <button type="button" class="nav-notif-clear" id="nav-notif-clear">Mark all read</button>
        </div>
        <div class="nav-notif-list" id="nav-notif-list">
          <!-- populated by shell scripts -->
        </div>
      </div>
    </div>

    <button id="theme-toggle-btn" class="nav-icon-btn" type="button" aria-label="Toggle theme">
      <!-- Sun -->
      <svg class="sun-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="4.5"/>
        <line x1="12" y1="2" x2="12" y2="4.5"/>
        <line x1="12" y1="19.5" x2="12" y2="22"/>
        <line x1="4.93" y1="4.93" x2="6.7" y2="6.7"/>
        <line x1="17.3" y1="17.3" x2="19.07" y2="19.07"/>
        <line x1="2" y1="12" x2="4.5" y2="12"/>
        <line x1="19.5" y1="12" x2="22" y2="12"/>
        <line x1="4.93" y1="19.07" x2="6.7" y2="17.3"/>
        <line x1="17.3" y1="6.7" x2="19.07" y2="4.93"/>
      </svg>
      <!-- Moon -->
      <svg class="moon-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>

    <span class="nav-divider" aria-hidden="true"></span>

    <!-- User profile (clickable → profile popup) -->
    <div class="nav-user nav-user--clickable" id="nav-user" role="button" tabindex="0" aria-haspopup="true" aria-expanded="false">
      <div class="nav-avatar" id="nav-avatar"><%= locals.user ? user.firstName[0] : 'U' %></div>
      <div class="nav-user-info">
        <span class="nav-user-name" id="nav-user-name"><%= locals.user ? user.firstName + ' ' + user.lastName : 'User' %></span>
        <span class="nav-user-email" id="nav-user-email"><%= locals.user ? user.email : 'user@hauers.com' %></span>
      </div>

      <!-- Profile popup dropdown -->
      <div class="nav-profile-popup" id="nav-profile-popup" hidden role="menu">
        <div class="npp-header">
          <div class="npp-avatar" id="npp-avatar"><%= locals.user ? user.firstName[0] : 'U' %></div>
          <div class="npp-info">
            <strong class="npp-name" id="npp-name"><%= locals.user ? user.firstName + ' ' + user.lastName : 'User' %></strong>
            <span class="npp-email" id="npp-email"><%= locals.user ? user.email : 'user@hauers.com' %></span>
            <div class="npp-role-wrap">
              <span class="material-symbols-outlined">badge</span>
              <span class="npp-role" id="npp-role"><%= locals.user ? (user.role === 'admin' ? 'Administrator' : 'Reviewee') : 'Role' %></span>
            </div>
          </div>
        </div>
        <div class="npp-divider"></div>
        <div class="npp-actions">
          <a class="npp-link" id="npp-edit-link" href="/<%= locals.user && user.role === 'admin' ? 'admin' : 'reviewee' %>/profile" role="menuitem">
            <span class="npp-icon material-symbols-outlined">person</span>
            My Profile
          </a>
          <a class="npp-link" id="npp-settings-link" href="/<%= locals.user && user.role === 'admin' ? 'admin' : 'reviewee' %>/settings" role="menuitem">
            <span class="npp-icon material-symbols-outlined">settings</span>
            Account Settings
          </a>
          <a class="npp-link" id="npp-help-link" href="mailto:hauers.app@gmail.com" role="menuitem">
            <span class="npp-icon material-symbols-outlined">help</span>
            Help &amp; Support
          </a>
        </div>
        <div class="npp-divider"></div>
        <a class="npp-link npp-link--logout" href="/logout" role="menuitem">
          <span class="npp-icon material-symbols-outlined">logout</span>
          Log out
        </a>
      </div>
    </div>
  </div>

</nav>