<div class="header-outer">
  <header class="site-header">
    <div class="brand-group">
      <a href="/" style="display:flex;align-items:center;gap:0.75rem;">
        <img src="/assets/access-logo.svg" alt="ACCESS logo" class="logo-access" height="26">
        <span class="brand-separator">×</span>
        <img src="/assets/hauers-logo.svg" alt="Hauers logo" class="logo-hauers" height="26">
      </a>
    </div>
    <nav class="header-nav">
      <a href="/" class="nav-link">Home</a>
      <a href="#features" class="nav-link">Features</a>
      <a href="#about" class="nav-link">About</a>
    </nav>
    <div class="header-actions">
      <button id="theme-toggle-btn" class="theme-toggle-btn" aria-label="Switch between dark and light mode" title="Toggle dark mode">
        <!-- Sun: shown in dark mode -->
        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
          stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="17" height="17" aria-hidden="true">
          <circle cx="12" cy="12" r="5" />
          <line x1="12" y1="1" x2="12" y2="3" />
          <line x1="12" y1="21" x2="12" y2="23" />
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
          <line x1="1" y1="12" x2="3" y2="12" />
          <line x1="21" y1="12" x2="23" y2="12" />
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
        </svg>
        <!-- Moon: shown in light mode -->
        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="17"
          height="17" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
      </button>
      <a href="/login" class="header-login">Log In</a>
      <a href="/signup" class="header-cta">Sign Up</a>
