<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Privacy Policy | Hauers</title>
  <link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link rel="stylesheet" href="/css/legal.css">
  <script src="/js/theme-toggle.js"></script>
</head>
<body data-role="reviewee">

  <div id="navbar-placeholder"><%- include('../partials/navbar') %></div>

  <div class="app-shell sidebar-collapsed">
    <div class="sidebar-overlay" id="sidebar-overlay"></div>
    <div id="sidebar-placeholder"><%- include('../partials/sidebar') %></div>

    <main class="page-content legal-page">

      <!-- ── Header ── -->
      <div class="legal-header">
        <p class="legal-eyebrow">Legal</p>
        <h1 class="legal-title">Privacy Policy</h1>
        <div class="legal-meta">
          <span class="legal-meta-dot"></span>
          Last updated: March 12, 2026
        </div>
        <div class="legal-highlight">
          Your privacy matters to us. Hauers is a small, student-built platform &mdash; we collect only what we need to make the review experience work, and we do not sell your data.
        </div>
      </div>

      <!-- ── Grid: TOC + content ── -->
      <div class="legal-grid">

        <!-- TOC -->
        <aside class="legal-toc-col">
          <nav class="legal-toc" aria-label="Table of contents">
            <p class="legal-toc-label">On this page</p>
            <ol>
              <li><a href="#overview">Overview</a></li>
              <li><a href="#data-collected">Data We Collect</a></li>
              <li><a href="#how-we-use">How We Use Your Data</a></li>
              <li><a href="#data-storage">Data Storage &amp; Security</a></li>
              <li><a href="#sharing">Data Sharing</a></li>
              <li><a href="#cookies">Cookies &amp; Local Storage</a></li>
              <li><a href="#your-rights">Your Rights</a></li>
              <li><a href="#children">Children&rsquo;s Privacy</a></li>
              <li><a href="#changes">Changes to This Policy</a></li>
              <li><a href="#contact">Contact Us</a></li>
            </ol>
          </nav>
        </aside>

        <!-- Sections -->
        <div class="legal-sections">

          <section class="legal-section" id="overview">
            <h2>1. Overview</h2>
            <p>This Privacy Policy explains how Camarines Sur Polytechnic Colleges - Academic Center for Continuing Enhancement Services for Students ("CSPC ACCESS") &times; Hauers (&ldquo;Hauers,&rdquo; &ldquo;we,&rdquo; &ldquo;us,&rdquo; or &ldquo;our&rdquo;) collects, uses, stores, and protects information about you when you use the Hauers platform. It also explains your rights with respect to that information.</p>
            <p>By using Hauers, you agree to the collection and use of information as described in this policy. If you disagree, please discontinue use and delete your account.</p>
          </section>

          <section class="legal-section" id="data-collected">
            <h2>2. Data We Collect</h2>
            <p>We collect only the minimum information necessary to provide the platform&rsquo;s features:</p>
            <table class="legal-data-table">
              <thead>
                <tr>
                  <th>Data Type</th>
                  <th>Examples</th>
                  <th>How Collected</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><strong>Account Information</strong></td>
                  <td>First name, last name, email address, password (hashed), exam level</td>
                  <td>Provided by you during registration</td>
                </tr>
                <tr>
                  <td><strong>Usage Data</strong></td>
                  <td>Quiz scores, diagnostic results, study plan progress, materials viewed</td>
                  <td>Generated automatically as you use the platform</td>
                </tr>
                <tr>
                  <td><strong>Session Data</strong></td>
                  <td>Login session token, current page, authentication state</td>
                  <td>Created automatically at login</td>
                </tr>
                <tr>
                  <td><strong>Preferences</strong></td>
                  <td>Theme (dark/light), notification preferences, countdown visibility</td>
                  <td>Stored in your browser&rsquo;s localStorage</td>
                </tr>
              </tbody>
            </table>
            <p>We do <strong>not</strong> collect payment information, government IDs, or any sensitive personal data beyond what is listed above.</p>
          </section>

          <section class="legal-section" id="how-we-use">
            <h2>3. How We Use Your Data</h2>
            <p>We use the information we collect to:</p>
            <ul>
              <li>Create and manage your account and authenticate your sessions.</li>
              <li>Personalize your study plan, diagnostic results, and progress tracking.</li>
              <li>Display your readiness scores, domain breakdowns, and learning streak.</li>
              <li>Send study reminders or progress updates if you have opted in.</li>
              <li>Improve the platform&rsquo;s features based on aggregated, anonymized usage patterns.</li>
              <li>Respond to support inquiries or reported issues.</li>
            </ul>
            <p>We do not use your data for advertising, profiling for commercial purposes, or any purpose unrelated to your CSE-PPT review.</p>
          </section>

          <section class="legal-section" id="data-storage">
            <h2>4. Data Storage &amp; Security</h2>
            <p>Your account data is stored in a secure server environment. We implement reasonable technical and organizational measures to protect your data from unauthorized access, alteration, disclosure, or destruction, including:</p>
            <ul>
              <li>Password hashing &mdash; passwords are never stored in plain text.</li>
              <li>Server-side session management with secure, HttpOnly cookies.</li>
              <li>HTTPS encryption for all data in transit.</li>
            </ul>
            <p>While we take security seriously, no method of electronic storage or transmission is 100% secure. We encourage you to use a strong, unique password for your account.</p>
            <p>Your data is retained for as long as your account is active. You may request deletion at any time (see <a href="#your-rights">Your Rights</a>).</p>
          </section>

          <section class="legal-section" id="sharing">
            <h2>5. Data Sharing</h2>
            <p>We do <strong>not</strong> sell, rent, or trade your personal information to any third party. Your data may be shared only in the following limited circumstances:</p>
            <ul>
              <li><strong>With CSPC ACCESS administrators</strong> &mdash; for platform oversight and academic coordination, in aggregate or anonymized form where possible.</li>
              <li><strong>As required by law</strong> &mdash; if we are legally compelled to disclose information by a valid court order or government authority.</li>
              <li><strong>To protect rights and safety</strong> &mdash; if disclosure is necessary to prevent fraud, abuse, or harm to users or the platform.</li>
            </ul>
          </section>

          <section class="legal-section" id="cookies">
            <h2>6. Cookies &amp; Local Storage</h2>
            <p>Hauers uses the following client-side storage mechanisms:</p>
            <ul>
              <li><strong>Session cookie</strong> &mdash; a server-issued, HttpOnly cookie used to maintain your login session. It expires when you log out or your session times out.</li>
              <li><strong>localStorage</strong> &mdash; used to store your UI preferences (dark mode, notification toggles) locally in your browser. This data never leaves your device.</li>
            </ul>
            <p>We do not use third-party tracking cookies, advertising cookies, or analytics services that share data externally.</p>
          </section>

          <section class="legal-section" id="your-rights">
            <h2>7. Your Rights</h2>
            <p>As a user of Hauers, you have the following rights regarding your personal data:</p>
            <ul>
              <li><strong>Access</strong> &mdash; you may view and update your profile information at any time via the <a href="/reviewee/settings">Account Settings</a> page.</li>
              <li><strong>Correction</strong> &mdash; you may correct inaccurate personal information in your account settings.</li>
              <li><strong>Deletion</strong> &mdash; you may request the deletion of your account and associated data by emailing <a href="mailto:hauers.app@gmail.com">hauers.app@gmail.com</a>. We will process deletion requests within 30 days.</li>
              <li><strong>Data portability</strong> &mdash; you may request a copy of your stored account data in readable format.</li>
              <li><strong>Opt-out</strong> &mdash; you may disable study reminders and email notifications in your Account Settings at any time.</li>
            </ul>
          </section>

          <section class="legal-section" id="children">
            <h2>8. Children&rsquo;s Privacy</h2>
            <p>Hauers is not directed to children under the age of 18. We do not knowingly collect personal information from anyone under 18. If you believe a minor has registered an account, please contact us so we can promptly delete the account and associated data.</p>
          </section>

          <section class="legal-section" id="changes">
            <h2>9. Changes to This Policy</h2>
            <p>We may update this Privacy Policy from time to time. When we do, we will revise the &ldquo;Last updated&rdquo; date at the top of this page. For significant changes, we will make reasonable efforts to notify registered users via email or an in-platform notice.</p>
            <p>Continued use of Hauers after any changes constitutes your acceptance of the updated policy.</p>
          </section>

          <section class="legal-section" id="contact">
            <h2>10. Contact Us</h2>
            <p>If you have questions, concerns, or requests related to your privacy or this policy, please reach out:</p>
          </section>

          <div class="legal-contact-box">
            <p>
              <strong>CSPC ACCESS &times; Hauers</strong><br>
              Email: <a href="mailto:hauers.app@gmail.com">hauers.app@gmail.com</a><br>
              Camarines Sur Polytechnic Colleges<br>
              Nabua, Camarines Sur, Philippines
            </p>
            <p>Also see our <a href="/terms">Terms of Service</a> for the rules governing use of the platform.</p>
          </div>

        </div><!-- /legal-sections -->
      </div><!-- /legal-grid -->

    </main>
  </div>

  <script src="/js/app-shell.js"></script>
  <script>
    /* ── TOC scroll spy ── */
    const _sections = document.querySelectorAll('.legal-section');
    const _links    = document.querySelectorAll('.legal-toc a');
    const _spy = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          _links.forEach(l => l.classList.remove('toc-active'));
          const t = document.querySelector(`.legal-toc a[href="#${e.target.id}"]`);
          if (t) t.classList.add('toc-active');
        }
      });
    }, { rootMargin: '-15% 0% -75% 0%' });
    _sections.forEach(s => _spy.observe(s));
  </script>

</body>
</html>