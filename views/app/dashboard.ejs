<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Home | Hauers</title>
  <link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <script src="/js/theme-toggle.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
</head>
<body data-role="reviewee">

  <div id="navbar-placeholder"><%- include('../partials/navbar') %></div>

  <div class="app-shell sidebar-collapsed">
    <div class="sidebar-overlay" id="sidebar-overlay"></div>
    <div id="sidebar-placeholder"><%- include('../partials/sidebar') %></div>

    <main class="page-content home-page">

      <!-- Load error -->
      <div class="home-load-error" id="home-load-error" role="alert" hidden>
        <span class="material-symbols-outlined" aria-hidden="true">wifi_off</span>
        <p class="home-load-error-text">Could not load your dashboard.</p>
        <button type="button" class="home-btn home-btn--ghost home-retry-btn" id="home-retry-btn">Try again</button>
      </div>

      <!-- ── Header ── -->
      <header class="home-header">
        <div class="home-greet-block">
          <p class="home-greet-eyebrow" id="home-greeting-eyebrow"></p>
          <h1 class="home-greet-name" id="home-greeting-name">—</h1>
        </div>
        <div class="home-header-actions">
          <a href="/reviewee/review" class="home-btn home-btn--primary" id="btn-continue">
            <span class="material-symbols-outlined" aria-hidden="true">play_circle</span>
            Continue Studying
          </a>
          <a href="/reviewee/progress" class="home-btn home-btn--ghost">
            <span class="material-symbols-outlined" aria-hidden="true">insights</span>
            View Progress
          </a>
        </div>
      </header>

      <!-- ── Pre-test callout ── -->
      <section class="home-pretest-callout" id="pretest-banner" aria-labelledby="home-pretest-heading" hidden>
        <span class="material-symbols-outlined home-pretest-icon" aria-hidden="true">assignment_late</span>
        <div class="home-pretest-body">
          <h2 class="home-pretest-title" id="home-pretest-heading">Complete your pre-test first</h2>
          <p class="home-pretest-desc">The 45-minute pre-test measures your baseline across all exam domains. It unlocks your personalised study plan and today's recommendations.</p>
        </div>
        <a href="/reviewee/diagnostic" class="home-btn home-btn--primary home-pretest-cta">Take Pre-test</a>
      </section>

      <!-- ── Announcements Banner ── -->
      <div id="announcements-banner-placeholder"></div>

      <!-- ── Main grid ── -->
      <div class="home-main-grid">

        <!-- Activity: 4 top cards -->
        <div class="home-stats-row">

          <div class="dash-card home-stat-card">
            <div class="home-stat-ico-wrap home-stat-ico-wrap--green" aria-hidden="true">
              <span class="material-symbols-outlined">analytics</span>
            </div>
            <div class="home-stat-copy">
              <span class="home-stat-value"><span id="home-stat-readiness">—</span><span style="font-size: 0.65em; font-weight: normal; color: var(--text-subdued);">/100</span></span>
              <span class="home-stat-label">Exam readiness</span>
            </div>
          </div>

          <div class="dash-card home-stat-card">
            <div class="home-stat-ico-wrap home-stat-ico-wrap--fire" aria-hidden="true">
              <span class="material-symbols-outlined">local_fire_department</span>
            </div>
            <div class="home-stat-copy">
              <span class="home-stat-value" id="home-streak">0</span>
              <span class="home-stat-label">Day study streak</span>
            </div>
          </div>

          <div class="dash-card home-stat-card">
            <div class="home-stat-ico-wrap home-stat-ico-wrap--blue" aria-hidden="true">
              <span class="material-symbols-outlined">event_available</span>
            </div>
            <div class="home-stat-copy">
              <span class="home-stat-value" id="home-session-count">0</span>
              <span class="home-stat-label">Sessions completed</span>
            </div>
          </div>

          <div class="dash-card home-stat-card" id="home-tile-exam">
            <div class="home-stat-ico-wrap home-stat-ico-wrap--amber" aria-hidden="true">
              <span class="material-symbols-outlined">hourglass_bottom</span>
            </div>
            <div class="home-stat-copy">
              <span class="home-stat-value home-stat-value--days" id="home-days-left">—</span>
              <span class="home-stat-label">Days to exam</span>
              <span class="home-stat-meta" id="home-exam-date-label" hidden></span>
            </div>
          </div>
        </div>

        <!-- Today's Focus -->
        <section class="home-recs-section" aria-labelledby="home-focus-heading">
          <div class="home-recs-header">
            <div>
              <h2 class="home-recs-title" id="home-focus-heading">Today's Focus</h2>
            </div>
          </div>
          <div id="home-focus-content" class="dash-card home-focus-card">
            <p class="home-focus-loading">Checking today's tasks…</p>
          </div>
        </section>

        <!-- Recommended Materials -->
        <section class="home-recs-section" aria-labelledby="home-recs-heading">
          <div class="home-recs-header">
            <div>
              <h2 class="home-recs-title" id="home-recs-heading">Recommended Materials</h2>
            </div>
            <a href="/reviewee/materials" class="home-recs-seeall">
              See all
              <span class="material-symbols-outlined" aria-hidden="true">arrow_forward</span>
            </a>
          </div>
          <div class="dash-card home-mat-shell">
            <div id="home-rec-list" class="home-mat-grid">
              <div class="home-mat-empty">
                <span class="material-symbols-outlined" aria-hidden="true">auto_stories</span>
                <p>Complete your pre-test to get personalised recommendations.</p>
              </div>
            </div>
          </div>
        </section>

    <div>
        <!-- Performance by Domain -->
        <section class="home-recs-section" aria-labelledby="home-performance-heading">
          <div class="home-recs-header">
            <div>
              <h2 class="home-recs-title" id="home-performance-heading">Performance by Domain</h2>
            </div>
          </div>
          <div class="dash-card home-perf-card">
            <div class="home-perf-body">
              <div class="home-perf-chart-col">
                <div class="home-domain-chart-wrap" id="home-domain-chart-wrap">
                  <canvas id="home-domain-chart" aria-label="Domain score radar chart"></canvas>
                </div>
              </div>
              <div class="home-perf-list-col">
                <div class="home-perf-domain-list" id="home-perf-domain-list">
                  <div class="home-rec-empty"><p>Complete the pre-test to see domain scores.</p></div>
                </div>
                <div class="home-perf-insight" id="home-perf-insight" hidden>
                  <span class="home-perf-insight-domain" id="home-focus-domain"></span>
                  <p class="home-perf-insight-copy" id="home-focus-copy"></p>
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>

      </div>
      </main>
  </div>

  <script src="/js/app-shell.js"></script>
  <script>
  (function () {

    var DOMAIN_COLORS = {
      'Verbal Ability':      '#818cf8',
      'Numerical Ability':   '#f97316',
      'Analytical Ability':  '#2dd4bf',
      'Clerical Ability':    '#ec4899',
      'General Information': '#10b981',
    };

    /* Canonical domain order — ensures General Info always appears */
    var CANONICAL_DOMAINS = [
      'Verbal Ability',
      'Numerical Ability',
      'Analytical Ability',
      'General Information',
    ];

    /* ─── Safe broadcast (no innerHTML from user data) ─── */
    function safeBroadcastUrl(raw) {
      if (!raw || typeof raw !== 'string') return '';
      try {
        var u = new URL(raw.trim(), window.location.origin);
        if (u.protocol !== 'http:' && u.protocol !== 'https:') return '';
        if (u.origin !== window.location.origin) return '';
        return u.pathname + u.search + u.hash;
      } catch (_) { return ''; }
    }

    function appendBroadcast() {
      var broadcasts;
      try { broadcasts = JSON.parse(localStorage.getItem('hauers_broadcasts') || '[]'); }
      catch (_) { return; }
      if (!Array.isArray(broadcasts) || !broadcasts.length) return;
      var a = broadcasts[0];
      if (!a || typeof a !== 'object') return;
      var main = document.querySelector('.page-content');
      if (!main || document.getElementById('dash-announcement')) return;
      var wrap = document.createElement('div');
      wrap.id = 'dash-announcement';
      wrap.className = 'home-broadcast';
      wrap.setAttribute('role', 'status');
      var ico = document.createElement('span');
      ico.className = 'material-symbols-outlined home-broadcast-icon';
      ico.setAttribute('aria-hidden', 'true');
      ico.textContent = 'campaign';
      var body = document.createElement('div');
      body.className = 'home-broadcast-body';
      var t = document.createElement('strong'); t.textContent = String(a.title || '');
      var c = document.createElement('span');  c.textContent = String(a.content || '');
      body.appendChild(t); body.appendChild(c);
      var sl = safeBroadcastUrl(a.link);
      if (sl) { var al = document.createElement('a'); al.href = sl; al.textContent = 'Read more'; al.rel = 'noopener noreferrer'; body.appendChild(al); }
      var btn = document.createElement('button');
      btn.type = 'button'; btn.className = 'home-broadcast-close'; btn.setAttribute('aria-label', 'Dismiss');
      btn.addEventListener('click', function () { wrap.remove(); });
      var ci = document.createElement('span'); ci.className = 'material-symbols-outlined'; ci.setAttribute('aria-hidden', 'true'); ci.textContent = 'close';
      btn.appendChild(ci);
      wrap.appendChild(ico); wrap.appendChild(body); wrap.appendChild(btn);
      main.insertBefore(wrap, main.firstChild);
    }

    /* ─── Escape for innerHTML ─── */
    function esc(s) {
      return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    /* ─── Domain class ─── */
    function domClass(x) {
      if (x === 'Verbal Ability') return 'verbal';
      if (x === 'Numerical Ability') return 'numerical';
      if (x === 'Analytical Ability') return 'analytical';
      if (x === 'Clerical Ability') return 'clerical';
      return 'general';
    }

    function parseLocalDateOnly(value) {
      if (!value) return null;
      if (value instanceof Date) return new Date(value.getFullYear(), value.getMonth(), value.getDate());
      var parts = String(value).split('-');
      if (parts.length !== 3) return null;
      var year = Number(parts[0]);
      var month = Number(parts[1]);
      var day = Number(parts[2]);
      if (!Number.isFinite(year) || !Number.isFinite(month) || !Number.isFinite(day)) return null;
      return new Date(year, month - 1, day);
    }

    /* Short labels keep the chart narrow; full names in tooltip */
    var DOMAIN_SHORT = {
      'Verbal Ability':      'Verbal',
      'Numerical Ability':   'Numerical',
      'Analytical Ability':  'Analytical',
      'Clerical Ability':    'Clerical',
      'General Information': 'Gen. Info',
    };

    function domainAdvice(domain, score) {
      var short = (domain || 'this domain').replace(' Ability', '').toLowerCase();
      if (score >= 80) return 'Maintain this area with quick drills while you focus more time elsewhere.';
      if (score >= 65) return 'Close to passing. Do timed practice and review missed items in ' + short + '.';
      if (score > 0) return 'Prioritise guided review and short drills in ' + short + ' before your next full session.';
      return 'No score yet. Complete the pre-test to unlock a targeted action for this domain.';
    }

    /* index === -1 means "Overall"; any other index = specific domain */
    function updateDomainInsight(domainScores, index, overallScore) {
      var domainEl  = document.getElementById('home-focus-domain');
      var copyEl    = document.getElementById('home-focus-copy');
      var insightEl = document.getElementById('home-perf-insight');
      if (!domainScores || !domainScores.length) return;

      if (insightEl) insightEl.removeAttribute('hidden');

      if (index === -1) {
        var pct = Number.isFinite(overallScore) ? Math.round(overallScore) : 0;
        if (domainEl) domainEl.textContent = 'Overall readiness';
        var gap = 80 - pct;
        if (copyEl) copyEl.textContent = pct > 0
          ? pct + '% overall. ' + (gap <= 0
              ? 'You\'ve reached the passing threshold. Keep the momentum up.'
              : gap + ' pts away from the 80% pass mark. Focus on your weakest area.')
          : 'Complete the pre-test to calculate your overall readiness score.';
      } else {
        var d = domainScores[index] || domainScores[0];
        var sn = Number(d && d.score);
        var score = Number.isFinite(sn) ? Math.round(sn) : 0;
        if (domainEl) domainEl.textContent = (d.domain || 'Domain').replace(' Ability', '');
        if (copyEl) copyEl.textContent = score + '% readiness. ' + domainAdvice(d.domain, score);
      }

      /* Highlight active domain row */
      var listEl = document.getElementById('home-perf-domain-list');
      if (listEl) {
        listEl.querySelectorAll('.home-perf-row').forEach(function (row) {
          row.classList.toggle('active', Number(row.getAttribute('data-domain-index')) === index);
        });
      }

    }

    /* ─── Domain progress-bar list ─── */
    function buildDomainList(domainScores, overallScore) {
      var listEl = document.getElementById('home-perf-domain-list');
      if (!listEl) return;
      if (!domainScores || !domainScores.length) {
        listEl.innerHTML = '<div class="home-rec-empty" style="min-height:0;padding:1.5rem 1rem"><p>Complete the pre-test to see domain scores.</p></div>';
        return;
      }
      listEl.innerHTML = domainScores.map(function (d, i) {
        var score    = Math.round(Number(d && d.score) || 0);
        var isPassing = score >= 80;
        var hasScore  = score > 0;
        var color    = DOMAIN_COLORS[d.domain] || '#60a5fa';
        var pct      = Math.min(score, 100);
        var shortName = DOMAIN_SHORT[d.domain] || (d.domain || 'Domain').replace(' Ability', '');
        var statusCls = isPassing ? 'home-perf-row-score--pass' : (hasScore ? 'home-perf-row-score--gap' : 'home-perf-row-score--none');
        return '<div class="home-perf-row" data-domain-index="' + i + '" role="button" tabindex="0" aria-label="' + esc(shortName) + ' ' + score + '%">' +
          '<span class="home-perf-row-name">' + esc(shortName) + '</span>' +
          '<div class="home-perf-bar-track">' +
            '<div class="home-perf-bar-fill" style="width:' + pct + '%;background-color:' + color + '"></div>' +
            '<div class="home-perf-bar-target" aria-hidden="true"></div>' +
          '</div>' +
          '<span class="home-perf-row-score ' + statusCls + '">' + (hasScore ? score + '%' : '—') + '</span>' +
        '</div>';
      }).join('');

      listEl.querySelectorAll('.home-perf-row').forEach(function (row) {
        function activate() {
          var di = Number(row.getAttribute('data-domain-index'));
          updateDomainInsight(domainScores, di, overallScore);
        }
        row.addEventListener('click', activate);
        row.addEventListener('keydown', function (e) { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); activate(); } });
      });
    }

    /* ─── Chart.js: compact interactive radar profile ─── */
    var domainChart = null;
    function buildDomainChart(rawScores, reduceMotion, overallScore) {
      var wrap = document.getElementById('home-domain-chart-wrap');
      if (!wrap) return;

      /* Merge API scores with canonical 4 domains so all 4 always appear in the chart */
      var scoreMap = {};
      if (rawScores && rawScores.length) {
        rawScores.forEach(function (d) { if (d.domain) scoreMap[d.domain] = d; });
      }
      var domainScores = CANONICAL_DOMAINS.map(function (name) {
        return scoreMap[name] || { domain: name, score: 0 };
      });
      /* Append any extra domains returned by the API (e.g. Clerical) */
      if (rawScores && rawScores.length) {
        rawScores.forEach(function (d) {
          if (d.domain && CANONICAL_DOMAINS.indexOf(d.domain) === -1) domainScores.push(d);
        });
      }

      var canvas = document.getElementById('home-domain-chart');
      if (!canvas) {
        wrap.innerHTML = '<canvas id="home-domain-chart" aria-label="Domain score radar chart"></canvas>';
        canvas = document.getElementById('home-domain-chart');
      }
      if (!canvas) return;

      var isDark    = document.documentElement.getAttribute('data-theme') === 'dark';
      var labels    = domainScores.map(function (d) {
        return DOMAIN_SHORT[d.domain] || (d.domain || '').replace(' Ability', '');
      });
      var scores    = domainScores.map(function (d) {
        var n = Number(d && d.score);
        return Number.isFinite(n) ? Math.round(n) : 0;
      });
      var colors    = domainScores.map(function (d) { return DOMAIN_COLORS[d.domain] || '#60a5fa'; });

      var gridColor  = isDark ? 'rgba(255,255,255,0.10)' : 'rgba(30,64,175,0.12)';
      var tickColor  = isDark ? '#7A93B5' : '#3A5274';
      var tooltipBg  = isDark ? '#1F2E47' : '#0F172A';

      var weakestIndex = scores.reduce(function (minI, s, i) {
        return s < scores[minI] ? i : minI;
      }, 0);

      if (domainChart) { domainChart.destroy(); domainChart = null; }
      try {
        domainChart = new Chart(canvas, {
          type: 'radar',
          data: {
            labels: labels,
            datasets: [
              {
                label: 'Your score',
                data: scores,
                backgroundColor: isDark ? 'rgba(96,165,250,0.22)' : 'rgba(37,99,235,0.18)',
                borderColor: isDark ? '#60a5fa' : '#2563eb',
                pointBackgroundColor: colors,
                pointBorderColor: '#ffffff',
                pointBorderWidth: 2,
                pointRadius: 6,
                pointHoverRadius: 8,
                borderWidth: 2.5,
                fill: true,
              },
              {
                label: 'Pass target',
                data: labels.map(function () { return 80; }),
                backgroundColor: 'rgba(245,166,35,0.08)',
                borderColor: '#F5A623',
                borderDash: [6, 4],
                pointRadius: 0,
                borderWidth: 2,
                fill: false,
              }
            ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            animation: { duration: reduceMotion ? 0 : 650, easing: 'easeOutCubic' },
            layout: { padding: 8 },
            elements: { line: { tension: 0.15 } },
            onHover: function (event, elements) {
              if (event && event.native && event.native.target)
                event.native.target.style.cursor = elements && elements.length ? 'pointer' : 'default';
            },
            onClick: function (_, elements) {
              if (elements && elements.length)
                updateDomainInsight(domainScores, elements[0].index, overallScore);
            },
            scales: {
              r: {
                min: 0, max: 100,
                angleLines: { color: gridColor, lineWidth: 1 },
                grid: { color: gridColor, circular: false, lineWidth: 1 },
                pointLabels: { 
                  color: tickColor, 
                  font: { size: 11, weight: '700', family: "'Inter',sans-serif" },
                  padding: 8
                },
                ticks: { 
                  color: tickColor, 
                  backdropColor: 'transparent', 
                  showLabelBackdrop: false, 
                  stepSize: 20, 
                  font: { size: 9, weight: '600' }
                }
              }
            },
            plugins: {
              legend: { display: false },
              tooltip: {
                backgroundColor: tooltipBg,
                titleColor: '#fff',
                bodyColor: 'rgba(255,255,255,0.9)',
                padding: 12, 
                cornerRadius: 8,
                titleFont: { size: 13, weight: '600' },
                bodyFont: { size: 12 },
                callbacks: {
                  title: function (items) {
                    var i = items[0].dataIndex;
                    return (domainScores[i].domain || '').replace(' Ability', '');
                  },
                  label: function (ctx) {
                    if (ctx.datasetIndex === 1) return ' Pass target: 80%';
                    var s = (ctx.parsed && typeof ctx.parsed.r === 'number') ? ctx.parsed.r : Number(ctx.raw);
                    var gap = 80 - s;
                    return ' ' + s + '% — ' + (gap <= 0 ? 'passing ✓' : gap + ' pts to 80%');
                  }
                }
              }
            }
          }
        });
      } catch (e) {
        console.error('Home radar chart:', e);
        wrap.innerHTML = '<p class="home-chart-empty">Chart could not be drawn. Try refreshing the page.</p>';
        if (pillsEl) pillsEl.innerHTML = '';
        return;
      }

      /* Build domain progress-bar list */
      buildDomainList(domainScores, overallScore);

      /* Default: highlight weakest domain */
      updateDomainInsight(domainScores, weakestIndex, overallScore);
    }

    /* ─── Main init ─── */
    async function initHomeDashboard() {
      var errEl = document.getElementById('home-load-error');
      if (errEl) errEl.hidden = true;

      appendBroadcast();

      var reduceMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      var d;
      try {
        var r = await fetch('/reviewee/api/dashboard');
        if (!r.ok) throw new Error('bad');
        d = await r.json();
      } catch (_) {
        if (errEl) errEl.hidden = false;
        return;
      }

      /* Greeting */
      var eyeEl  = document.getElementById('home-greeting-eyebrow');
      var nameEl = document.getElementById('home-greeting-name');
      if (d.user) {
        var h = new Date().getHours();
        if (eyeEl)  eyeEl.textContent  = h < 12 ? 'Good morning' : h < 18 ? 'Good afternoon' : 'Good evening';
        if (nameEl) nameEl.textContent = d.user.firstName + ' ' + d.user.lastName;
      }

      /* Pretest callout + primary CTA */
      var banner = document.getElementById('pretest-banner');
      var btnEl = document.getElementById('btn-continue');
      if (!d.pretestComplete) {
        if (banner) banner.removeAttribute('hidden');
        if (btnEl) btnEl.style.display = 'none';
      } else {
        if (banner) banner.setAttribute('hidden', '');
        if (btnEl) {
          btnEl.style.display = '';
          btnEl.innerHTML = '<span class="material-symbols-outlined" aria-hidden="true">play_circle</span> Continue Studying';
          btnEl.href = '/reviewee/review';
        }
      }

      /* Score + readiness badge */
      var scoreNumEl  = document.getElementById('home-score-num');
      var scoreBadge  = document.getElementById('home-score-badge');
      var gapNoteEl   = document.getElementById('home-gap-note');
      var pct = d.readinessScore || 0;

      if (d.pretestComplete) {
        if (scoreNumEl) scoreNumEl.textContent = (pct || 0);
        var statReadinessEl = document.getElementById('home-stat-readiness');
        if (statReadinessEl) statReadinessEl.textContent = (pct || 0);
 {
          if (reduceMotion) {
            scoreNumEl.textContent = String(pct);
          } else {
            var cur = 0;
            var step = function () {
              cur = Math.min(cur + Math.ceil((pct - cur) / 8 + 1), pct);
              scoreNumEl.textContent = String(cur);
              if (cur < pct) requestAnimationFrame(step);
            };
            requestAnimationFrame(step);
          }
        }
        if (scoreBadge) {
          scoreBadge.removeAttribute('hidden');
          var gap = 80 - pct;
          if (gap <= 0) {
            scoreBadge.textContent = 'Passing';
            scoreBadge.className = 'home-score-badge home-score-badge--pass';
          } else {
            scoreBadge.textContent = gap + ' pts to pass';
            scoreBadge.className = 'home-score-badge home-score-badge--gap';
          }
          if (gapNoteEl) {
            gapNoteEl.textContent = gap <= 0
              ? 'You\'ve reached the passing threshold.'
              : 'You need ' + gap + ' more points to reach the 80% pass mark.';
          }
        }
      }

      /* Domain chart */
      var rawDomain = (d.diagnostic && Array.isArray(d.diagnostic.domainScores)) ? d.diagnostic.domainScores : [];
      var hasDomainScores = rawDomain.some(function (x) { return Number(x && x.score) > 0; });
      var domainScores = rawDomain.length && (d.pretestComplete || hasDomainScores) ? rawDomain : null;
      buildDomainChart(domainScores, reduceMotion, d.readinessScore || 0);

      /* Stat tiles */
      var sesEl  = document.getElementById('home-session-count');
      var strEl  = document.getElementById('home-streak');
      var daysEl = document.getElementById('home-days-left');
      var dateEl = document.getElementById('home-exam-date-label');

      var qEl   = document.getElementById('home-questions-count');

      if (sesEl) sesEl.textContent = String(d.sessionCount    || 0);
      if (strEl) strEl.textContent = String(d.streak          || 0);
      if (qEl)   qEl.textContent   = String(d.totalQuestions  || 0);

      if (d.examDate) {
        var exam = parseLocalDateOnly(d.examDate);
        if (exam) {
          var today = new Date();
          today.setHours(0, 0, 0, 0);
          var days = Math.max(0, Math.ceil((exam - today) / 86400000));
          if (daysEl) {
            daysEl.textContent = String(days);
            daysEl.classList.toggle('home-stat-value--urgent', days <= 14);
          }
          if (dateEl) {
            dateEl.textContent = exam.toLocaleDateString('en-PH', { month: 'short', day: 'numeric', year: 'numeric' });
            dateEl.removeAttribute('hidden');
          }
        } else {
          if (daysEl) {
            daysEl.textContent = '—';
            daysEl.classList.remove('home-stat-value--urgent');
          }
          if (dateEl) {
            dateEl.textContent = '';
            dateEl.setAttribute('hidden', '');
          }
        }
      } else if (daysEl) {
        daysEl.textContent = '—';
        daysEl.classList.remove('home-stat-value--urgent');
        if (dateEl) {
          dateEl.textContent = '';
          dateEl.setAttribute('hidden', '');
        }
      }

      /* Recommendations */
      var listEl = document.getElementById('home-rec-list');
      var subEl  = document.getElementById('home-rec-sub');
      var mats   = d.recommendedMaterials || [];

      if (listEl && mats.length) {
        var ICON = { 'Lesson Module': 'school', 'Practice Set': 'quiz', 'Mock Exam': 'assignment', 'Reference Sheet': 'article' };
        listEl.innerHTML = mats.map(function (m) {
          var dom  = (m.domain || '').replace(' Ability', '');
          var type = m.type || 'Material';
          var icon = ICON[m.type] || 'description';
          var dc   = domClass(m.domain);
          var dur  = m.estMinutes ? '<span class="home-mat-dur"><span class="material-symbols-outlined" aria-hidden="true">schedule</span>' + esc(m.estMinutes) + '\u202fmin</span>' : '';
          return '<a href="/reviewee/materials" class="home-mat-card" title="' + esc(m.title || 'Untitled') + '">' +
            '<div class="home-mat-cover home-mat-cover--' + dc + '">' +
              '<span class="material-symbols-outlined home-mat-icon" aria-hidden="true">' + esc(icon) + '</span>' +
            '</div>' +
            '<div class="home-mat-body">' +
              '<span class="home-mat-type">' + esc(type) + '</span>' +
              '<p class="home-mat-title">' + esc(m.title || 'Untitled') + '</p>' +
              '<div class="home-mat-meta">' +
                '<span class="q-domain-badge ' + dc + '">' + esc(dom) + '</span>' +
                dur +
              '</div>' +
            '</div>' +
          '</a>';
        }).join('');
      } else if (listEl && d.pretestComplete) {
        listEl.innerHTML = '<div class="home-mat-empty"><span class="material-symbols-outlined" aria-hidden="true">search_off</span><p>No materials found. Browse the library.</p></div>';
      }

      /* Today's Focus */
      var focusEl = document.getElementById('home-focus-content');
      if (focusEl && d.todayFocus) {
        var focus     = d.todayFocus;
        var focusDom  = (focus.domain || '').replace(' Ability', '');
        var focusDc   = domClass(focus.domain);
        var focusMins = esc(focus.est_minutes || 30);
        
        focusEl.innerHTML =
          '<div class="home-focus-split">' +
            '<div class="home-focus-main">' +
              '<div class="home-focus-meta">' +
                '<span class="q-domain-badge ' + focusDc + '">' + esc(focusDom) + '</span>' +
                '<span class="home-focus-dur"><span class="material-symbols-outlined" aria-hidden="true">schedule</span>' + focusMins + '\u202fmin</span>' +
              '</div>' +
              '<h3 class="home-focus-title">' + esc(focus.focus_label || 'Study Session') + '</h3>' +
              '<p class="home-focus-desc">Today\'s recommended session focuses on strengthening your performance in ' + esc(focusDom) + '.</p>' +
            '</div>' +
            '<div class="home-focus-actions">' +
              '<a href="/reviewee/review" class="home-btn home-btn--primary home-focus-cta">' +
                '<span class="material-symbols-outlined" aria-hidden="true">play_circle</span>' +
                'Start Session' +
              '</a>' +
            '</div>' +
          '</div>' +
          '<div class="home-focus-footer">' +
            '<a href="/reviewee/study-plan" class="home-focus-plan-link">' +
              '<span class="material-symbols-outlined">calendar_month</span>' +
              'View full week study plan' +
              '<span class="material-symbols-outlined">chevron_right</span>' +
            '</a>' +
          '</div>';
      } else if (focusEl && d.pretestComplete) {
        focusEl.innerHTML =
          '<div class="home-focus-empty">' +
            '<span class="material-symbols-outlined" aria-hidden="true">event_busy</span>' +
            '<p>No focus tasks scheduled for today.</p>' +
            '<a href="/reviewee/study-plan" class="home-focus-plan-link" style="margin-top:0.75rem">Check study plan</a>' +
          '</div>';
      }

    }

    initHomeDashboard();
    var retryBtn = document.getElementById('home-retry-btn');
    if (retryBtn) retryBtn.addEventListener('click', initHomeDashboard);

  })();
  </script>

  <%- include('../partials/enrollment-code-modal') %>
  <script src="/js/toast-notifications.js"></script>
</body>
</html>
