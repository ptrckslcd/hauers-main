<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Study Plan | Hauers</title>
  <link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <script src="/js/theme-toggle.js"></script>
</head>
<body data-role="reviewee">

  <div id="navbar-placeholder"><%- include('../partials/navbar') %></div>

  <div class="app-shell">
    <div class="sidebar-overlay" id="sidebar-overlay"></div>
    <div id="sidebar-placeholder"><%- include('../partials/sidebar') %></div>

    <main class="page-content">

      <header class="page-header">
        <h1 class="page-title">Study Plan</h1>
      </header>

      <!-- Row 1: Overview + Current phase -->
      <div class="pgx-grid-2">
        <div class="dash-card spx-card-overview">
          <p class="pgx-section-label">Plan Overview</p>

          <div class="spx-exam-block">
            <div>
              <span class="spx-k">Target exam date</span>
              <p class="spx-exam-date" id="spx-exam-date">—</p>
            </div>
            <a href="#spx-roadmap" class="spx-profile-link spx-timeline-btn">
              <span class="material-symbols-outlined" style="font-size:16px">account_tree</span>
              Preparation timeline
            </a>
          </div>

          <div class="spx-metrics">
            <div class="spx-metric">
              <span class="spx-metric-n" id="spx-weeks-rem">—</span>
              <span class="spx-metric-l">Weeks remaining</span>
            </div>
            <div class="spx-metric-div"></div>
            <div class="spx-metric">
              <span class="spx-metric-n" id="spx-cur-week">—</span>
              <span class="spx-metric-l">Current week</span>
            </div>
            <div class="spx-metric-div"></div>
            <div class="spx-metric">
              <span class="spx-metric-n" id="spx-total-weeks">—</span>
              <span class="spx-metric-l">Total weeks</span>
            </div>
          </div>

          <div class="spx-sessions-progress">
            <div class="spx-sessions-head">
              <span class="spx-sessions-title">Weekly session goal</span>
              <span class="spx-sessions-frac" id="spx-sessions-frac">—</span>
            </div>
            <div class="spx-sessions-track">
              <div class="spx-sessions-fill" id="spx-sessions-fill" style="width:0%"></div>
            </div>
          </div>
        </div>

        <div class="dash-card spx-card-phase-now">
          <p class="pgx-section-label">Your phase</p>
          <div class="spx-phase-now-inner" id="spx-phase-now">
            <span class="spx-phase-now-badge" id="spx-phase-badge">—</span>
            <h2 class="spx-phase-now-title" id="spx-phase-title">—</h2>
            <p class="spx-phase-now-sub" id="spx-phase-weeks">—</p>
          </div>
          <ul class="spx-phase-now-bullets" id="spx-phase-bullets"></ul>
        </div>
      </div>

      <!-- Weekly schedule -->
      <div class="dash-card spx-card-week">
        <div class="spx-week-head">
          <p class="pgx-section-label pgx-section-label--flush">Weekly schedule</p>
          <span class="spx-week-range" id="spx-week-range"></span>
        </div>
        <div class="pgx-chart-shell spx-week-shell">
          <div class="spx-week-grid" id="spx-week-grid"></div>
        </div>
        <div class="spx-start-row">
          <a href="#" class="spx-start-primary" id="spx-start-today" hidden>
            <span class="material-symbols-outlined" style="font-size:18px">play_circle</span>
            Start today's session
          </a>
          <p class="spx-start-hint" id="spx-start-hint" hidden></p>
        </div>
      </div>

      <!-- Phases + log -->
      <div class="pgx-grid-2 spx-bottom-grid">
        <div class="dash-card spx-card-roadmap">
          <p class="pgx-section-label pgx-section-label--flush">Preparation timeline</p>
          <div class="spx-roadmap" id="spx-roadmap"></div>
        </div>
        <div class="dash-card spx-card-log">
          <p class="pgx-section-label pgx-section-label--flush">Plan adjustment log</p>
          <div class="spx-log-list" id="spx-log-list"></div>
        </div>
      </div>

    </main>
  </div>

  <script src="/js/app-shell.js"></script>
  <script>
  (function () {
    const DOMAIN_SLUG = {
      'Verbal Ability':      'verbal',
      'Numerical Ability':   'numerical',
      'Analytical Ability':  'analytical',
      'Clerical Ability':    'clerical',
      'General Information': 'general',
    };
    const DOMAIN_SHORT = {
      'Verbal Ability':      'Verbal',
      'Numerical Ability':   'Numerical',
      'Analytical Ability':  'Analytical',
      'Clerical Ability':    'Clerical',
      'General Information': 'Gen. Info',
    };

    function fmtRange(daily) {
      if (!daily?.length) return '';
      const a = daily[0].date;
      const b = daily[daily.length - 1].date;
      const fa = new Date(a + 'T12:00:00').toLocaleDateString('en-PH', { month: 'short', day: 'numeric' });
      const fb = new Date(b + 'T12:00:00').toLocaleDateString('en-PH', { month: 'short', day: 'numeric', year: 'numeric' });
      return fa + ' – ' + fb;
    }

    function renderWeekGrid(daily, todayIso, diagOk) {
      const el = document.getElementById('spx-week-grid');
      el.innerHTML = daily.map(d => {
        const isToday = d.date === todayIso;
        const slug = DOMAIN_SLUG[d.domain] || 'general';
        const done = d.completed;
        const cls = ['spx-day', isToday ? 'spx-day--today' : '', done ? 'spx-day--done' : ''].filter(Boolean).join(' ');
        return `
          <div class="${cls}">
            <div class="spx-day-top">
              <span class="spx-day-name">${d.day}</span>
              <span class="spx-day-date">${d.date.slice(5).replace('-', '/')}</span>
            </div>
            <span class="q-domain-badge ${slug} spx-day-badge">${DOMAIN_SHORT[d.domain] || d.domain}</span>
            <p class="spx-day-meta">~${d.estMinutes} min session</p>
            ${done
              ? '<span class="spx-done-badge"><span class="material-symbols-outlined" style="font-size:13px">check</span> Completed</span>'
              : '<span class="spx-pending-label">Scheduled</span>'}
          </div>`;
      }).join('');

      const startA = document.getElementById('spx-start-today');
      const hint = document.getElementById('spx-start-hint');
      const todayRow = daily.find(d => d.date === todayIso);
      if (!diagOk) {
        startA.hidden = true;
        hint.hidden = false;
        hint.textContent = 'Complete the diagnostic to unlock focused practice from your study plan.';
        return;
      }
      if (todayRow && !todayRow.completed) {
        const u = '/reviewee/review?domain=' + encodeURIComponent(todayRow.domain) + '&start=1';
        startA.href = u;
        startA.removeAttribute('hidden');
        hint.hidden = true;
      } else if (todayRow && todayRow.completed) {
        startA.hidden = true;
        hint.hidden = false;
        hint.textContent = "Today's scheduled session is already complete. Nice work.";
      } else {
        startA.hidden = true;
        hint.hidden = true;
      }
    }

    function renderRoadmap(phases, currentIdx) {
      document.getElementById('spx-roadmap').innerHTML = phases.map((p, i) => {
        const state = p.done ? 'done' : p.current ? 'current' : '';
        return `
          <div class="spx-rm-step spx-rm-step--${state || 'upcoming'}">
            <div class="spx-rm-rail">
              <div class="spx-rm-dot">${p.done ? '<span class="material-symbols-outlined" style="font-size:14px">check</span>' : i + 1}</div>
              ${i < phases.length - 1 ? '<div class="spx-rm-line"></div>' : ''}
            </div>
            <div class="spx-rm-body">
              <div class="spx-rm-head">
                <span class="spx-rm-title">${p.title}</span>
                ${p.current ? '<span class="spx-rm-you">You are here</span>' : ''}
              </div>
              <p class="spx-rm-weeks">${p.weeks}</p>
              <ul class="spx-rm-items">${p.items.map(x => `<li>${x}</li>`).join('')}</ul>
            </div>
          </div>`;
      }).join('');
    }

    function renderLog(entries) {
      document.getElementById('spx-log-list').innerHTML = entries.map(e => `
        <div class="spx-log-item${e.isInfo ? ' spx-log-item--info' : ''}">
          <span class="spx-log-date">${e.date}</span>
          <p class="spx-log-msg">${e.message}</p>
        </div>`).join('');
    }

    function todayLocalKey() {
      const n = new Date();
      const y = n.getFullYear();
      const m = String(n.getMonth() + 1).padStart(2, '0');
      const d = String(n.getDate()).padStart(2, '0');
      return `${y}-${m}-${d}`;
    }

    Promise.all([
      fetch('/reviewee/api/study-plan').then(r => r.ok ? r.json() : Promise.reject()),
      fetch('/reviewee/api/dashboard').then(r => r.ok ? r.json() : {}).catch(() => ({})),
    ]).then(([sp, dash]) => {
      const todayIso = todayLocalKey();
      const diagOk = !!dash.pretestComplete;

      document.getElementById('spx-exam-date').textContent =
        sp.examDateDisplay || 'Not set — add a target date in your learner profile.';
      document.getElementById('spx-weeks-rem').textContent = sp.weeksRemaining ?? '—';
      document.getElementById('spx-cur-week').textContent  = sp.currentWeek ?? '—';
      document.getElementById('spx-total-weeks').textContent = sp.totalWeeks ?? '—';

      const wg = sp.weeklySessions || { completed: 0, target: 1 };
      const tgt = Math.max(1, wg.target);
      const done = Math.min(wg.completed || 0, tgt);
      document.getElementById('spx-sessions-frac').textContent =
        `${done} of ${tgt} sessions this week`;
      setTimeout(() => {
        document.getElementById('spx-sessions-fill').style.width =
          Math.round((done / tgt) * 100) + '%';
      }, 120);

      const phases = sp.phases || [];
      const idx = sp.currentPhaseIndex ?? 0;
      const cur = phases[idx];
      if (cur) {
        document.getElementById('spx-phase-badge').textContent = cur.label;
        document.getElementById('spx-phase-title').textContent = cur.title;
        document.getElementById('spx-phase-weeks').textContent = cur.weeks;
        document.getElementById('spx-phase-bullets').innerHTML =
          cur.items.map(t => `<li>${t}</li>`).join('');
      }

      document.getElementById('spx-week-range').textContent = fmtRange(sp.dailySchedule);
      renderWeekGrid(sp.dailySchedule || [], todayIso, diagOk);
      renderRoadmap(phases, idx);
      renderLog(sp.adjustments || []);

      // Smooth scroll for timeline link
      document.querySelector('.spx-timeline-btn')?.addEventListener('click', e => {
        e.preventDefault();
        const target = document.getElementById('spx-roadmap');
        if (target) {
          window.scrollTo({
            top: target.offsetTop - 100, // accounting for navbar
            behavior: 'smooth'
          });
        }
      });
    }).catch(err => console.error('[study-plan]', err));
  })();
  </script>

  <%- include('../partials/enrollment-code-modal') %>
  <script src="/js/toast-notifications.js"></script>
</body>
</html>
