<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Settings | Hauers</title>
  <link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <script src="/js/theme-toggle.js"></script>
</head>
<body data-role="reviewee">

  <div id="navbar-placeholder"><%- include('../partials/navbar') %></div>

  <div class="app-shell">
    <div class="sidebar-overlay" id="sidebar-overlay"></div>
    <div id="sidebar-placeholder"><%- include('../partials/sidebar') %></div>

    <main class="page-content">

      <header class="page-header">
        <h1 class="page-title">Settings</h1>
      </header>

      <!-- Preferences (full-width) -->
      <div class="dash-card st-card">
        <p class="pgx-section-label">Preferences</p>
        <div class="st-pref-list">

          <div class="st-pref-row">
            <div class="st-pref-info">
              <strong>Dark Mode</strong>
              <span>Switch between light and dark theme</span>
            </div>
            <label class="st-toggle" aria-label="Toggle dark mode">
              <input type="checkbox" id="st-dark-toggle">
              <span class="st-toggle-track"></span>
            </label>
          </div>

          <div class="st-pref-row">
            <div class="st-pref-info">
              <strong>Study Reminders</strong>
              <span>Daily reminders to keep your streak going</span>
            </div>
            <label class="st-toggle" aria-label="Toggle study reminders">
              <input type="checkbox" id="st-reminders-toggle" checked>
              <span class="st-toggle-track"></span>
            </label>
          </div>

          <div class="st-pref-row">
            <div class="st-pref-info">
              <strong>Email Notifications</strong>
              <span>Receive weekly progress reports via email</span>
            </div>
            <label class="st-toggle" aria-label="Toggle email notifications">
              <input type="checkbox" id="st-email-notif-toggle" checked>
              <span class="st-toggle-track"></span>
            </label>
          </div>

          <div class="st-pref-row st-pref-row--last">
            <div class="st-pref-info">
              <strong>Show Exam Countdown</strong>
              <span>Display days remaining on the sidebar</span>
            </div>
            <label class="st-toggle" aria-label="Toggle exam countdown">
              <input type="checkbox" id="st-countdown-toggle" checked>
              <span class="st-toggle-track"></span>
            </label>
          </div>

        </div>
      </div>

      <!-- Row 2: Change Password + Privacy & Data side-by-side -->
      <div class="pgx-grid-2" style="align-items:stretch">

        <!-- Change Password -->
        <div class="dash-card st-card">
          <p class="pgx-section-label">Change Password</p>
          <div class="st-alert" id="st-pw-alert"></div>
          <form id="st-pw-form" class="st-form" novalidate>
            <div class="st-form-group">
              <label for="st-current-pw">Current Password</label>
              <div class="st-pw-wrap">
                <input type="password" id="st-current-pw" name="currentPassword" placeholder="Current password" autocomplete="current-password">
                <button type="button" class="st-pw-eye" data-target="st-current-pw" aria-label="Show/hide">
                  <span class="material-symbols-outlined eye-off">visibility_off</span>
                  <span class="material-symbols-outlined eye-on" style="display:none">visibility</span>
                </button>
              </div>
            </div>
            <div class="st-form-group">
              <label for="st-new-pw">New Password</label>
              <div class="st-pw-wrap">
                <input type="password" id="st-new-pw" name="newPassword" placeholder="New password" autocomplete="new-password">
                <button type="button" class="st-pw-eye" data-target="st-new-pw" aria-label="Show/hide">
                  <span class="material-symbols-outlined eye-off">visibility_off</span>
                  <span class="material-symbols-outlined eye-on" style="display:none">visibility</span>
                </button>
              </div>
              <div class="st-pw-strength" id="st-pw-strength"></div>
            </div>
            <div class="st-form-group">
              <label for="st-confirm-pw">Confirm New Password</label>
              <div class="st-pw-wrap">
                <input type="password" id="st-confirm-pw" name="confirmPassword" placeholder="Confirm password" autocomplete="new-password">
                <button type="button" class="st-pw-eye" data-target="st-confirm-pw" aria-label="Show/hide">
                  <span class="material-symbols-outlined eye-off">visibility_off</span>
                  <span class="material-symbols-outlined eye-on" style="display:none">visibility</span>
                </button>
              </div>
            </div>
            <div class="st-form-actions">
              <button type="submit" class="cta-pill" id="st-pw-btn">Update Password</button>
            </div>
          </form>
        </div>

        <!-- Privacy & Data -->
        <div class="dash-card st-card">
          <p class="pgx-section-label">Privacy &amp; Data</p>

          <div class="st-info-grid">
            <span class="st-info-lbl">Enrolled Batch</span>
            <span class="st-info-val" id="st-priv-batch">—</span>
            <span class="st-info-lbl">Account Email</span>
            <span class="st-info-val" id="st-priv-email">—</span>
          </div>

          <div class="st-notice" style="margin-top:1rem">
            <span class="material-symbols-outlined st-notice-ic">info</span>
            <p>Hauers collects your quiz answers, self-ratings, and session activity to personalise study recommendations. Data is stored securely and never shared with third parties. Review our
              <a href="/privacy" target="_blank" rel="noopener" class="st-legal-link">Privacy Policy</a>
              and
              <a href="/terms" target="_blank" rel="noopener" class="st-legal-link">Terms of Service</a>.
            </p>
          </div>

          <div class="st-priv-danger">
            <div class="st-priv-danger-info">
              <strong>Request Data Deletion</strong>
              <p>Submits a deletion request to the admin. Your account stays active until the request is reviewed.</p>
            </div>
            <div id="st-del-alert"></div>
            <button type="button" class="st-danger-btn" id="st-del-btn">Request Deletion</button>
          </div>
        </div>

      </div><!-- /.pgx-grid-2 -->

    </main>
  </div>

  <script src="/js/app-shell.js"></script>
  <script>
  /* ── Load user data ── */
  (async () => {
    try {
      const res = await fetch('/reviewee/api/profile');
      if (!res.ok) return;
      const data = await res.json();
      const u = data.user || {};
      const privBatch = document.getElementById('st-priv-batch');
      const privEmail = document.getElementById('st-priv-email');
      if (privBatch) privBatch.textContent = data.batchName || 'Not enrolled';
      if (privEmail) privEmail.textContent = u.email || '—';
    } catch (_) {}
  })();

  /* ── Password eye toggle ── */
  document.querySelectorAll('.st-pw-eye').forEach(btn => {
    btn.addEventListener('click', () => {
      const inp     = document.getElementById(btn.dataset.target);
      const visible = inp.type === 'text';
      inp.type = visible ? 'password' : 'text';
      btn.querySelector('.eye-off').style.display = visible ? ''     : 'none';
      btn.querySelector('.eye-on').style.display  = visible ? 'none' : '';
    });
  });

  /* ── Password strength ── */
  document.getElementById('st-new-pw').addEventListener('input', function () {
    const v  = this.value;
    const el = document.getElementById('st-pw-strength');
    if (!v) { el.innerHTML = ''; return; }
    let s = 0;
    if (v.length >= 6)          s++;
    if (/[A-Z]/.test(v))        s++;
    if (/[0-9]/.test(v))        s++;
    if (/[^A-Za-z0-9]/.test(v)) s++;
    const cls   = ['', 'st-str-weak', 'st-str-fair', 'st-str-good', 'st-str-strong'][s];
    const label = ['', 'Weak',        'Fair',         'Good',        'Strong'       ][s];
    el.innerHTML =
      `<div class="st-str-bar ${cls}"><span></span><span></span><span></span><span></span></div>` +
      `<span class="st-str-label ${cls}">${label}</span>`;
  });

  /* ── Alert helper ── */
  function showAlert(id, type, msg) {
    const el = document.getElementById(id);
    if (!el) return;
    el.className = 'st-alert st-alert--' + type;
    el.textContent = msg;
    el.style.display = 'flex';
    clearTimeout(el._t);
    el._t = setTimeout(() => { el.style.display = 'none'; }, 5000);
  }

  /* ── Password form ── */
  document.getElementById('st-pw-form').addEventListener('submit', async e => {
    e.preventDefault();
    const btn = document.getElementById('st-pw-btn');
    btn.disabled = true; btn.textContent = 'Updating…';
    try {
      const r = await fetch('/reviewee/api/settings/password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          currentPassword: document.getElementById('st-current-pw').value,
          newPassword:     document.getElementById('st-new-pw').value,
          confirmPassword: document.getElementById('st-confirm-pw').value,
        }),
      });
      const data = await r.json();
      if (!r.ok) { showAlert('st-pw-alert', 'error', data.error); }
      else { document.getElementById('st-pw-form').reset(); document.getElementById('st-pw-strength').innerHTML = ''; showAlert('st-pw-alert', 'success', 'Password updated.'); }
    } catch (_) { showAlert('st-pw-alert', 'error', 'Something went wrong.'); }
    finally { btn.disabled = false; btn.textContent = 'Update Password'; }
  });

  /* ── Theme toggle ── */
  const darkToggle = document.getElementById('st-dark-toggle');
  darkToggle.checked = (localStorage.getItem('theme') || 'light') === 'dark';
  darkToggle.addEventListener('change', function () {
    const theme = this.checked ? 'dark' : 'light';
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('theme', theme);
  });

  /* ── Preference toggles ── */
  ['st-reminders-toggle', 'st-email-notif-toggle', 'st-countdown-toggle'].forEach(id => {
    const el = document.getElementById(id);
    if (!el) return;
    const stored = localStorage.getItem(id);
    if (stored !== null) el.checked = stored === 'true';
    el.addEventListener('change', function () { localStorage.setItem(id, this.checked); });
  });

  /* ── Data deletion ── */
  const delBtn = document.getElementById('st-del-btn');
  if (delBtn) {
    delBtn.addEventListener('click', async () => {
      if (!confirm('Send a data deletion request to the admin?\n\nYour account will stay active until reviewed.')) return;
      delBtn.disabled = true; delBtn.textContent = 'Submitting…';
      try {
        const r = await fetch('/reviewee/api/profile/request-deletion', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ reason: 'User-initiated from Settings' }),
        });
        const d = await r.json();
        const alEl = document.getElementById('st-del-alert');
        if (alEl) {
          alEl.className = r.ok ? 'st-alert st-alert--success' : 'st-alert st-alert--error';
          alEl.textContent = r.ok ? 'Request submitted. An admin will review it shortly.' : (d.error || 'Failed to submit request.');
          alEl.style.display = 'flex';
        }
        if (!r.ok) { delBtn.disabled = false; delBtn.textContent = 'Request Deletion'; }
      } catch { delBtn.disabled = false; delBtn.textContent = 'Request Deletion'; }
    });
  }
  </script>

</body>
</html>
