<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Learning Materials | Hauers</title>
  <link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <script src="/js/theme-toggle.js"></script>
</head>
<body data-role="reviewee">

  <div id="navbar-placeholder"><%- include('../partials/navbar') %></div>

  <div class="app-shell">
    <div class="sidebar-overlay" id="sidebar-overlay"></div>
    <div id="sidebar-placeholder"><%- include('../partials/sidebar') %></div>

    <main class="page-content">

      <header class="page-header">
        <h1 class="page-title">Learning Materials</h1>
      </header>

      <!-- 7.5.1 Recommended -->
      <div class="dash-card mlx-section">
        <div class="mlx-section-top">
          <p class="pgx-section-label pgx-section-label--flush">Recommended for you</p>
          <span class="mlx-rec-tag" id="mlx-rec-hint"></span>
        </div>
        <div class="pgx-chart-shell mlx-shell">
          <div class="mlx-grid mlx-grid--rec" id="mlx-rec-grid">
            <div class="mlx-loading">Loading recommendations…</div>
          </div>
        </div>
      </div>

      <!-- 7.5.2 Browse -->
      <div class="dash-card mlx-section mlx-browse">
        <div class="mlx-section-top">
          <p class="pgx-section-label pgx-section-label--flush">Browse all materials</p>
        </div>

        <div class="mlx-toolbar-compact">
          <label class="mlx-search mlx-search--flex">
            <span class="material-symbols-outlined mlx-search-ic" aria-hidden="true">search</span>
            <input type="search" id="mlx-search" class="mlx-search-input" placeholder="Search title or description" autocomplete="off" />
          </label>
          <div class="mlx-select-group" role="group" aria-label="Filters">
            <label class="mlx-field">
              <span class="mlx-field-lbl">Domain</span>
              <select id="mlx-sel-domain" class="mlx-select">
                <option value="all">All domains</option>
                <option value="Verbal Ability">Verbal</option>
                <option value="Numerical Ability">Numerical</option>
                <option value="Analytical Ability">Analytical</option>
                <option value="Clerical Ability">Clerical</option>
                <option value="General Information">General Info</option>
              </select>
            </label>
            <label class="mlx-field">
              <span class="mlx-field-lbl">Type</span>
              <select id="mlx-sel-type" class="mlx-select">
                <option value="all">All types</option>
                <option value="lesson_module">Lesson Module</option>
                <option value="practice_set">Practice Set</option>
                <option value="mock_exam">Mock Exam</option>
                <option value="reference_sheet">Reference Sheet</option>
              </select>
            </label>
            <label class="mlx-field">
              <span class="mlx-field-lbl">Difficulty</span>
              <select id="mlx-sel-diff" class="mlx-select">
                <option value="all">All levels</option>
                <option value="basic">Basic</option>
                <option value="intermediate">Intermediate</option>
                <option value="advanced">Advanced</option>
              </select>
            </label>
          </div>
        </div>

        <p class="mlx-result-count" id="mlx-count" aria-live="polite"></p>
        <div class="mlx-grid" id="mlx-grid"></div>
      </div>

    </main>
  </div>

  <!-- 7.5.3 Viewer modal (placeholder viewer + timer) -->
  <div class="mlx-modal" id="mlx-modal" hidden>
    <div class="mlx-modal-backdrop" id="mlx-modal-bg"></div>
    <div class="mlx-modal-panel" role="dialog" aria-modal="true" aria-labelledby="mlx-modal-title">

      <div class="mlx-modal-head">
        <div class="mlx-modal-head-main">
          <p class="mlx-modal-eyebrow" id="mlx-modal-type"></p>
          <h2 class="mlx-modal-title" id="mlx-modal-title"></h2>
        </div>
        <div class="mlx-modal-head-actions">
          <div class="mlx-timer" id="mlx-timer" title="Time spent on this material">
            <span class="material-symbols-outlined mlx-timer-ic" aria-hidden="true">timer</span>
            <span class="mlx-timer-digits" id="mlx-timer-digits">00:00</span>
            <span class="mlx-timer-suggest" id="mlx-timer-suggest"></span>
          </div>
          <button type="button" class="mlx-modal-icon-btn" id="mlx-sum-toggle" aria-label="Toggle summary panel">
            <span class="material-symbols-outlined" id="mlx-sum-toggle-ic">dock_to_right</span>
          </button>
          <button type="button" class="mlx-modal-icon-btn" id="mlx-modal-fs" aria-label="Toggle full screen">
            <span class="material-symbols-outlined" id="mlx-fs-icon">open_in_full</span>
          </button>
          <button type="button" class="mlx-modal-icon-btn mlx-modal-icon-btn--close" id="mlx-modal-close" aria-label="Close">
            <span class="material-symbols-outlined">close</span>
          </button>
        </div>
      </div>

      <div class="mlx-modal-split" id="mlx-modal-split" data-sum-open="true">
        <div class="mlx-modal-maincol">
          <div class="mlx-placeholder-banner">
            <span class="material-symbols-outlined">construction</span>
            <span>Preview mode — full viewer coming soon</span>
          </div>
          <div class="mlx-modal-main" id="mlx-modal-main"></div>
        </div>

        <aside class="mlx-modal-summary" id="mlx-modal-summary" aria-label="Material summary">
          <p class="mlx-sum-label">Summary</p>
          <div class="mlx-sum-body" id="mlx-sum-body"></div>
        </aside>
      </div>

      <div class="mlx-modal-foot" id="mlx-modal-foot"></div>
    </div>
  </div>

  <script src="/js/app-shell.js"></script>
  <script>
  (async () => {
    const TYPE_ICONS = {
      'Lesson Module':    'school',
      'Practice Set':     'quiz',
      'Mock Exam':        'assignment',
      'Reference Sheet':  'article',
    };
    const DOMAIN_SLUG = {
      'Verbal Ability':      'verbal',
      'Numerical Ability':   'numerical',
      'Analytical Ability':  'analytical',
      'Clerical Ability':    'clerical',
      'General Information': 'general',
    };
    const COVER_MAP = {
      verbal:     'mlx-cover--verbal',
      numerical:  'mlx-cover--numerical',
      analytical: 'mlx-cover--analytical',
      clerical:   'mlx-cover--clerical',
      general:    'mlx-cover--general',
    };

    function slugDom(d) {
      return DOMAIN_SLUG[d] || 'general';
    }
    function fmtMins(m) {
      if (m == null) return '—';
      const n = Number(m);
      if (!n) return '—';
      if (n < 60) return `${n} min`;
      const h = Math.floor(n / 60);
      const r = n % 60;
      return r ? `${h}h ${r}m` : `${h}h`;
    }
    function escapeHtml(s) {
      const d = document.createElement('div');
      d.textContent = s;
      return d.innerHTML;
    }
    function isExternal(url) {
      return /^https?:\/\//i.test(url || '');
    }
    function isPdf(url) {
      return /\.pdf(\?|#|$)/i.test(url || '');
    }
    function resolveUrl(url) {
      if (!url) return '';
      if (isExternal(url)) return url;
      if (url.startsWith('/')) return url;
      return '/' + url;
    }

    let allMaterials = [];

    function diffCls(key) {
      const k = (key || '').toLowerCase();
      if (k === 'basic') return 'mlx-diff mlx-diff--basic';
      if (k === 'advanced') return 'mlx-diff mlx-diff--adv';
      return 'mlx-diff mlx-diff--mid';
    }

    function actionLabel(m) {
      if ((m.contentHtml || '').trim()) return 'Read';
      const url = (m.contentUrl || '').trim();
      if (!url) return 'View details';
      if (isExternal(url)) return 'Open link';
      if (isPdf(url) && m.typeKey === 'reference_sheet') return 'Download';
      if (isPdf(url)) return 'Open';
      return 'Start';
    }

    function catalogCard(m, recHighlight) {
      const slug = slugDom(m.domain);
      const cover = COVER_MAP[slug] || 'mlx-cover--general';
      const icon  = TYPE_ICONS[m.type] || 'menu_book';
      const rec   = recHighlight && m.isRecommended ? '<span class="mlx-rec-star" title="Recommended">★</span>' : '';
      return `
        <article class="mlx-card${recHighlight && m.isRecommended ? ' mlx-card--rec' : ''}" data-id="${m.id}">
          <div class="mlx-cover ${cover}">
            ${rec}
            <span class="material-symbols-outlined mlx-cover-ic">${icon}</span>
          </div>
          <div class="mlx-card-body">
            <span class="mlx-type-tag">${escapeHtml(m.type)}</span>
            <h3 class="mlx-card-title">${escapeHtml(m.title || 'Untitled')}</h3>
            <p class="mlx-card-desc">${escapeHtml((m.desc || '').slice(0, 140))}${(m.desc || '').length > 140 ? '…' : ''}</p>
            <div class="mlx-card-row">
              <span class="q-domain-badge ${slug} mlx-card-badge">${escapeHtml((m.domain || '').replace(' Ability', ''))}</span>
              <span class="${diffCls(m.difficultyKey)}">${escapeHtml(m.difficulty)}</span>
            </div>
            <div class="mlx-card-foot">
              <span class="mlx-time"><span class="material-symbols-outlined" style="font-size:14px">schedule</span> ${fmtMins(m.estMinutes)}</span>
              <button type="button" class="mlx-btn-primary mlx-open" data-id="${m.id}">${actionLabel(m)}</button>
            </div>
          </div>
        </article>`;
    }

    function bindOpen(root) {
      root.querySelectorAll('.mlx-open').forEach(btn => {
        btn.addEventListener('click', e => {
          e.stopPropagation();
          const id = Number(btn.dataset.id);
          const m = allMaterials.find(x => x.id === id);
          if (m) openMaterial(m);
        });
      });
    }

    let mlxTimerId = null;
    let mlxTimerStarted = 0;
    let mlxSuggestedSec = 25 * 60;

    function fmtTimerSecs(sec) {
      const m = Math.floor(sec / 60);
      const s = sec % 60;
      return `${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
    }

    function stopModalTimer() {
      if (mlxTimerId) {
        clearInterval(mlxTimerId);
        mlxTimerId = null;
      }
      const t = document.getElementById('mlx-timer');
      if (t) t.classList.remove('mlx-timer--over');
    }

    function startModalTimer(suggestedMins) {
      stopModalTimer();
      const mins = Number(suggestedMins);
      mlxSuggestedSec = Math.max(5, (Number.isFinite(mins) && mins > 0 ? mins : 25)) * 60;
      mlxTimerStarted = Date.now();
      const sugg = document.getElementById('mlx-timer-suggest');
      if (sugg) sugg.textContent = `Suggested \u2248 ${Math.round(mlxSuggestedSec / 60)} min`;
      const digits = document.getElementById('mlx-timer-digits');
      if (digits) digits.textContent = '00:00';
      mlxTimerId = setInterval(() => {
        const elapsed = Math.floor((Date.now() - mlxTimerStarted) / 1000);
        if (digits) digits.textContent = fmtTimerSecs(elapsed);
        const timerEl = document.getElementById('mlx-timer');
        if (timerEl) {
          if (elapsed >= mlxSuggestedSec) timerEl.classList.add('mlx-timer--over');
          else timerEl.classList.remove('mlx-timer--over');
        }
      }, 1000);
    }

    function openMaterial(m) {
      const modal = document.getElementById('mlx-modal');
      const url = (m.contentUrl || '').trim();
      const html = (m.contentHtml || '').trim();
      document.getElementById('mlx-modal-type').textContent = m.type;
      document.getElementById('mlx-modal-title').textContent = m.title || 'Material';

      startModalTimer(m.estMinutes);

      const descSnippet = (m.desc || '').trim();
      const descShow = descSnippet
        ? escapeHtml(descSnippet.slice(0, 320)) + (descSnippet.length > 320 ? '…' : '')
        : '<em class="mlx-ph-muted">No description on file yet.</em>';

      let bodyInner = '';
      if (html) {
        bodyInner = `<div class="mlx-prose mlx-inline-html">${html}</div>`;
      } else if (url && isPdf(url)) {
        const src = escapeHtml(isExternal(url) ? url : resolveUrl(url));
        bodyInner = `<iframe class="mlx-pdf-frame" src="${src}" title="PDF preview"></iframe>`;
      } else {
        bodyInner = `
        <div class="mlx-ph-content">
          <p class="mlx-ph-lead">Open the resource below or use the link in the footer when available.</p>
          <ul class="mlx-ph-list">
            <li>PDFs open in the viewer when linked from the library.</li>
            <li>Word documents open via download.</li>
            <li>Inline lessons appear in this column when authored by your coordinator.</li>
          </ul>
          <div class="mlx-ph-descwrap">
            <span class="mlx-ph-desclbl">Catalog description</span>
            <p class="mlx-ph-desc">${descShow}</p>
          </div>
        </div>`;
      }

      document.getElementById('mlx-modal-main').innerHTML = bodyInner;

      document.getElementById('mlx-sum-body').innerHTML = `
        <dl class="mlx-sum-dl">
          <dt>Type</dt><dd>${escapeHtml(m.type)}</dd>
          <dt>Domain</dt><dd>${escapeHtml((m.domain || '').replace(' Ability', ''))}</dd>
          <dt>Level</dt><dd>${escapeHtml(m.difficulty)}</dd>
          <dt>Time</dt><dd>${escapeHtml(fmtMins(m.estMinutes))}</dd>
        </dl>
        <div class="mlx-sum-box">
          <p class="mlx-sum-box-title">Objectives</p>
          <ul class="mlx-sum-ul">
            <li>Strengthen recall for this topic.</li>
            <li>Connect ideas to exam-style prompts.</li>
            <li>Flag areas to revisit in Review.</li>
          </ul>
        </div>
        <div class="mlx-sum-box">
          <p class="mlx-sum-box-title">Key points</p>
          <p class="mlx-sum-p">Short bullets and mnemonics will appear here once content is authored.</p>
        </div>`;

      const foot = document.getElementById('mlx-modal-foot');
      foot.innerHTML = '';
      if (url) {
        const href = escapeHtml(isExternal(url) ? url : resolveUrl(url));
        const isDoc = /\.(docx?)(\?|#|$)/i.test(url);
        const label = isDoc ? 'Download document' : (isPdf(url) ? 'Open PDF in new tab' : 'Open original resource');
        foot.innerHTML = `<a href="${href}" target="_blank" rel="noopener noreferrer" class="mlx-btn-secondary">${label}</a>`;
      }

      modal.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      stopModalTimer();
      const modal = document.getElementById('mlx-modal');
      modal.setAttribute('hidden', '');
      document.getElementById('mlx-modal-main').innerHTML = '';
      document.getElementById('mlx-sum-body').innerHTML = '';
      // Exit full-screen when closing
      const panel = document.querySelector('.mlx-modal-panel');
      if (panel.classList.contains('mlx-modal-panel--fs')) {
        panel.classList.remove('mlx-modal-panel--fs');
        modal.style.padding = '';
        const fsIcon = document.getElementById('mlx-fs-icon');
        if (fsIcon) fsIcon.textContent = 'open_in_full';
      }
      document.body.style.overflow = '';
    }
    document.getElementById('mlx-modal-close').addEventListener('click', closeModal);
    document.getElementById('mlx-modal-bg').addEventListener('click', closeModal);
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

    // Full-screen toggle
    document.getElementById('mlx-modal-fs').addEventListener('click', () => {
      const modal  = document.getElementById('mlx-modal');
      const panel  = document.querySelector('.mlx-modal-panel');
      const fsIcon = document.getElementById('mlx-fs-icon');
      const isFs   = panel.classList.toggle('mlx-modal-panel--fs');
      modal.style.padding = isFs ? '0' : '';
      fsIcon.textContent = isFs ? 'close_fullscreen' : 'open_in_full';
    });

    // Summary collapse toggle
    document.getElementById('mlx-sum-toggle').addEventListener('click', () => {
      const split    = document.getElementById('mlx-modal-split');
      const toggleIc = document.getElementById('mlx-sum-toggle-ic');
      const isOpen   = split.getAttribute('data-sum-open') !== 'false';
      split.setAttribute('data-sum-open', isOpen ? 'false' : 'true');
      toggleIc.textContent = isOpen ? 'dock_to_right' : 'dock_to_right';
      document.getElementById('mlx-sum-toggle').setAttribute('aria-pressed', isOpen ? 'false' : 'true');
    });

    let domFilter = 'all';
    let typeFilter = 'all';
    let diffFilter = 'all';
    let searchQ = '';

    function matches(m) {
      if (domFilter !== 'all' && m.domain !== domFilter) return false;
      if (typeFilter !== 'all' && m.typeKey !== typeFilter) return false;
      if (diffFilter !== 'all' && (m.difficultyKey || '').toLowerCase() !== diffFilter) return false;
      if (searchQ) {
        const t = (m.title + ' ' + (m.desc || '')).toLowerCase();
        if (!t.includes(searchQ)) return false;
      }
      return true;
    }

    function renderBrowse() {
      const grid = document.getElementById('mlx-grid');
      const filtered = allMaterials.filter(matches);
      const el = document.getElementById('mlx-count');
      if (!allMaterials.length) {
        grid.innerHTML = `<div class="mlx-empty">
          <span class="material-symbols-outlined">inventory_2</span>
          <p>No published materials for your exam level yet. Check back soon.</p>
        </div>`;
        el.textContent = '';
        return;
      }
      el.textContent = filtered.length === allMaterials.length
        ? `${filtered.length} materials`
        : `Showing ${filtered.length} of ${allMaterials.length}`;
      if (!filtered.length) {
        grid.innerHTML = `<div class="mlx-empty">
          <span class="material-symbols-outlined">search_off</span>
          <p>No materials match these filters.</p>
        </div>`;
        return;
      }
      grid.innerHTML = filtered.map(m => catalogCard(m, false)).join('');
      bindOpen(grid);
    }

    try {
      const r = await fetch('/reviewee/api/materials');
      if (!r.ok) throw new Error('load');
      const data = await r.json();
      allMaterials = data.materials || [];
      const recDom = data.recommendedDomains || [];

      const hint = document.getElementById('mlx-rec-hint');
      if (recDom.length) {
        hint.textContent = 'Weighted toward: ' + recDom.slice(0, 3).map(d => d.replace(' Ability', '')).join(', ');
      } else {
        hint.textContent = 'Balanced picks across the library';
      }

      const recGrid = document.getElementById('mlx-rec-grid');
      const recs = allMaterials.filter(m => m.isRecommended).slice(0, 5);
      if (!recs.length) {
        recGrid.innerHTML = `<div class="mlx-empty mlx-empty--soft">
          <span class="material-symbols-outlined">auto_awesome</span>
          <p>No recommendations yet. Complete your diagnostic so we can suggest materials by domain.</p>
        </div>`;
      } else {
        recGrid.innerHTML = recs.map(m => catalogCard(m, true)).join('');
        bindOpen(recGrid);
      }

      renderBrowse();
    } catch (e) {
      console.error(e);
      document.getElementById('mlx-rec-grid').innerHTML = `<div class="mlx-empty"><p>Could not load materials.</p></div>`;
    }

    document.getElementById('mlx-search').addEventListener('input', e => {
      searchQ = (e.target.value || '').toLowerCase().trim();
      renderBrowse();
    });

    document.getElementById('mlx-sel-domain').addEventListener('change', e => {
      domFilter = e.target.value;
      renderBrowse();
    });
    document.getElementById('mlx-sel-type').addEventListener('change', e => {
      typeFilter = e.target.value;
      renderBrowse();
    });
    document.getElementById('mlx-sel-diff').addEventListener('change', e => {
      diffFilter = e.target.value;
      renderBrowse();
    });
  })();
  </script>

  <%- include('../partials/enrollment-code-modal') %>
  <script src="/js/toast-notifications.js"></script>
</body>
</html>
