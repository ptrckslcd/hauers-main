<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Learning Materials | Hauers</title>
  <link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <script src="/js/theme-toggle.js"></script>
</head>
<body data-role="reviewee">

  <div id="navbar-placeholder"><%- include('../partials/navbar') %></div>

  <div class="app-shell">
    <div class="sidebar-overlay" id="sidebar-overlay"></div>
    <div id="sidebar-placeholder"><%- include('../partials/sidebar') %></div>

    <main class="page-content">

      <!-- ── Page header ── -->
      <header class="page-header">
        <div>
          <h1 class="page-title">Learning Materials</h1>
          <p class="page-subtitle">Curated study resources for your exam preparation</p>
        </div>
        <div class="sp-header-chips">
          <span class="sp-chip sp-chip--week" id="rm-level-chip">Professional</span>
        </div>
      </header>

      <!-- ── Priority: Recommended for you ── -->
      <section class="rm-priority-section" id="rm-priority">
        <div class="rm-priority-header">
          <span class="rm-priority-badge">
            <span class="material-symbols-outlined" style="font-size:15px">bolt</span>
            Priority for You
          </span>
          <p style="font-size:0.83rem;color:var(--text-subdued)" id="rm-priority-sub">Based on your weakest domains</p>
        </div>
        <div class="rm-priority-grid" id="rm-priority-grid">
          <!-- Populated by JS -->
        </div>
      </section>

      <!-- ── Domain tabs + type filter ── -->
      <div class="rm-tabs-bar">
        <div class="rm-tabs" id="rm-domain-tabs">
          <button class="rm-tab active" data-domain="all">All</button>
          <button class="rm-tab" data-domain="Verbal Ability">Verbal</button>
          <button class="rm-tab" data-domain="Numerical Ability">Numerical</button>
          <button class="rm-tab" data-domain="Analytical Ability">Analytical</button>
          <button class="rm-tab" data-domain="Clerical Ability">Clerical</button>
          <button class="rm-tab" data-domain="General Information">General Info</button>
        </div>
        <div class="rm-type-filter" id="rm-type-chips">
          <button class="rm-filter-chip active" data-type="all">All Types</button>
          <button class="rm-filter-chip" data-type="Reference">Reading</button>
          <button class="rm-filter-chip" data-type="Video">Video</button>
          <button class="rm-filter-chip" data-type="Drill Set">Drills</button>
        </div>
      </div>

      <!-- ── Result count ── -->
      <p class="rm-result-msg" id="rm-result-msg"></p>

      <!-- ── Materials grid ── -->
      <div class="rm-grid" id="rm-grid">
        <div style="grid-column:1/-1;text-align:center;padding:3rem 0;color:var(--text-subdued)">Loading materials…</div>
      </div>

    </main>
  </div>

  <script src="/js/app-shell.js"></script>
  <script>
  (async () => {

    /* ── User level chip ──────────────────────────────── */
    try {
      const ur = await fetch('/reviewee/api/user');
      if (ur.ok) {
        const u = await ur.json();
        const chip = document.getElementById('rm-level-chip');
        if (chip && u.examLevel) chip.textContent = u.examLevel;
      }
    } catch (_) {}

    /* ── Fetch data ──────────────────────────────────── */
    let data;
    try {
      const r = await fetch('/reviewee/api/materials');
      if (!r.ok) return;
      data = await r.json();
    } catch (_) { return; }

    const materials    = data.materials    || [];
    const recDomains   = data.recommendedDomains || [];

    /* ── Update priority sub ── */
    const subEl = document.getElementById('rm-priority-sub');
    if (subEl && recDomains.length) {
      subEl.textContent = `Based on: ${recDomains.slice(0, 2).map(d => d.replace(' Ability', '')).join(', ')}`;
    }

    /* ── Mock progress/status ── */
    materials.forEach((m, idx) => {
      if (idx % 7 === 0)      { m.status = 'mastered';     m.progress = 100; }
      else if (idx % 3 === 0) { m.status = 'in-progress';  m.progress = Math.floor(Math.random() * 70) + 15; }
      else                    { m.status = 'new';           m.progress = 0; }
    });

    /* ── Helpers ─────────────────────────────────────── */
    const DOMAIN_COLORS = {
      'Verbal Ability':      '#818cf8',
      'Numerical Ability':   '#ff9933',
      'Analytical Ability':  '#2dd4bf',
      'Clerical Ability':    '#f472b6',
      'General Information': '#60a5fa',
    };
    const TYPE_ICONS = {
      'Drill Set':     'fitness_center',
      'Practice Exam': 'assignment',
      'Video':         'play_circle',
      'Reference':     'article',
      'Manual':        'book',
    };
    function domainClass(d) {
      if (d === 'Verbal Ability')    return 'verbal';
      if (d === 'Numerical Ability') return 'numerical';
      if (d === 'Analytical Ability') return 'analytical';
      if (d === 'Clerical Ability')  return 'clerical';
      return 'general';
    }
    function fmtMins(m) {
      const h = Math.floor(m / 60);
      const r = m % 60;
      return h > 0 ? `${h}h ${r}m` : `${r}m`;
    }

    /* ── Card HTML ───────────────────────────────────── */
    function cardHtml(m) {
      const icon      = TYPE_ICONS[m.type] || 'description';
      const color     = DOMAIN_COLORS[m.domain] || '#888';
      const statusMap = { mastered: { cls: 'rm-status--mastered', label: 'Mastered' }, 'in-progress': { cls: 'rm-status--progress', label: 'In Progress' }, new: { cls: 'rm-status--new', label: 'New' } };
      const status    = statusMap[m.status] || statusMap.new;
      return `<div class="rm-card${m.recommended ? ' rm-card--recommended' : ''}" data-domain="${m.domain}" data-type="${m.type}">
        <div class="rm-card-top">
          <span class="rm-status-badge ${status.cls}">${status.label}</span>
          <span class="rm-type-pill">
            <span class="material-symbols-outlined" style="font-size:13px;vertical-align:-2px">${icon}</span>
            ${m.type || 'Material'}
          </span>
        </div>
        <span class="q-domain-badge ${domainClass(m.domain)}" style="margin-bottom:0.5rem">${(m.domain || '').replace(' Ability','')}</span>
        <p class="rm-card-title">${m.title || 'Untitled'}</p>
        <p class="rm-card-desc">${m.desc || ''}</p>
        ${m.progress > 0 ? `<div class="rm-card-progress-wrap">
          <div class="rm-card-progress-label"><span>Progress</span><span>${m.progress}%</span></div>
          <div class="rm-card-progress-track"><div class="rm-card-progress-fill" style="width:${m.progress}%;background:${color}"></div></div>
        </div>` : ''}
        <div class="rm-card-footer">
          ${m.estMinutes ? `<span class="rm-card-time"><span class="material-symbols-outlined" style="font-size:13px;vertical-align:-2px">schedule</span> ${fmtMins(m.estMinutes)}</span>` : ''}
          <a href="#" class="rm-open-btn">Open</a>
        </div>
      </div>`;
    }

    /* ── Render grids ────────────────────────────────── */
    const grid      = document.getElementById('rm-grid');
    const priGrid   = document.getElementById('rm-priority-grid');
    const resultMsg = document.getElementById('rm-result-msg');

    // Priority: recommended materials, preferring weak domains
    const prioritized = materials
      .filter(m => recDomains.length ? recDomains.includes(m.domain) : m.recommended)
      .slice(0, 3);
    if (priGrid) {
      priGrid.innerHTML = prioritized.length
        ? prioritized.map(cardHtml).join('')
        : materials.filter(m => m.recommended).slice(0, 3).map(cardHtml).join('');
    }
    const priSection = document.getElementById('rm-priority');
    if (priSection && !prioritized.length && !materials.some(m => m.recommended)) {
      priSection.style.display = 'none';
    }

    let activeDomain = 'all';
    let activeType   = 'all';

    function applyFilters() {
      return materials.filter(m => {
        const dm = activeDomain === 'all' || m.domain === activeDomain;
        const tm = activeType === 'all' ||
          (activeType === 'Reference' && (m.type === 'Reference' || m.type === 'Manual')) ||
          (activeType === 'Video'     && m.type === 'Video') ||
          (activeType === 'Drill Set' && (m.type === 'Drill Set' || m.type === 'Practice Exam'));
        return dm && tm;
      });
    }

    function renderCards() {
      const filtered = applyFilters();
      if (!grid) return;
      if (!filtered.length) {
        grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:3rem 0;color:var(--text-subdued)"><span class="material-symbols-outlined" style="font-size:2rem;display:block;margin-bottom:0.5rem">search_off</span>No materials match your filters.</div>';
        if (resultMsg) resultMsg.textContent = '';
        return;
      }
      grid.innerHTML = filtered.map(cardHtml).join('');
      if (resultMsg) resultMsg.textContent = filtered.length < materials.length ? `Showing ${filtered.length} of ${materials.length} materials` : '';
    }

    renderCards();

    /* ── Domain tabs ─────────────────────────────────── */
    document.getElementById('rm-domain-tabs').addEventListener('click', e => {
      const tab = e.target.closest('.rm-tab');
      if (!tab) return;
      document.querySelectorAll('#rm-domain-tabs .rm-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      activeDomain = tab.dataset.domain;
      const priSec = document.getElementById('rm-priority');
      if (priSec) priSec.style.display = activeDomain === 'all' ? 'block' : 'none';
      renderCards();
    });

    /* ── Type filter chips ───────────────────────────── */
    document.getElementById('rm-type-chips').addEventListener('click', e => {
      const chip = e.target.closest('.rm-filter-chip');
      if (!chip) return;
      document.querySelectorAll('#rm-type-chips .rm-filter-chip').forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
      activeType = chip.dataset.type;
      renderCards();
    });

  })();
  </script>
</body>
</html>
