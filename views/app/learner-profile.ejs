<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Profile | Hauers</title>
  <link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
  <link rel="stylesheet" href="/css/base.css">
  <link rel="stylesheet" href="/css/dashboard.css">
  <script src="/js/theme-toggle.js"></script>
</head>
<body data-role="reviewee">

  <div id="navbar-placeholder"><%- include('../partials/navbar') %></div>

  <div class="app-shell">
    <div class="sidebar-overlay" id="sidebar-overlay"></div>
    <div id="sidebar-placeholder"><%- include('../partials/sidebar') %></div>

    <main class="page-content">

      <header class="page-header">
        <h1 class="page-title">My Profile</h1>
      </header>

      <!-- Row 1: Identity + Exam Summary — equal columns -->
      <div class="prf-row-hero">

        <!-- Identity card -->
        <div class="dash-card prf-identity-card">
          <div class="prf-identity-hero">
            <div class="prf-avatar" id="prf-avatar">U</div>
            <div class="prf-identity-body">
              <p class="prf-name" id="prf-name">—</p>
              <p class="prf-email-sub" id="prf-email-sub">—</p>
              <div class="prf-chips">
                <span class="prf-chip prf-chip--level" id="prf-level-chip">—</span>
                <span class="prf-chip prf-chip--batch" id="prf-batch-chip" hidden>—</span>
                <span class="prf-chip prf-chip--streak" id="prf-streak-chip" hidden>—</span>
              </div>
            </div>
          </div>

          <div class="prf-divider"></div>

          <div class="prf-identity-meta">
            <div class="prf-meta-tile">
              <span class="material-symbols-outlined prf-meta-tile-ic">history_edu</span>
              <p class="prf-meta-tile-lbl">Member since</p>
              <p class="prf-meta-tile-val" id="pf-since">—</p>
            </div>
            <div class="prf-meta-tile">
              <span class="material-symbols-outlined prf-meta-tile-ic">schedule</span>
              <p class="prf-meta-tile-lbl">Study hrs / wk</p>
              <p class="prf-meta-tile-val" id="pf-id-hours">—</p>
            </div>
            <div class="prf-meta-tile">
              <span class="material-symbols-outlined prf-meta-tile-ic">wb_sunny</span>
              <p class="prf-meta-tile-lbl">Preferred time</p>
              <p class="prf-meta-tile-val" id="pf-id-time">—</p>
            </div>
            <div class="prf-meta-tile">
              <span class="material-symbols-outlined prf-meta-tile-ic">devices</span>
              <p class="prf-meta-tile-lbl">Primary device</p>
              <p class="prf-meta-tile-val" id="pf-id-device">—</p>
            </div>
          </div>

          <div class="prf-identity-actions">
            <button id="btn-edit-profile" class="prf-edit-btn" type="button">
              <span class="material-symbols-outlined">edit_note</span>
              Edit Profile
            </button>
          </div>
        </div>

        <!-- Exam Summary card -->
        <div class="dash-card prf-exam-card">
          <p class="pgx-section-label pgx-section-label--flush" style="margin-bottom:0.75rem">Exam Overview</p>

          <div class="prf-countdown-block">
            <div>
              <span class="prf-countdown-num" id="prf-days">—</span>
              <span class="prf-countdown-unit">days</span>
            </div>
            <p class="prf-countdown-label">until your exam</p>
          </div>

          <div class="prf-exam-tiles">
            <div class="prf-meta-tile">
              <span class="material-symbols-outlined prf-meta-tile-ic">calendar_today</span>
              <p class="prf-meta-tile-lbl">Exam date</p>
              <p class="prf-meta-tile-val" id="pf-exam-date">—</p>
            </div>
            <div class="prf-meta-tile">
              <span class="material-symbols-outlined prf-meta-tile-ic">school</span>
              <p class="prf-meta-tile-lbl">Level</p>
              <p class="prf-meta-tile-val" id="pf-exam-level">—</p>
            </div>
            <div class="prf-meta-tile">
              <span class="material-symbols-outlined prf-meta-tile-ic">format_list_numbered</span>
              <p class="prf-meta-tile-lbl">Items</p>
              <p class="prf-meta-tile-val">170 &middot; Paper &amp; Pen</p>
            </div>
            <div class="prf-meta-tile">
              <span class="material-symbols-outlined prf-meta-tile-ic">flag</span>
              <p class="prf-meta-tile-lbl">Passing score</p>
              <p class="prf-meta-tile-val">80%</p>
            </div>
          </div>

          <p class="pgx-section-label pgx-section-label--flush" style="margin-bottom:0.6rem">Readiness</p>
          <div class="prf-readiness-row">
            <div class="prf-readiness-gauge">
              <canvas id="prf-gauge-chart"></canvas>
              <div class="prf-gauge-overlay">
                <span class="prf-gauge-pct" id="prf-gauge-val">0</span>
                <span class="prf-gauge-unit">%</span>
              </div>
            </div>
            <div class="prf-readiness-info">
              <p class="prf-readiness-status" id="prf-readiness-status">—</p>
              <p class="prf-readiness-sub">Based on quiz performance</p>
            </div>
          </div>
        </div>

      </div><!-- /.prf-row-hero -->

      <!-- Domain Self-Rating vs M-Elo -->
      <div class="dash-card prf-ratings-card">
        <p class="pgx-section-label pgx-section-label--flush" style="margin-bottom:0.85rem">Domain Self-Rating vs Performance</p>
        <div class="prf-ratings-table" id="prf-ratings-table">
          <div class="prf-ratings-loading">
            <span class="material-symbols-outlined">bar_chart</span>
            <p>Loading domain data…</p>
          </div>
        </div>
      </div>

    </main>
  </div>

  <!-- Edit Profile Modal -->
  <div class="prf-modal-overlay" id="prf-modal-overlay" hidden>
    <div class="prf-modal" role="dialog" aria-modal="true" aria-labelledby="prf-modal-title">
      <div class="prf-modal-head">
        <h2 class="prf-modal-title" id="prf-modal-title">Edit Profile</h2>
        <button type="button" class="prf-modal-close" id="prf-modal-close" aria-label="Close">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>

      <form class="prf-modal-form" id="prf-modal-form" autocomplete="off">
        <!-- Locked fields -->
        <div class="prf-modal-locked-row">
          <div class="prf-modal-locked-field">
            <span class="prf-form-label">Email Address</span>
            <span class="prf-locked-value" id="ep-email-locked">—</span>
            <span class="prf-locked-badge">
              <span class="material-symbols-outlined" style="font-size:12px">lock</span>
              Not editable
            </span>
          </div>
          <div class="prf-modal-locked-field">
            <span class="prf-form-label">Exam Level</span>
            <span class="prf-locked-value" id="ep-level-locked">—</span>
            <span class="prf-locked-badge">
              <span class="material-symbols-outlined" style="font-size:12px">lock</span>
              Set by enrollment
            </span>
          </div>
        </div>

        <div class="prf-modal-divider"></div>

        <div class="prf-form-row">
          <div class="prf-form-field">
            <label class="prf-form-label" for="ep-firstname">First Name</label>
            <input class="prf-form-input" type="text" id="ep-firstname" name="firstName" required placeholder="First name">
          </div>
          <div class="prf-form-field">
            <label class="prf-form-label" for="ep-lastname">Last Name</label>
            <input class="prf-form-input" type="text" id="ep-lastname" name="lastName" required placeholder="Last name">
          </div>
        </div>

        <div class="prf-modal-divider"></div>

        <p class="prf-form-section-label">Study Preferences</p>

        <div class="prf-form-row">
          <div class="prf-form-field">
            <label class="prf-form-label" for="ep-hours">Study Hours / Week</label>
            <input class="prf-form-input" type="number" id="ep-hours" name="studyHours" min="1" max="80" placeholder="e.g. 10">
          </div>
          <div class="prf-form-field">
            <label class="prf-form-label" for="ep-time">Preferred Study Time</label>
            <select class="prf-form-input prf-form-select" id="ep-time" name="preferredStudyTime">
              <option value="">Not specified</option>
              <option value="morning">Morning</option>
              <option value="afternoon">Afternoon</option>
              <option value="evening">Evening</option>
            </select>
          </div>
        </div>

        <div class="prf-form-field">
          <label class="prf-form-label" for="ep-device">Primary Device</label>
          <select class="prf-form-input prf-form-select" id="ep-device" name="primaryDevice">
            <option value="">Not specified</option>
            <option value="desktop">Desktop / Laptop</option>
            <option value="mobile">Mobile Phone</option>
            <option value="tablet">Tablet</option>
          </select>
        </div>

        <div class="prf-modal-actions">
          <button type="button" class="prf-modal-cancel" id="prf-modal-cancel">Cancel</button>
          <button type="submit" class="prf-save-btn" id="ep-save">
            <span id="ep-save-text">Save Changes</span>
            <span id="ep-save-spin" hidden style="opacity:0.7">Saving…</span>
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Toast -->
  <div class="prf-toast" id="prf-toast" hidden>
    <span class="material-symbols-outlined prf-toast-icon" id="prf-toast-icon">check_circle</span>
    <span id="prf-toast-msg">Saved successfully.</span>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
  <script src="/js/app-shell.js"></script>
  <script>
  (async () => {
    const $ = id => document.getElementById(id);
    const set = (id, v) => { const e = $(id); if (e) e.textContent = v; };

    function fmtDate(ts) {
      if (!ts) return '—';
      return new Date(ts).toLocaleDateString('en-PH', { month: 'long', day: 'numeric', year: 'numeric' });
    }
    function capitalize(s) {
      if (!s) return '—';
      return s.charAt(0).toUpperCase() + s.slice(1).toLowerCase();
    }

    /* ── Toast ── */
    function showToast(msg, isError) {
      const toast = $('prf-toast');
      const icon  = $('prf-toast-icon');
      $('prf-toast-msg').textContent = msg;
      if (icon) { icon.textContent = isError ? 'error' : 'check_circle'; icon.style.color = isError ? '#ef4444' : '#4ade80'; }
      toast.removeAttribute('hidden');
      requestAnimationFrame(() => {
        toast.classList.add('prf-toast--show');
        setTimeout(() => {
          toast.classList.remove('prf-toast--show');
          setTimeout(() => toast.setAttribute('hidden', ''), 300);
        }, 3000);
      });
    }

    /* ── Load ── */
    let profileData = {};
    try {
      const r = await fetch('/reviewee/api/profile');
      if (!r.ok) throw new Error('load');
      profileData = await r.json();
    } catch { return; }

    const { user, batchName, learnerProfile: lp, selfRatings = [], domainThetas = [],
            readinessScore = 0, streak = 0, examDate } = profileData;

    /* ── Identity ── */
    if (user) {
      const initial  = (user.firstName || 'U')[0].toUpperCase();
      const fullName = user.firstName + ' ' + user.lastName;

      $('prf-avatar').textContent    = initial;
      $('prf-name').textContent      = fullName;
      $('prf-email-sub').textContent = user.email;

      set('pf-since',      fmtDate(user.createdAt));
      set('pf-exam-level', capitalize(user.examLevel));
      if (lp) {
        set('pf-id-hours',  lp.study_hours_per_week != null ? lp.study_hours_per_week + ' hrs' : 'Not set');
        set('pf-id-time',   capitalize(lp.preferred_study_time));
        set('pf-id-device', capitalize(lp.primary_device));
      }

      const lvlChip = $('prf-level-chip');
      if (lvlChip) lvlChip.textContent = capitalize(user.examLevel);

      const batchChip = $('prf-batch-chip');
      if (batchChip && batchName) { batchChip.textContent = batchName; batchChip.removeAttribute('hidden'); }

      if (streak > 0) {
        const sc = $('prf-streak-chip');
        if (sc) { sc.textContent = streak + '-day streak'; sc.removeAttribute('hidden'); }
      }

      window.__prfCache = { ...user, batchName, lp };
    }

    /* ── Exam countdown ── */
    if (examDate) {
      const d = Math.max(0, Math.ceil((new Date(examDate) - Date.now()) / 86400000));
      set('prf-days', d);
      set('pf-exam-date', fmtDate(examDate));
    }

    /* ── Readiness gauge ── */
    const gaugeEl = $('prf-gauge-chart');
    if (gaugeEl) {
      const pct   = readinessScore;
      const isDark = () => document.documentElement.dataset.theme === 'dark';
      const color = pct >= 80 ? '#4ade80' : pct >= 60 ? '#fb923c' : '#f87171';
      const track = isDark() ? 'rgba(255,255,255,0.07)' : 'rgba(15,23,42,0.07)';
      new Chart(gaugeEl, {
        type: 'doughnut',
        data: { datasets: [{ data: [Math.max(pct,0), Math.max(100-pct,0)], backgroundColor: [color, track], borderWidth: 0, hoverOffset: 0 }] },
        options: { rotation: -90, circumference: 360, cutout: '76%', responsive: true, maintainAspectRatio: true, plugins: { legend: { display: false }, tooltip: { enabled: false } }, animation: { duration: 1200, easing: 'easeInOutQuart' } },
      });
      const valEl = $('prf-gauge-val');
      if (valEl && pct > 0) {
        let v = 0;
        const step = () => { v = Math.min(v + Math.max(1, Math.ceil((pct - v) / 12)), pct); valEl.textContent = v; if (v < pct) requestAnimationFrame(step); };
        requestAnimationFrame(step);
      }
      const statusEl = $('prf-readiness-status');
      if (statusEl) {
        if (pct === 0)      statusEl.textContent = 'Complete the diagnostic to see your score.';
        else if (pct >= 80) { statusEl.textContent = 'Above passing threshold'; statusEl.style.color = '#4ade80'; }
        else if (pct >= 60) statusEl.textContent = `${80 - pct} pts below passing`;
        else                statusEl.textContent = `${80 - pct} pts to reach 80%`;
      }
    }


    /* ── Domain ratings table ── */
    const ratingsTable = $('prf-ratings-table');
    if (ratingsTable) {
      const thetaMap  = Object.fromEntries(domainThetas.map(t => [t.domain, t.theta]));
      const ratingMap = Object.fromEntries(selfRatings.map(r => [r.domain, r.rating]));
      const allDomains = [...new Set([...selfRatings.map(r => r.domain), ...domainThetas.map(t => t.domain)])];

      if (!allDomains.length) {
        ratingsTable.innerHTML = `<div class="prf-ratings-empty"><span class="material-symbols-outlined">bar_chart</span><p>Complete the onboarding to see your domain ratings and performance data.</p></div>`;
      } else {
        const thetaToPercent = t => Math.max(0, Math.min(100, Math.round((t - 800) / 8)));
        const DOMAIN_COLOR = { 'Verbal Ability':'#818cf8','Numerical Ability':'#fb923c','Analytical Ability':'#2dd4bf','Clerical Ability':'#f472b6','General Information':'#60a5fa' };

        ratingsTable.innerHTML = `
          <div class="prf-rt-head">
            <span>Domain</span>
            <span>Self-Rating</span>
            <span>M-Elo Performance</span>
            <span>Status</span>
          </div>
          ${allDomains.map(domain => {
            const rating = ratingMap[domain] || 0;
            const theta  = thetaMap[domain]  || null;
            const eloPct = theta ? thetaToPercent(theta) : null;
            const color  = DOMAIN_COLOR[domain] || '#888';
            const short  = domain.replace(' Ability','');
            const stars  = Array.from({length:5},(_,i)=>`<span class="prf-star${i<rating?' prf-star--on':''}">★</span>`).join('');
            let statusTxt='No data', statusCls='muted';
            if (eloPct !== null) {
              if (eloPct >= 80)      { statusTxt='Strong';     statusCls='good'; }
              else if (eloPct >= 60) { statusTxt='On track';   statusCls='ok';   }
              else                   { statusTxt='Needs work'; statusCls='warn'; }
            }
            return `<div class="prf-rt-row">
              <div class="prf-rt-domain"><span class="prf-rt-dot" style="background:${color}"></span><span>${short}</span></div>
              <div class="prf-rt-stars" aria-label="${rating} out of 5">${stars}</div>
              <div class="prf-rt-elo">
                ${eloPct!==null?`<div class="prf-elo-bar-wrap"><div class="prf-elo-bar-fill" style="width:${eloPct}%;background:${color}"></div></div><span class="prf-elo-pct">${eloPct}%</span>`:'<span class="prf-rt-none">—</span>'}
              </div>
              <span class="prf-rt-status prf-rt-status--${statusCls}">${statusTxt}</span>
            </div>`;
          }).join('')}`;
      }
    }


    /* ═══ EDIT MODAL ═══ */
    const overlay = $('prf-modal-overlay');
    const form    = $('prf-modal-form');

    function openModal() {
      const c = window.__prfCache || {};
      const lpr = c.lp || {};
      $('ep-firstname').value        = c.firstName || '';
      $('ep-lastname').value         = c.lastName  || '';
      $('ep-email-locked').textContent = c.email   || '—';
      $('ep-level-locked').textContent = capitalize(c.examLevel) || '—';
      $('ep-hours').value  = lpr.study_hours_per_week != null ? lpr.study_hours_per_week : '';
      $('ep-time').value   = lpr.preferred_study_time || '';
      $('ep-device').value = lpr.primary_device       || '';
      overlay.removeAttribute('hidden');
      setTimeout(() => $('ep-firstname').focus(), 50);
    }
    function closeModal() { overlay.setAttribute('hidden', ''); }

    $('btn-edit-profile').addEventListener('click', openModal);
    $('prf-modal-close').addEventListener('click',  closeModal);
    $('prf-modal-cancel').addEventListener('click', closeModal);
    overlay.addEventListener('click', e => { if (e.target === overlay) closeModal(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape' && !overlay.hidden) closeModal(); });

    form.addEventListener('submit', async e => {
      e.preventDefault();
      $('ep-save-text').hidden = true;
      $('ep-save-spin').removeAttribute('hidden');

      const payload = {
        firstName:          $('ep-firstname').value.trim(),
        lastName:           $('ep-lastname').value.trim(),
        studyHours:         $('ep-hours').value ? Number($('ep-hours').value) : null,
        preferredStudyTime: $('ep-time').value  || null,
        primaryDevice:      $('ep-device').value || null,
      };

      try {
        const r = await fetch('/reviewee/api/profile/update', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload),
        });
        const result = await r.json();
        if (!r.ok) { showToast(result.error || 'Update failed.', true); return; }

        const u = result.user;
        const fullName = u.firstName + ' ' + u.lastName;
        const initial  = u.firstName[0].toUpperCase();

        $('prf-avatar').textContent    = initial;
        $('prf-name').textContent      = fullName;

        const h = payload.studyHours;
        set('pf-id-hours',  h != null ? h + ' hrs' : 'Not set');
        set('pf-id-time',   capitalize(payload.preferredStudyTime));
        set('pf-id-device', capitalize(payload.primaryDevice));

        const navName   = document.getElementById('nav-user-name');
        const navAvatar = document.getElementById('nav-avatar');
        if (navName)   navName.textContent   = fullName;
        if (navAvatar) navAvatar.textContent = initial;

        window.__prfCache = { ...window.__prfCache, ...u, lp: { ...((window.__prfCache||{}).lp||{}), study_hours_per_week: payload.studyHours, preferred_study_time: payload.preferredStudyTime, primary_device: payload.primaryDevice } };

        closeModal();
        showToast('Profile updated successfully.');
      } catch { showToast('Network error. Please try again.', true); }
      finally {
        $('ep-save-text').hidden = false;
        $('ep-save-spin').setAttribute('hidden', '');
      }
    });

  })();
  </script>

  <%- include('../partials/enrollment-code-modal') %>
  <script src="/js/toast-notifications.js"></script>
</body>
</html>
