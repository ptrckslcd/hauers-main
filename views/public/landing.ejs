  <script>
    (function () {
      const els = document.querySelectorAll('[data-reveal]');
      if (!els.length) return;
      const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.1 });
      els.forEach(el => io.observe(el));
    })();

    (function () {
      const hero = document.querySelector('.hero-section');
      if (!hero) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      let targetCx = 50;
      let targetCy = 50;
      let curCx = 50;
      let curCy = 50;
      let raf = 0;

      function tick() {
        raf = 0;
        curCx += (targetCx - curCx) * 0.2;
        curCy += (targetCy - curCy) * 0.2;
        hero.style.setProperty('--hero-cx', curCx.toFixed(2) + '%');
        hero.style.setProperty('--hero-cy', curCy.toFixed(2) + '%');
        if (Math.abs(targetCx - curCx) > 0.04 || Math.abs(targetCy - curCy) > 0.04) {
          raf = requestAnimationFrame(tick);
        }
      }

      function queueTick() {
        if (!raf) raf = requestAnimationFrame(tick);
      }

      hero.addEventListener('mousemove', function (e) {
        const r = hero.getBoundingClientRect();
        targetCx = ((e.clientX - r.left) / Math.max(r.width, 1)) * 100;
        targetCy = ((e.clientY - r.top) / Math.max(r.height, 1)) * 100;
        queueTick();
      }, { passive: true });

      hero.addEventListener('mouseleave', function () {
        targetCx = 50;
        targetCy = 50;
        queueTick();
      });
    })();

    (function () {
      function initReadinessRadar() {
        const canvas = document.getElementById('readinessRadarChart');
        if (!canvas || typeof Chart === 'undefined') return null;

        const labels = ['Verbal', 'Numerical', 'Analytical', 'Constitution', 'Ethics', 'Environment'];
        const profile = [82, 64, 77, 58, 72, 63];
        const targetRing = [80, 80, 80, 80, 80, 80];

        function theme() {
          const dark = document.documentElement.getAttribute('data-theme') === 'dark';
          if (dark) {
            return {
              grid: 'rgba(147, 197, 253, 0.24)',
              angle: 'rgba(147, 197, 253, 0.14)',
              ticks: 'rgba(226, 232, 240, 0.82)',
              fill: 'rgba(59, 130, 246, 0.3)',
              stroke: '#93C5FD',
              target: '#FBBF24',
              pointBg: '#3B82F6',
              pointBorder: '#F5A623',
            };
          }
          return {
            grid: 'rgba(37, 99, 235, 0.16)',
            angle: 'rgba(37, 99, 235, 0.1)',
            ticks: 'rgba(30, 41, 59, 0.88)',
            fill: 'rgba(37, 99, 235, 0.24)',
            stroke: '#1E40AF',
            target: '#CA8A04',
            pointBg: '#2563EB',
            pointBorder: '#D97706',
          };
        }

        function makeConfig() {
          const c = theme();
          const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          return {
            type: 'radar',
            data: {
              labels,
              datasets: [
                {
                  label: 'Domain score',
                  data: profile,
                  fill: true,
                  backgroundColor: c.fill,
                  borderColor: c.stroke,
                  borderWidth: 2.5,
                  pointBackgroundColor: c.pointBg,
                  pointBorderColor: c.pointBorder,
                  pointBorderWidth: 2,
                  pointHoverBackgroundColor: c.pointBorder,
                  pointHoverBorderColor: '#ffffff',
                  pointRadius: 4,
                  pointHoverRadius: 6,
                },
                {
                  label: 'CSC target',
                  data: targetRing,
                  fill: false,
                  borderColor: c.target,
                  borderWidth: 2,
                  borderDash: [7, 5],
                  pointRadius: 0,
                  pointHoverRadius: 0,
                },
              ],
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              scales: {
                r: {
                  min: 0,
                  max: 100,
                  beginAtZero: true,
                  ticks: {
                    stepSize: 20,
                    backdropColor: 'transparent',
                    color: c.ticks,
                    font: { size: 10, weight: 600, family: "'Plus Jakarta Sans', system-ui, sans-serif" },
                  },
                  grid: { color: c.grid },
                  angleLines: { color: c.angle },
                  pointLabels: {
                    color: c.ticks,
                    font: { size: 11, weight: 700, family: "'Plus Jakarta Sans', system-ui, sans-serif" },
                  },
                },
              },
              plugins: {
                legend: { display: false },
                tooltip: {
                  callbacks: {
                    label(ctx) {
                      if (ctx.datasetIndex === 1) return ' CSC passing line: 80%';
                      return ' ' + ctx.label + ': ' + ctx.formattedValue + '%';
                    },
                  },
                },
              },
              animation: reduced ? false : { duration: 1300 },
            },
          };
        }

        let chart = new Chart(canvas, makeConfig());

        const mo = new MutationObserver(() => {
          chart.destroy();
          chart = new Chart(canvas, makeConfig());
        });
        mo.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

        return function cleanup() {
          mo.disconnect();
          chart.destroy();
        };
      }

      function bootChart() {
        initReadinessRadar();
      }

      if (document.readyState === 'complete') bootChart();
      else window.addEventListener('load', bootChart);
    })();
  </script>
</body>

</html>
