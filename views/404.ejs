<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Page Not Found | Hauers</title>
  <link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
  <link rel="stylesheet" href="/css/base.css">
  <script src="/js/theme-toggle.js"></script>
  <style>
    body { display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; font-family: 'Inter', 'Plus Jakarta Sans', sans-serif; background: var(--bg-base, #f8fafc); color: var(--text-main, #0f172a); }
    .err-wrap { text-align: center; padding: 2rem; max-width: 420px; }
    .err-code { font-size: 6rem; font-weight: 900; line-height: 1; color: #2563EB; font-family: 'Plus Jakarta Sans', sans-serif; margin: 0 0 0.5rem; letter-spacing: -0.03em; }
    .err-title { font-size: 1.35rem; font-weight: 700; margin: 0 0 0.5rem; }
    .err-sub { font-size: 0.9rem; color: #64748b; margin: 0 0 2rem; line-height: 1.6; }
    .err-btn { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.6rem 1.4rem; background: #2563EB; color: #fff; border-radius: 8px; font-size: 0.88rem; font-weight: 600; text-decoration: none; transition: background 130ms; }
    .err-btn:hover { background: #1d4ed8; }
  </style>
</head>
<body>
  <div class="err-wrap">
    <p class="err-code">404</p>
    <h1 class="err-title">Page not found</h1>
    <p class="err-sub">The page you're looking for doesn't exist or has been moved.</p>
    <a href="/" class="err-btn">Go to Homepage</a>
  </div>
</body>
</html>
