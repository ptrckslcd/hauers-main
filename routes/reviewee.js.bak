/* ── API: dashboard data ─────────────────────────────────── */
router.get('/api/dashboard', requireAuth, (req, res) => {
  const user = req.session.user;
  res.json({
    user: {
      firstName: user.firstName,
      lastName:  user.lastName,
      email:     user.email,
      examLevel: user.examLevel || 'Professional',
    },
    ...dashboardData,
    diagnostic: diagnosticData,
  });
});

